--- /dev/null
+++ b/src/nautilus-macos-integration.m
@@ -0,0 +1,1453 @@
+/*
+ * nautilus-macos-integration.m: opt-in, reversible Finder integration (W12).
+ *
+ * Copyright (C) 2026 The Nautilus authors
+ *
+ * This program is free software; you can redistribute it and/or
+ * modify it under the terms of the GNU General Public License as
+ * published by the Free Software Foundation; either version 2 of the
+ * License, or (at your option) any later version.
+ *
+ * This program is distributed in the hope that it will be useful,
+ * but WITHOUT ANY WARRANTY; without even the implied warranty of
+ * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU
+ * General Public License for more details.
+ *
+ * You should have received a copy of the GNU General Public
+ * License along with this program; if not, see <http://www.gnu.org/licenses/>.
+ *
+ * ==========================================================================
+ * DESIGN CONTRACT — READ BEFORE EDITING
+ *
+ * Three INDEPENDENT, individually-toggleable integrations, all OFF by
+ * default, all fully revertible:
+ *
+ *   1. DEFAULT_HANDLER — make Nautilus the default app for public.folder.
+ *      apply saves the current handler's bundle id first; revert restores
+ *      exactly that (falling back to com.apple.finder only if nothing was
+ *      recorded, which matches the factory state).
+ *   2. FAVORITES — one-shot two-way sync between Finder's shared favorites
+ *      (LSSharedFileList, deprecated-but-functional; NEVER raw .sfl3/.sfl4
+ *      file writes) and Nautilus bookmarks (~/.config/gtk-3.0/bookmarks).
+ *      apply records exactly which items IT added on each side; revert
+ *      removes only those, never user-created entries. If the shared-list
+ *      API turns out to be write-broken at runtime, apply degrades to
+ *      import-only and says so.
+ *   3. HIDE_DESKTOP — set com.apple.finder CreateDesktop=false and relaunch
+ *      Finder. apply saves the pre-change value (including "key absent");
+ *      revert restores it bit-for-bit. Finder is relaunched (SIGTERM, the
+ *      same thing `killall Finder` does) ONLY inside apply/revert — i.e.
+ *      only when the user explicitly flipped the toggle. Never at startup.
+ *
+ * NOTHING in this file mutates system state at startup: the only functions
+ * safe-and-intended for launch time are the status/read functions, the
+ * first-run-dialog gate, and the (passive) NSServices provider
+ * registration. apply/revert run exclusively from the preferences toggles
+ * and the Revert All button.
+ *
+ * State keyfile: $XDG_CONFIG_HOME/nautilus/macos-integration.ini. It stores
+ * BOTH what we changed and the pre-change value, so revert restores the
+ * user's original state rather than a hardcoded default.
+ *
+ * DRY-RUN: with NAUTILUS_INTEGRATION_DRY_RUN=1 every out-of-process/system
+ * mutation (LaunchServices default-handler write, shared-favorites-list
+ * write, com.apple.finder defaults write, Finder relaunch) is logged
+ * verbatim via g_message("DRY-RUN: …") and skipped. Bookkeeping inside
+ * $XDG_CONFIG_HOME (the state keyfile and the gtk-3.0/bookmarks file) still
+ * executes, so a harness pointing XDG_CONFIG_HOME at a temp dir can verify
+ * the full record/revert round trip without touching anything real.
+ *
+ * MOCK FAVORITES: with NAUTILUS_INTEGRATION_MOCK_FAVORITES=<path>, the
+ * "Finder favorites list" is read from and written to that plain-text file
+ * (one URI per line, optional display name after a space) instead of
+ * LSSharedFileList — a sandbox for exercising the favorites bookkeeping.
+ * ==========================================================================
+ */
+
+#define G_LOG_DOMAIN "nautilus-macos-bridge"
+
+#include <config.h>
+#include "nautilus-macos-bridge.h"
+
+#include <adwaita.h>
+#include <glib/gi18n.h>
+
+#import <AppKit/AppKit.h>
+#import <CoreServices/CoreServices.h>
+#import <UniformTypeIdentifiers/UniformTypeIdentifiers.h>
+
+#include <signal.h>
+
+#define FINDER_BUNDLE_ID "com.apple.finder"
+
+/* The macOS bundle identifier stamped into the installed .app's Info.plist
+ * (package/Info.plist.template). Distinct from APPLICATION_ID (the GLib
+ * application id, which stays org.gnome.Nautilus internally): LaunchServices
+ * knows the app by THIS id. */
+#define MACOS_BUNDLE_ID "com.intuition.shenzhenfiles"
+
+/* --- Keyfile layout -------------------------------------------------------
+ * [integration]  choice-made            first-run dialog shown (any answer)
+ * [default-handler] enabled             our toggle state
+ *                   previous-handler    bundle id saved before apply
+ * [favorites]    enabled
+ *                imported-bookmarks     URIs WE added to gtk-3.0/bookmarks
+ *                exported-urls          URIs WE inserted into the shared list
+ *                export-supported       FALSE => degraded to import-only
+ * [desktop]      enabled
+ *                had-previous-value     was CreateDesktop set at all?
+ *                previous-create-desktop  its value if so
+ * ------------------------------------------------------------------------- */
+
+#define STATE_GROUP_INTEGRATION "integration"
+#define STATE_KEY_CHOICE_MADE "choice-made"
+
+#define STATE_GROUP_HANDLER "default-handler"
+#define STATE_GROUP_FAVORITES "favorites"
+#define STATE_GROUP_DESKTOP "desktop"
+
+#define STATE_KEY_ENABLED "enabled"
+#define STATE_KEY_PREVIOUS_HANDLER "previous-handler"
+#define STATE_KEY_IMPORTED_BOOKMARKS "imported-bookmarks"
+#define STATE_KEY_EXPORTED_URLS "exported-urls"
+#define STATE_KEY_EXPORT_SUPPORTED "export-supported"
+#define STATE_KEY_HAD_PREVIOUS_VALUE "had-previous-value"
+#define STATE_KEY_PREVIOUS_CREATE_DESKTOP "previous-create-desktop"
+
+/* --- Dry-run --------------------------------------------------------------- */
+
+gboolean
+nautilus_macos_integration_is_dry_run (void)
+{
+    const char *value = g_getenv ("NAUTILUS_INTEGRATION_DRY_RUN");
+
+    return value != NULL && g_strcmp0 (value, "0") != 0 && value[0] != '\0';
+}
+
+/* --- State keyfile --------------------------------------------------------- */
+
+static char *
+integration_state_path (void)
+{
+    return g_build_filename (g_get_user_config_dir (), "nautilus",
+                             "macos-integration.ini", NULL);
+}
+
+static GKeyFile *
+integration_state_load (void)
+{
+    g_autofree char *path = integration_state_path ();
+    GKeyFile *key_file = g_key_file_new ();
+
+    /* Missing file is fine: everything defaults to OFF/unset. */
+    g_key_file_load_from_file (key_file, path, G_KEY_FILE_KEEP_COMMENTS, NULL);
+
+    return key_file;
+}
+
+static gboolean
+integration_state_save (GKeyFile *key_file,
+                        GError  **error)
+{
+    g_autofree char *path = integration_state_path ();
+    g_autofree char *dir = g_path_get_dirname (path);
+
+    g_mkdir_with_parents (dir, 0700);
+
+    return g_key_file_save_to_file (key_file, path, error);
+}
+
+static const char *
+integration_state_group (NautilusMacosIntegration which)
+{
+    switch (which)
+    {
+        case NAUTILUS_MACOS_INTEGRATION_DEFAULT_HANDLER: { return STATE_GROUP_HANDLER; }
+        case NAUTILUS_MACOS_INTEGRATION_FAVORITES: { return STATE_GROUP_FAVORITES; }
+        case NAUTILUS_MACOS_INTEGRATION_HIDE_DESKTOP: { return STATE_GROUP_DESKTOP; }
+        default: { g_assert_not_reached (); }
+    }
+}
+
+gboolean
+nautilus_macos_integration_get_enabled (NautilusMacosIntegration which)
+{
+    g_autoptr (GKeyFile) key_file = integration_state_load ();
+
+    return g_key_file_get_boolean (key_file, integration_state_group (which),
+                                   STATE_KEY_ENABLED, NULL);
+}
+
+/* --- Default folder handler ------------------------------------------------ */
+
+/* Bundle id of the current default app for public.folder, or NULL if it
+ * cannot be determined. Read-only; safe at any time. */
+static char *
+handler_current_bundle_id (void)
+{
+    @autoreleasepool
+    {
+        NSURL *app_url =
+            [[NSWorkspace sharedWorkspace] URLForApplicationToOpenContentType:UTTypeFolder];
+
+        if (app_url == nil)
+        {
+            return NULL;
+        }
+
+        NSBundle *bundle = [NSBundle bundleWithURL:app_url];
+        NSString *bundle_id = [bundle bundleIdentifier];
+
+        if (bundle_id != nil)
+        {
+            return g_strdup ([bundle_id UTF8String]);
+        }
+
+        return g_strdup ([[app_url path] fileSystemRepresentation]);
+    }
+}
+
+/* file:// URL of the app bundle to make the handler: the running bundle when
+ * launched as a .app, otherwise the LaunchServices-registered Nautilus. */
+static NSURL *
+handler_nautilus_app_url (void)
+{
+    NSBundle *main_bundle = [NSBundle mainBundle];
+    NSString *path = [main_bundle bundlePath];
+
+    if (path != nil && [path hasSuffix:@".app"] &&
+        [main_bundle bundleIdentifier] != nil)
+    {
+        return [main_bundle bundleURL];
+    }
+
+    return [[NSWorkspace sharedWorkspace]
+            URLForApplicationWithBundleIdentifier:@MACOS_BUNDLE_ID];
+}
+
+/* Set the default public.folder handler to the app at @app_url. Synchronous
+ * wrapper around the async NSWorkspace API: pumps the run loop up to 10 s.
+ * Reviewers flagged parameter/permission errors from this API on recent
+ * macOS (26.x); any NSError comes back verbatim in @error so the UI can
+ * show it. Honors dry-run. */
+static gboolean
+handler_set_default_app (NSURL   *app_url,
+                         GError **error)
+{
+    if (nautilus_macos_integration_is_dry_run ())
+    {
+        g_message ("DRY-RUN: would call -[NSWorkspace setDefaultApplicationAtURL:%s "
+                   "toOpenContentType:public.folder completionHandler:]",
+                   [[app_url path] fileSystemRepresentation]);
+        return TRUE;
+    }
+
+    __block gboolean done = FALSE;
+    __block char *error_message = NULL;
+
+    [[NSWorkspace sharedWorkspace]
+     setDefaultApplicationAtURL:app_url
+              toOpenContentType:UTTypeFolder
+              completionHandler:^(NSError *ns_error)
+    {
+        if (ns_error != nil)
+        {
+            error_message = g_strdup ([[ns_error localizedDescription] UTF8String]);
+        }
+        done = TRUE;
+    }];
+
+    /* The completion handler arrives on an unspecified queue; pump the
+     * current run loop (drains the main queue when called on the main
+     * thread) with a hard deadline so a stuck LaunchServices can never
+     * wedge the app. */
+    NSDate *deadline = [NSDate dateWithTimeIntervalSinceNow:10.0];
+    while (!done && [deadline timeIntervalSinceNow] > 0)
+    {
+        @autoreleasepool
+        {
+            [[NSRunLoop currentRunLoop] runMode:NSDefaultRunLoopMode
+                                     beforeDate:[NSDate dateWithTimeIntervalSinceNow:0.05]];
+        }
+    }
+
+    if (!done)
+    {
+        g_set_error_literal (error, G_IO_ERROR, G_IO_ERROR_TIMED_OUT,
+                             _("Timed out waiting for macOS to change the default "
+                               "folder application."));
+        return FALSE;
+    }
+
+    if (error_message != NULL)
+    {
+        g_set_error (error, G_IO_ERROR, G_IO_ERROR_FAILED,
+                     /* Translators: %s is the error macOS reported. */
+                     _("macOS refused to change the default folder application: %s "
+                       "(recent macOS versions restrict this; nothing was changed)"),
+                     error_message);
+        g_free (error_message);
+        return FALSE;
+    }
+
+    return TRUE;
+}
+
+/* Capability probe: can the default public.folder handler be changed AT ALL
+ * on this macOS? Empirically verified on macOS 26 (Tahoe, 26.5.1): EVERY
+ * known route fails without user recourse —
+ *   - -[NSWorkspace setDefaultApplicationAtURL:toOpenContentType:] returns
+ *     NSCocoaErrorDomain 256 (underlying OSStatus -50 paramErr), no consent
+ *     dialog is ever shown;
+ *   - legacy LSSetDefaultRoleHandlerForContentType returns -50 for every
+ *     role (duti hits the same wall);
+ *   - a hand-written LSHandlers entry in
+ *     com.apple.launchservices.secure.plist is ignored by lsd, and the
+ *     `lsregister -kill` database rebuild that used to force a re-read has
+ *     been removed from the OS ("dangerous and no longer useful").
+ * macOS simply hardwires folders to Finder now. Read-only; safe at startup.
+ * @out_reason (nullable) receives a user-showable explanation when FALSE. */
+gboolean
+nautilus_macos_integration_default_handler_supported (char **out_reason)
+{
+    gboolean supported;
+
+    @autoreleasepool
+    {
+        NSOperatingSystemVersion version =
+            [[NSProcessInfo processInfo] operatingSystemVersion];
+
+        supported = version.majorVersion < 26;
+    }
+
+    if (out_reason != NULL)
+    {
+        *out_reason = supported ? NULL :
+                      g_strdup (_("Not available on this version of macOS"));
+    }
+
+    return supported;
+}
+
+static gboolean
+handler_status_is_nautilus (char **detail)
+{
+    g_autofree char *current = handler_current_bundle_id ();
+    gboolean is_us = g_strcmp0 (current, MACOS_BUNDLE_ID) == 0;
+
+    if (detail != NULL)
+    {
+        *detail = g_strdup_printf (_("Current folder handler: %s"),
+                                   current != NULL ? current : _("unknown"));
+    }
+
+    return is_us;
+}
+
+static gboolean
+handler_apply (GError **error)
+{
+    /* Fail fast (and honestly) where the OS forbids the change entirely,
+     * before recording anything — see the probe for the evidence. */
+    if (!nautilus_macos_integration_default_handler_supported (NULL))
+    {
+        g_set_error_literal (error, G_IO_ERROR, G_IO_ERROR_NOT_SUPPORTED,
+                             _("macOS no longer allows changing the default "
+                               "folder application (all system routes refuse "
+                               "the change on this version)."));
+        return FALSE;
+    }
+
+    @autoreleasepool
+    {
+        g_autoptr (GKeyFile) key_file = integration_state_load ();
+        g_autofree char *previous = handler_current_bundle_id ();
+        NSURL *app_url = handler_nautilus_app_url ();
+
+        if (app_url == nil)
+        {
+            g_set_error_literal (error, G_IO_ERROR, G_IO_ERROR_NOT_FOUND,
+                                 _("Shenzhen Files.app is not registered with LaunchServices; "
+                                   "install it to /Applications first."));
+            return FALSE;
+        }
+
+        /* Record the pre-change handler BEFORE changing anything, so a
+         * mid-flight failure still leaves us able to revert. Never
+         * overwrite an existing record with ourselves (re-apply case). */
+        if (previous != NULL && g_strcmp0 (previous, MACOS_BUNDLE_ID) != 0)
+        {
+            g_key_file_set_string (key_file, STATE_GROUP_HANDLER,
+                                   STATE_KEY_PREVIOUS_HANDLER, previous);
+        }
+        else if (!g_key_file_has_key (key_file, STATE_GROUP_HANDLER,
+                                      STATE_KEY_PREVIOUS_HANDLER, NULL))
+        {
+            g_key_file_set_string (key_file, STATE_GROUP_HANDLER,
+                                   STATE_KEY_PREVIOUS_HANDLER, FINDER_BUNDLE_ID);
+        }
+
+        if (!integration_state_save (key_file, error))
+        {
+            return FALSE;
+        }
+
+        if (!handler_set_default_app (app_url, error))
+        {
+            return FALSE;
+        }
+
+        g_key_file_set_boolean (key_file, STATE_GROUP_HANDLER, STATE_KEY_ENABLED, TRUE);
+        return integration_state_save (key_file, error);
+    }
+}
+
+static gboolean
+handler_revert (GError **error)
+{
+    @autoreleasepool
+    {
+        g_autoptr (GKeyFile) key_file = integration_state_load ();
+        g_autofree char *previous = g_key_file_get_string (key_file, STATE_GROUP_HANDLER,
+                                                           STATE_KEY_PREVIOUS_HANDLER, NULL);
+        const char *restore_id = previous != NULL ? previous : FINDER_BUNDLE_ID;
+        NSURL *app_url = [[NSWorkspace sharedWorkspace]
+                          URLForApplicationWithBundleIdentifier:@(restore_id)];
+
+        if (app_url == nil)
+        {
+            g_set_error (error, G_IO_ERROR, G_IO_ERROR_NOT_FOUND,
+                         /* Translators: %s is an application bundle identifier. */
+                         _("The previous folder application (%s) could not be found."),
+                         restore_id);
+            return FALSE;
+        }
+
+        if (!handler_set_default_app (app_url, error))
+        {
+            return FALSE;
+        }
+
+        g_key_file_set_boolean (key_file, STATE_GROUP_HANDLER, STATE_KEY_ENABLED, FALSE);
+        g_key_file_remove_key (key_file, STATE_GROUP_HANDLER,
+                               STATE_KEY_PREVIOUS_HANDLER, NULL);
+        return integration_state_save (key_file, error);
+    }
+}
+
+/* --- Favorites: Nautilus bookmarks side (gtk-3.0/bookmarks) ---------------- */
+
+/* Same file NautilusBookmarkList reads, writes and monitors — editing it
+ * here is picked up live by the sidebar (1 s monitor rate limit). Format:
+ * one "URI[ <space> display name]" per line. */
+static char *
+gtk_bookmarks_path (void)
+{
+    return g_build_filename (g_get_user_config_dir (), "gtk-3.0", "bookmarks", NULL);
+}
+
+static GStrv
+gtk_bookmarks_read_lines (void)
+{
+    g_autofree char *path = gtk_bookmarks_path ();
+    g_autofree char *contents = NULL;
+
+    if (!g_file_get_contents (path, &contents, NULL, NULL))
+    {
+        return g_new0 (char *, 1);
+    }
+
+    g_auto (GStrv) raw = g_strsplit (contents, "\n", -1);
+    g_autoptr (GStrvBuilder) builder = g_strv_builder_new ();
+
+    for (gsize i = 0; raw[i] != NULL; i++)
+    {
+        if (raw[i][0] != '\0')
+        {
+            g_strv_builder_add (builder, raw[i]);
+        }
+    }
+
+    return g_strv_builder_end (builder);
+}
+
+static char *
+bookmark_line_uri (const char *line)
+{
+    const char *space = strchr (line, ' ');
+
+    return space != NULL ? g_strndup (line, space - line) : g_strdup (line);
+}
+
+static gboolean
+gtk_bookmarks_contains_uri (GStrv       lines,
+                            const char *uri)
+{
+    for (gsize i = 0; lines[i] != NULL; i++)
+    {
+        g_autofree char *line_uri = bookmark_line_uri (lines[i]);
+
+        if (g_strcmp0 (line_uri, uri) == 0)
+        {
+            return TRUE;
+        }
+    }
+
+    return FALSE;
+}
+
+static gboolean
+gtk_bookmarks_write_lines (GStrv    lines,
+                           GError **error)
+{
+    g_autofree char *path = gtk_bookmarks_path ();
+    g_autofree char *dir = g_path_get_dirname (path);
+    g_autofree char *joined = g_strjoinv ("\n", lines);
+    g_autofree char *contents = g_strconcat (joined, joined[0] != '\0' ? "\n" : "", NULL);
+
+    g_mkdir_with_parents (dir, 0700);
+
+    return g_file_set_contents (path, contents, -1, error);
+}
+
+/* --- Favorites: Finder shared-favorites side ------------------------------- */
+
+/* LSSharedFileList has been deprecated since 10.11 but remains the ONLY
+ * supported way to edit the shared favorites; writing .sfl3/.sfl4 files
+ * directly is forbidden (undocumented format, cfprefsd caching). Capability
+ * is probed at runtime and reported honestly. */
+#pragma clang diagnostic push
+#pragma clang diagnostic ignored "-Wdeprecated-declarations"
+
+static const char *
+favorites_mock_path (void)
+{
+    const char *path = g_getenv ("NAUTILUS_INTEGRATION_MOCK_FAVORITES");
+
+    return (path != NULL && path[0] != '\0') ? path : NULL;
+}
+
+/* Read the favorites as a NULL-terminated list of URI strings. Mock file
+ * when NAUTILUS_INTEGRATION_MOCK_FAVORITES is set, LSSharedFileList
+ * otherwise (READ-ONLY there). Returns NULL + @error when the list cannot
+ * be read at all. */
+static GStrv
+favorites_list_read (GError **error)
+{
+    const char *mock = favorites_mock_path ();
+
+    if (mock != NULL)
+    {
+        g_autofree char *contents = NULL;
+        g_autoptr (GStrvBuilder) builder = g_strv_builder_new ();
+
+        if (!g_file_get_contents (mock, &contents, NULL, error))
+        {
+            return NULL;
+        }
+
+        g_auto (GStrv) raw = g_strsplit (contents, "\n", -1);
+        for (gsize i = 0; raw[i] != NULL; i++)
+        {
+            if (raw[i][0] != '\0')
+            {
+                g_autofree char *uri = bookmark_line_uri (raw[i]);
+                g_strv_builder_add (builder, uri);
+            }
+        }
+
+        return g_strv_builder_end (builder);
+    }
+
+    @autoreleasepool
+    {
+        LSSharedFileListRef list = LSSharedFileListCreate (NULL,
+                                                           kLSSharedFileListFavoriteItems,
+                                                           NULL);
+
+        if (list == NULL)
+        {
+            g_set_error_literal (error, G_IO_ERROR, G_IO_ERROR_NOT_SUPPORTED,
+                                 _("The shared Finder favorites list is not available "
+                                   "on this version of macOS."));
+            return NULL;
+        }
+
+        UInt32 seed = 0;
+        CFArrayRef snapshot = LSSharedFileListCopySnapshot (list, &seed);
+
+        if (snapshot == NULL)
+        {
+            CFRelease (list);
+            g_set_error_literal (error, G_IO_ERROR, G_IO_ERROR_NOT_SUPPORTED,
+                                 _("The shared Finder favorites list could not be read "
+                                   "on this version of macOS."));
+            return NULL;
+        }
+
+        g_autoptr (GStrvBuilder) builder = g_strv_builder_new ();
+
+        for (CFIndex i = 0; i < CFArrayGetCount (snapshot); i++)
+        {
+            LSSharedFileListItemRef item =
+                (LSSharedFileListItemRef) CFArrayGetValueAtIndex (snapshot, i);
+            CFURLRef url = LSSharedFileListItemCopyResolvedURL (
+                item,
+                kLSSharedFileListNoUserInteraction | kLSSharedFileListDoNotMountVolumes,
+                NULL);
+
+            if (url != NULL)
+            {
+                NSString *uri = [(__bridge NSURL *) url absoluteString];
+
+                if (uri != nil)
+                {
+                    g_strv_builder_add (builder, [uri UTF8String]);
+                }
+                CFRelease (url);
+            }
+        }
+
+        CFRelease (snapshot);
+        CFRelease (list);
+
+        return g_strv_builder_end (builder);
+    }
+}
+
+/* Insert @uri at the end of the favorites. Mock: appends a line. Real:
+ * LSSharedFileListInsertItemURL — skipped and logged under dry-run. */
+static gboolean
+favorites_list_insert (const char *uri,
+                       GError    **error)
+{
+    const char *mock = favorites_mock_path ();
+
+    if (mock != NULL)
+    {
+        g_autofree char *contents = NULL;
+        g_file_get_contents (mock, &contents, NULL, NULL);
+        g_autofree char *updated = g_strdup_printf ("%s%s\n",
+                                                    contents != NULL ? contents : "",
+                                                    uri);
+        return g_file_set_contents (mock, updated, -1, error);
+    }
+
+    if (nautilus_macos_integration_is_dry_run ())
+    {
+        g_message ("DRY-RUN: would call LSSharedFileListInsertItemURL(favorites, "
+                   "kLSSharedFileListItemLast, %s)", uri);
+        return TRUE;
+    }
+
+    @autoreleasepool
+    {
+        LSSharedFileListRef list = LSSharedFileListCreate (NULL,
+                                                           kLSSharedFileListFavoriteItems,
+                                                           NULL);
+
+        if (list == NULL)
+        {
+            g_set_error_literal (error, G_IO_ERROR, G_IO_ERROR_NOT_SUPPORTED,
+                                 _("The shared Finder favorites list is not available."));
+            return FALSE;
+        }
+
+        NSURL *url = [NSURL URLWithString:@(uri)];
+        LSSharedFileListItemRef item = NULL;
+
+        if (url != nil)
+        {
+            item = LSSharedFileListInsertItemURL (list, kLSSharedFileListItemLast,
+                                                  NULL, NULL,
+                                                  (__bridge CFURLRef) url,
+                                                  NULL, NULL);
+        }
+
+        CFRelease (list);
+
+        if (item == NULL)
+        {
+            g_set_error (error, G_IO_ERROR, G_IO_ERROR_NOT_SUPPORTED,
+                         /* Translators: %s is a file URI. */
+                         _("macOS rejected adding “%s” to the Finder sidebar "
+                           "(the shared-favorites API is not functional here)."),
+                         uri);
+            return FALSE;
+        }
+
+        CFRelease (item);
+        return TRUE;
+    }
+}
+
+/* Remove the favorites item resolving to @uri (only used for URIs WE
+ * inserted). Mock: drops the line. Real: skipped and logged under dry-run.
+ * A URI that is already gone counts as success (idempotent revert). */
+static gboolean
+favorites_list_remove (const char *uri,
+                       GError    **error)
+{
+    const char *mock = favorites_mock_path ();
+
+    if (mock != NULL)
+    {
+        g_autofree char *contents = NULL;
+
+        if (!g_file_get_contents (mock, &contents, NULL, NULL))
+        {
+            return TRUE;
+        }
+
+        g_auto (GStrv) raw = g_strsplit (contents, "\n", -1);
+        g_autoptr (GString) updated = g_string_new (NULL);
+
+        for (gsize i = 0; raw[i] != NULL; i++)
+        {
+            g_autofree char *line_uri = NULL;
+
+            if (raw[i][0] == '\0')
+            {
+                continue;
+            }
+
+            line_uri = bookmark_line_uri (raw[i]);
+            if (g_strcmp0 (line_uri, uri) != 0)
+            {
+                g_string_append_printf (updated, "%s\n", raw[i]);
+            }
+        }
+
+        return g_file_set_contents (mock, updated->str, -1, error);
+    }
+
+    if (nautilus_macos_integration_is_dry_run ())
+    {
+        g_message ("DRY-RUN: would call LSSharedFileListItemRemove(favorites, "
+                   "item-resolving-to %s)", uri);
+        return TRUE;
+    }
+
+    @autoreleasepool
+    {
+        LSSharedFileListRef list = LSSharedFileListCreate (NULL,
+                                                           kLSSharedFileListFavoriteItems,
+                                                           NULL);
+
+        if (list == NULL)
+        {
+            g_set_error_literal (error, G_IO_ERROR, G_IO_ERROR_NOT_SUPPORTED,
+                                 _("The shared Finder favorites list is not available."));
+            return FALSE;
+        }
+
+        UInt32 seed = 0;
+        CFArrayRef snapshot = LSSharedFileListCopySnapshot (list, &seed);
+        gboolean removed_or_absent = TRUE;
+
+        if (snapshot != NULL)
+        {
+            for (CFIndex i = 0; i < CFArrayGetCount (snapshot); i++)
+            {
+                LSSharedFileListItemRef item =
+                    (LSSharedFileListItemRef) CFArrayGetValueAtIndex (snapshot, i);
+                CFURLRef url = LSSharedFileListItemCopyResolvedURL (
+                    item,
+                    kLSSharedFileListNoUserInteraction | kLSSharedFileListDoNotMountVolumes,
+                    NULL);
+
+                if (url != NULL)
+                {
+                    NSString *item_uri = [(__bridge NSURL *) url absoluteString];
+
+                    if (item_uri != nil && g_strcmp0 ([item_uri UTF8String], uri) == 0)
+                    {
+                        removed_or_absent =
+                            LSSharedFileListItemRemove (list, item) == noErr;
+                    }
+                    CFRelease (url);
+                }
+            }
+            CFRelease (snapshot);
+        }
+
+        CFRelease (list);
+
+        if (!removed_or_absent)
+        {
+            g_set_error (error, G_IO_ERROR, G_IO_ERROR_FAILED,
+                         /* Translators: %s is a file URI. */
+                         _("Could not remove “%s” from the Finder sidebar."), uri);
+            return FALSE;
+        }
+
+        return TRUE;
+    }
+}
+
+gboolean
+nautilus_macos_integration_favorites_probe (guint  *out_count,
+                                            char  **out_detail)
+{
+    /* Strictly read-only capability probe: list the favorites, touch
+     * nothing. Used by the preferences UI to degrade honestly and by the
+     * verification harness. */
+    g_autoptr (GError) error = NULL;
+    g_auto (GStrv) uris = favorites_list_read (&error);
+
+    if (uris == NULL)
+    {
+        if (out_count != NULL)
+        {
+            *out_count = 0;
+        }
+        if (out_detail != NULL)
+        {
+            *out_detail = g_strdup (error->message);
+        }
+        return FALSE;
+    }
+
+    if (out_count != NULL)
+    {
+        *out_count = g_strv_length (uris);
+    }
+    if (out_detail != NULL)
+    {
+        *out_detail = g_strdup_printf (_("Shared favorites list readable: %u items"),
+                                       g_strv_length (uris));
+    }
+    return TRUE;
+}
+
+#pragma clang diagnostic pop
+
+/* --- Favorites: apply / revert / status ------------------------------------ */
+
+static gboolean
+favorites_apply (GError **error)
+{
+    g_autoptr (GKeyFile) key_file = integration_state_load ();
+    g_autoptr (GError) read_error = NULL;
+    g_auto (GStrv) finder_uris = favorites_list_read (&read_error);
+    gboolean export_supported = TRUE;
+
+    if (finder_uris == NULL)
+    {
+        /* Cannot even read the shared list: report capability honestly and
+         * change nothing (import needs the list too). */
+        g_propagate_error (error, g_steal_pointer (&read_error));
+        return FALSE;
+    }
+
+    /* 1. IMPORT: Finder favorites → Nautilus bookmarks. Record exactly the
+     *    URIs we add so revert removes only those. */
+    g_auto (GStrv) bookmark_lines = gtk_bookmarks_read_lines ();
+    g_autoptr (GStrvBuilder) new_lines = g_strv_builder_new ();
+    g_autoptr (GStrvBuilder) imported = g_strv_builder_new ();
+
+    g_strv_builder_addv (new_lines, (const char **) bookmark_lines);
+
+    for (gsize i = 0; finder_uris[i] != NULL; i++)
+    {
+        /* Only local files/folders make sense as Nautilus bookmarks. */
+        if (!g_str_has_prefix (finder_uris[i], "file://"))
+        {
+            continue;
+        }
+
+        if (!gtk_bookmarks_contains_uri (bookmark_lines, finder_uris[i]))
+        {
+            g_autoptr (GFile) file = g_file_new_for_uri (finder_uris[i]);
+            g_autofree char *name = g_file_get_basename (file);
+            g_autofree char *line = g_strdup_printf ("%s %s", finder_uris[i],
+                                                     name != NULL ? name : "");
+
+            g_strv_builder_add (new_lines, g_strchomp (line));
+            g_strv_builder_add (imported, finder_uris[i]);
+        }
+    }
+
+    g_auto (GStrv) new_lines_v = g_strv_builder_end (new_lines);
+    g_auto (GStrv) imported_v = g_strv_builder_end (imported);
+
+    if (imported_v[0] != NULL &&
+        !gtk_bookmarks_write_lines (new_lines_v, error))
+    {
+        return FALSE;
+    }
+
+    /* 2. EXPORT: Nautilus bookmarks → Finder favorites, recording every URI
+     *    we insert. A write failure degrades to import-only (recorded, and
+     *    reported to the UI via status). */
+    g_autoptr (GStrvBuilder) exported = g_strv_builder_new ();
+
+    for (gsize i = 0; bookmark_lines[i] != NULL; i++)
+    {
+        g_autofree char *uri = bookmark_line_uri (bookmark_lines[i]);
+
+        if (!g_str_has_prefix (uri, "file://") ||
+            g_strv_contains ((const char *const *) finder_uris, uri))
+        {
+            continue;
+        }
+
+        g_autoptr (GError) insert_error = NULL;
+
+        if (favorites_list_insert (uri, &insert_error))
+        {
+            g_strv_builder_add (exported, uri);
+        }
+        else
+        {
+            g_message ("Favorites export unavailable (%s); degrading to import-only",
+                       insert_error->message);
+            export_supported = FALSE;
+            break;
+        }
+    }
+
+    g_auto (GStrv) exported_v = g_strv_builder_end (exported);
+
+    g_key_file_set_boolean (key_file, STATE_GROUP_FAVORITES, STATE_KEY_ENABLED, TRUE);
+    g_key_file_set_boolean (key_file, STATE_GROUP_FAVORITES,
+                            STATE_KEY_EXPORT_SUPPORTED, export_supported);
+    g_key_file_set_string_list (key_file, STATE_GROUP_FAVORITES,
+                                STATE_KEY_IMPORTED_BOOKMARKS,
+                                (const char *const *) imported_v,
+                                g_strv_length (imported_v));
+    g_key_file_set_string_list (key_file, STATE_GROUP_FAVORITES,
+                                STATE_KEY_EXPORTED_URLS,
+                                (const char *const *) exported_v,
+                                g_strv_length (exported_v));
+
+    return integration_state_save (key_file, error);
+}
+
+static gboolean
+favorites_revert (GError **error)
+{
+    g_autoptr (GKeyFile) key_file = integration_state_load ();
+    gsize n_imported = 0;
+    gsize n_exported = 0;
+    g_auto (GStrv) imported = g_key_file_get_string_list (key_file, STATE_GROUP_FAVORITES,
+                                                          STATE_KEY_IMPORTED_BOOKMARKS,
+                                                          &n_imported, NULL);
+    g_auto (GStrv) exported = g_key_file_get_string_list (key_file, STATE_GROUP_FAVORITES,
+                                                          STATE_KEY_EXPORTED_URLS,
+                                                          &n_exported, NULL);
+
+    /* Remove ONLY what we recorded as ours; user-created entries on either
+     * side are never touched. */
+    for (gsize i = 0; exported != NULL && exported[i] != NULL; i++)
+    {
+        if (!favorites_list_remove (exported[i], error))
+        {
+            return FALSE;
+        }
+    }
+
+    if (imported != NULL && imported[0] != NULL)
+    {
+        g_auto (GStrv) lines = gtk_bookmarks_read_lines ();
+        g_autoptr (GStrvBuilder) kept = g_strv_builder_new ();
+
+        for (gsize i = 0; lines[i] != NULL; i++)
+        {
+            g_autofree char *uri = bookmark_line_uri (lines[i]);
+
+            if (!g_strv_contains ((const char *const *) imported, uri))
+            {
+                g_strv_builder_add (kept, lines[i]);
+            }
+        }
+
+        g_auto (GStrv) kept_v = g_strv_builder_end (kept);
+
+        if (!gtk_bookmarks_write_lines (kept_v, error))
+        {
+            return FALSE;
+        }
+    }
+
+    g_key_file_set_boolean (key_file, STATE_GROUP_FAVORITES, STATE_KEY_ENABLED, FALSE);
+    g_key_file_remove_key (key_file, STATE_GROUP_FAVORITES,
+                           STATE_KEY_IMPORTED_BOOKMARKS, NULL);
+    g_key_file_remove_key (key_file, STATE_GROUP_FAVORITES,
+                           STATE_KEY_EXPORTED_URLS, NULL);
+    g_key_file_remove_key (key_file, STATE_GROUP_FAVORITES,
+                           STATE_KEY_EXPORT_SUPPORTED, NULL);
+    return integration_state_save (key_file, error);
+}
+
+static gboolean
+favorites_status (char **detail)
+{
+    g_autoptr (GKeyFile) key_file = integration_state_load ();
+    gboolean enabled = g_key_file_get_boolean (key_file, STATE_GROUP_FAVORITES,
+                                               STATE_KEY_ENABLED, NULL);
+
+    if (detail != NULL)
+    {
+        if (enabled)
+        {
+            gsize n_imported = 0;
+            gsize n_exported = 0;
+            g_auto (GStrv) imported = g_key_file_get_string_list (key_file,
+                                                                  STATE_GROUP_FAVORITES,
+                                                                  STATE_KEY_IMPORTED_BOOKMARKS,
+                                                                  &n_imported, NULL);
+            g_auto (GStrv) exported = g_key_file_get_string_list (key_file,
+                                                                  STATE_GROUP_FAVORITES,
+                                                                  STATE_KEY_EXPORTED_URLS,
+                                                                  &n_exported, NULL);
+            GError *probe_error = NULL;
+            gboolean export_supported = g_key_file_get_boolean (key_file,
+                                                                STATE_GROUP_FAVORITES,
+                                                                STATE_KEY_EXPORT_SUPPORTED,
+                                                                &probe_error);
+
+            if (probe_error != NULL)
+            {
+                export_supported = TRUE;
+                g_clear_error (&probe_error);
+            }
+
+            *detail = g_strdup_printf (
+                export_supported ?
+                _("Synced: %zu imported from Finder, %zu exported to the Finder sidebar") :
+                _("Imported %zu from Finder; exporting is unavailable on this macOS — "
+                  "add folders to the Finder sidebar manually (%zu exported)"),
+                n_imported, n_exported);
+        }
+        else
+        {
+            *detail = g_strdup (_("Not synced"));
+        }
+    }
+
+    return enabled;
+}
+
+/* --- Hide Finder desktop ---------------------------------------------------- */
+
+/* Read com.apple.finder CreateDesktop from our process (reading another
+ * app's defaults domain is unrestricted for non-sandboxed apps). Returns
+ * TRUE if the key exists, with its boolean interpretation in @out_value. */
+static gboolean
+desktop_read_create_desktop (gboolean *out_value)
+{
+    CFPropertyListRef value = CFPreferencesCopyAppValue (CFSTR ("CreateDesktop"),
+                                                         CFSTR (FINDER_BUNDLE_ID));
+
+    if (value == NULL)
+    {
+        return FALSE;
+    }
+
+    gboolean result = TRUE;
+
+    if (CFGetTypeID (value) == CFBooleanGetTypeID ())
+    {
+        result = CFBooleanGetValue ((CFBooleanRef) value);
+    }
+    else if (CFGetTypeID (value) == CFStringGetTypeID ())
+    {
+        @autoreleasepool
+        {
+            NSString *string = (__bridge NSString *) value;
+            result = ![string isEqualToString:@"0"] &&
+                     [string caseInsensitiveCompare:@"false"] != NSOrderedSame &&
+                     [string caseInsensitiveCompare:@"no"] != NSOrderedSame;
+        }
+    }
+    else if (CFGetTypeID (value) == CFNumberGetTypeID ())
+    {
+        int number = 1;
+        CFNumberGetValue ((CFNumberRef) value, kCFNumberIntType, &number);
+        result = number != 0;
+    }
+
+    CFRelease (value);
+
+    if (out_value != NULL)
+    {
+        *out_value = result;
+    }
+
+    return TRUE;
+}
+
+/* Write (or, with @remove_key, delete) CreateDesktop and flush cfprefsd.
+ * Honors dry-run. */
+static gboolean
+desktop_write_create_desktop (gboolean  value,
+                              gboolean  remove_key,
+                              GError  **error)
+{
+    if (nautilus_macos_integration_is_dry_run ())
+    {
+        if (remove_key)
+        {
+            g_message ("DRY-RUN: would call CFPreferencesSetAppValue(CreateDesktop, "
+                       "NULL /* remove */, " FINDER_BUNDLE_ID ") + AppSynchronize");
+        }
+        else
+        {
+            g_message ("DRY-RUN: would call CFPreferencesSetAppValue(CreateDesktop, "
+                       "%s, " FINDER_BUNDLE_ID ") + AppSynchronize",
+                       value ? "true" : "false");
+        }
+        return TRUE;
+    }
+
+    CFPreferencesSetAppValue (CFSTR ("CreateDesktop"),
+                              remove_key ? NULL : (value ? kCFBooleanTrue : kCFBooleanFalse),
+                              CFSTR (FINDER_BUNDLE_ID));
+
+    if (!CFPreferencesAppSynchronize (CFSTR (FINDER_BUNDLE_ID)))
+    {
+        g_set_error_literal (error, G_IO_ERROR, G_IO_ERROR_FAILED,
+                             _("Could not save the Finder desktop setting."));
+        return FALSE;
+    }
+
+    return TRUE;
+}
+
+/* Relaunch Finder so the CreateDesktop change takes effect: SIGTERM to the
+ * running Finder (exactly what `killall Finder` sends); launchd restarts it
+ * automatically. ONLY called from apply/revert — i.e. only when the user
+ * explicitly flipped the Hide Desktop toggle, never at install or startup.
+ * Honors dry-run. */
+static void
+desktop_relaunch_finder (void)
+{
+    @autoreleasepool
+    {
+        NSArray<NSRunningApplication *> *finders =
+            [NSRunningApplication runningApplicationsWithBundleIdentifier:@(FINDER_BUNDLE_ID)];
+
+        for (NSRunningApplication *finder in finders)
+        {
+            if (nautilus_macos_integration_is_dry_run ())
+            {
+                g_message ("DRY-RUN: would send SIGTERM to Finder (pid %d) to relaunch it",
+                           [finder processIdentifier]);
+                continue;
+            }
+
+            kill ([finder processIdentifier], SIGTERM);
+        }
+    }
+}
+
+static gboolean
+desktop_status_is_hidden (char **detail)
+{
+    gboolean value = TRUE;
+    gboolean has_key = desktop_read_create_desktop (&value);
+    gboolean hidden = has_key && !value;
+
+    if (detail != NULL)
+    {
+        *detail = g_strdup (hidden ?
+                            _("Finder desktop icons are hidden") :
+                            _("Finder is drawing the desktop"));
+    }
+
+    return hidden;
+}
+
+static gboolean
+desktop_apply (GError **error)
+{
+    g_autoptr (GKeyFile) key_file = integration_state_load ();
+    gboolean previous_value = TRUE;
+    gboolean had_value = desktop_read_create_desktop (&previous_value);
+
+    /* Save the pre-change state BEFORE writing, including the "key was not
+     * set at all" case so revert can delete it again. Never overwrite an
+     * existing record on re-apply. */
+    if (!g_key_file_has_key (key_file, STATE_GROUP_DESKTOP,
+                             STATE_KEY_HAD_PREVIOUS_VALUE, NULL))
+    {
+        g_key_file_set_boolean (key_file, STATE_GROUP_DESKTOP,
+                                STATE_KEY_HAD_PREVIOUS_VALUE, had_value);
+        g_key_file_set_boolean (key_file, STATE_GROUP_DESKTOP,
+                                STATE_KEY_PREVIOUS_CREATE_DESKTOP, previous_value);
+    }
+
+    if (!integration_state_save (key_file, error))
+    {
+        return FALSE;
+    }
+
+    if (!desktop_write_create_desktop (FALSE, FALSE, error))
+    {
+        return FALSE;
+    }
+
+    desktop_relaunch_finder ();
+
+    g_key_file_set_boolean (key_file, STATE_GROUP_DESKTOP, STATE_KEY_ENABLED, TRUE);
+    return integration_state_save (key_file, error);
+}
+
+static gboolean
+desktop_revert (GError **error)
+{
+    g_autoptr (GKeyFile) key_file = integration_state_load ();
+    gboolean had_value = g_key_file_get_boolean (key_file, STATE_GROUP_DESKTOP,
+                                                 STATE_KEY_HAD_PREVIOUS_VALUE, NULL);
+    gboolean previous_value = g_key_file_get_boolean (key_file, STATE_GROUP_DESKTOP,
+                                                      STATE_KEY_PREVIOUS_CREATE_DESKTOP,
+                                                      NULL);
+
+    /* No record (defensive): the factory state is "key absent" == desktop
+     * shown, so removing the key is the correct fallback. */
+    if (!desktop_write_create_desktop (previous_value, !had_value, error))
+    {
+        return FALSE;
+    }
+
+    desktop_relaunch_finder ();
+
+    g_key_file_set_boolean (key_file, STATE_GROUP_DESKTOP, STATE_KEY_ENABLED, FALSE);
+    g_key_file_remove_key (key_file, STATE_GROUP_DESKTOP,
+                           STATE_KEY_HAD_PREVIOUS_VALUE, NULL);
+    g_key_file_remove_key (key_file, STATE_GROUP_DESKTOP,
+                           STATE_KEY_PREVIOUS_CREATE_DESKTOP, NULL);
+    return integration_state_save (key_file, error);
+}
+
+/* --- Public dispatch -------------------------------------------------------- */
+
+gboolean
+nautilus_macos_integration_status (NautilusMacosIntegration   which,
+                                   char                     **detail)
+{
+    switch (which)
+    {
+        case NAUTILUS_MACOS_INTEGRATION_DEFAULT_HANDLER:
+        {
+            return handler_status_is_nautilus (detail);
+        }
+
+        case NAUTILUS_MACOS_INTEGRATION_FAVORITES:
+        {
+            return favorites_status (detail);
+        }
+
+        case NAUTILUS_MACOS_INTEGRATION_HIDE_DESKTOP:
+        {
+            return desktop_status_is_hidden (detail);
+        }
+
+        default:
+        {
+            g_assert_not_reached ();
+        }
+    }
+}
+
+gboolean
+nautilus_macos_integration_apply (NautilusMacosIntegration   which,
+                                  GError                   **error)
+{
+    g_message ("Finder integration: apply %d%s", which,
+               nautilus_macos_integration_is_dry_run () ? " (DRY-RUN)" : "");
+
+    switch (which)
+    {
+        case NAUTILUS_MACOS_INTEGRATION_DEFAULT_HANDLER: { return handler_apply (error); }
+        case NAUTILUS_MACOS_INTEGRATION_FAVORITES: { return favorites_apply (error); }
+        case NAUTILUS_MACOS_INTEGRATION_HIDE_DESKTOP: { return desktop_apply (error); }
+        default: { g_assert_not_reached (); }
+    }
+}
+
+gboolean
+nautilus_macos_integration_revert (NautilusMacosIntegration   which,
+                                   GError                   **error)
+{
+    g_message ("Finder integration: revert %d%s", which,
+               nautilus_macos_integration_is_dry_run () ? " (DRY-RUN)" : "");
+
+    switch (which)
+    {
+        case NAUTILUS_MACOS_INTEGRATION_DEFAULT_HANDLER: { return handler_revert (error); }
+        case NAUTILUS_MACOS_INTEGRATION_FAVORITES: { return favorites_revert (error); }
+        case NAUTILUS_MACOS_INTEGRATION_HIDE_DESKTOP: { return desktop_revert (error); }
+        default: { g_assert_not_reached (); }
+    }
+}
+
+gboolean
+nautilus_macos_integration_revert_all (GError **error)
+{
+    static const NautilusMacosIntegration all[] =
+    {
+        NAUTILUS_MACOS_INTEGRATION_DEFAULT_HANDLER,
+        NAUTILUS_MACOS_INTEGRATION_FAVORITES,
+        NAUTILUS_MACOS_INTEGRATION_HIDE_DESKTOP,
+    };
+    gboolean success = TRUE;
+
+    for (gsize i = 0; i < G_N_ELEMENTS (all); i++)
+    {
+        /* Only revert what is actually enabled; keep going past failures so
+         * one broken integration cannot pin the others, but report the
+         * first error. */
+        if (nautilus_macos_integration_get_enabled (all[i]) &&
+            !nautilus_macos_integration_revert (all[i],
+                                                (error != NULL && *error == NULL) ?
+                                                error : NULL))
+        {
+            success = FALSE;
+        }
+    }
+
+    return success;
+}
+
+/* --- First-run choice (DMG installers) -------------------------------------- */
+
+gboolean
+nautilus_macos_integration_should_show_first_run_dialog (void)
+{
+    g_autoptr (GKeyFile) key_file = integration_state_load ();
+
+    return !g_key_file_get_boolean (key_file, STATE_GROUP_INTEGRATION,
+                                    STATE_KEY_CHOICE_MADE, NULL);
+}
+
+void
+nautilus_macos_integration_set_first_run_choice_made (void)
+{
+    g_autoptr (GKeyFile) key_file = integration_state_load ();
+    g_autoptr (GError) error = NULL;
+
+    g_key_file_set_boolean (key_file, STATE_GROUP_INTEGRATION,
+                            STATE_KEY_CHOICE_MADE, TRUE);
+
+    if (!integration_state_save (key_file, &error))
+    {
+        g_warning ("Failed to save integration first-run state: %s", error->message);
+    }
+}
+
+static void
+integration_first_run_response_cb (AdwAlertDialog *dialog,
+                                   const char     *response,
+                                   gpointer        user_data)
+{
+    /* "standalone" (and dialog close) do NOTHING — that is the default.
+     * "setup" only OPENS the preferences page; every individual toggle
+     * still starts OFF and must be flipped by the user. */
+    if (g_strcmp0 (response, "setup") == 0)
+    {
+        GApplication *app = g_application_get_default ();
+
+        if (app != NULL)
+        {
+            g_action_group_activate_action (G_ACTION_GROUP (app),
+                                            "finder-integration", NULL);
+        }
+    }
+}
+
+void
+nautilus_macos_integration_show_first_run_dialog (GtkWindow *parent)
+{
+    AdwAlertDialog *dialog = ADW_ALERT_DIALOG (
+        adw_alert_dialog_new (_("How Do You Want to Use Shenzhen Files?"),
+                              _("Shenzhen Files works great as a standalone file manager. "
+                                "Optionally, it can also integrate with macOS: open "
+                                "folders by default, share Finder’s sidebar favorites, "
+                                "or hide the Finder desktop.\n\n"
+                                "Nothing is changed unless you turn it on, and every "
+                                "integration can be reverted at any time from "
+                                "Settings ▸ Finder Integration.")));
+
+    adw_alert_dialog_add_responses (dialog,
+                                    "standalone", _("Use as a Standalone App"),
+                                    "setup", _("Set Up Finder Integration…"),
+                                    NULL);
+    adw_alert_dialog_set_response_appearance (dialog, "setup",
+                                              ADW_RESPONSE_SUGGESTED);
+    adw_alert_dialog_set_default_response (dialog, "standalone");
+    adw_alert_dialog_set_close_response (dialog, "standalone");
+
+    g_signal_connect (dialog, "response",
+                      G_CALLBACK (integration_first_run_response_cb), NULL);
+
+    adw_dialog_present (ADW_DIALOG (dialog),
+                        parent != NULL ? GTK_WIDGET (parent) : NULL);
+}
+
+/* --- NSServices provider ("Open in Nautilus") ------------------------------- */
+
+/* Passive receiver for the NSServices entry declared in Info.plist
+ * (NSMessage = openInNautilus): Finder/other apps' Services menu hands us
+ * file URLs on a pasteboard; route them through GApplication::open, the
+ * same path `open -a Nautilus <dir>` takes. Registering a services
+ * provider changes nothing system-wide — macOS shows the menu item on its
+ * own once the bundle's Info.plist advertises it. */
+
+@interface NautilusServicesProvider : NSObject
+- (void) openInNautilus: (NSPasteboard *) pboard
+               userData: (NSString *) userData
+                  error: (NSString **) error;
+@end
+
+@implementation NautilusServicesProvider
+- (void) openInNautilus: (NSPasteboard *) pboard
+               userData: (NSString *) userData
+                  error: (NSString **) error
+{
+    NSArray<NSURL *> *urls =
+        [pboard readObjectsForClasses:@[[NSURL class]]
+                              options:@{NSPasteboardURLReadingFileURLsOnlyKey: @YES}];
+    GApplication *app = g_application_get_default ();
+
+    if (app == NULL || urls == nil || [urls count] == 0)
+    {
+        if (error != NULL)
+        {
+            *error = @"Shenzhen Files could not open the selected items.";
+        }
+        return;
+    }
+
+    GPtrArray *files = g_ptr_array_new_with_free_func (g_object_unref);
+
+    for (NSURL *url in urls)
+    {
+        g_ptr_array_add (files, g_file_new_for_path ([url fileSystemRepresentation]));
+    }
+
+    g_application_open (app, (GFile **) files->pdata, files->len, "");
+    g_ptr_array_unref (files);
+}
+@end
+
+/* setServicesProvider: keeps only a weak-ish reference historically; keep
+ * the provider alive for the process lifetime. */
+static NautilusServicesProvider *services_provider = nil;
+
+void
+nautilus_macos_integration_register_services_provider (void)
+{
+    @autoreleasepool
+    {
+        if (services_provider != nil)
+        {
+            return;
+        }
+
+        services_provider = [[NautilusServicesProvider alloc] init];
+        [NSApplication sharedApplication].servicesProvider = services_provider;
+        g_debug ("Finder integration: NSServices provider registered");
+    }
+}
