+#ifdef __APPLE__
+/* On macOS, GDK maps the Command key to GDK_META_MASK. GTK4 parses both
+ * "<Control>" and "<Primary>" accelerator strings to the (physical) Control
+ * modifier on every platform — "<Primary>" is *not* remapped to Command —
+ * so upstream accelerators would all land on Ctrl instead of Cmd. Rewrite
+ * the primary modifier to "<Meta>" at registration time, which turns every
+ * accelerator that funnels through nautilus_application_set_accelerator(s)
+ * into the equivalent Cmd shortcut. */
+static char *
+macos_remap_accel (const char *accel)
+{
+    static const char *primary_mods[] = { "<control>", "<ctrl>", "<ctl>", "<primary>" };
+    GString *remapped = g_string_new (NULL);
+
+    for (const char *p = accel; *p != '\0'; )
+    {
+        gboolean replaced = FALSE;
+
+        if (*p == '<')
+        {
+            for (gsize i = 0; i < G_N_ELEMENTS (primary_mods); i++)
+            {
+                gsize len = strlen (primary_mods[i]);
+
+                if (g_ascii_strncasecmp (p, primary_mods[i], len) == 0)
+                {
+                    g_string_append (remapped, "<Meta>");
+                    p += len;
+                    replaced = TRUE;
+                    break;
+                }
+            }
+        }
+
+        if (!replaced)
+        {
+            g_string_append_c (remapped, *p);
+            p++;
+        }
+    }
+
+    return g_string_free (remapped, FALSE);
