+ * Cached per (lowercased filename extension, size) — two files sharing an
+ * extension are assumed to share an icon, so a 10k-file directory costs one
+ * AppKit call per distinct extension per icon size. Paths ending in ".app"
+ * are cached per full path instead (every app bundle has its own icon).
+ * Extensionless files share the "" key (the generic document icon).
+ *
+ * MAIN THREAD ONLY: must be called on the AppKit/GTK main thread (returns
+ * NULL with a warning elsewhere). All Nautilus icon resolution happens on
+ * the main thread (cell binding in the views). */
+GdkTexture *nautilus_macos_file_icon_texture (const char *path,
+                                              int         size_px);
+
+/* Instrumentation for the headless harness: cumulative NSWorkspace
+ * iconForFile: calls, cache hits, and current cache entry count. Any
+ * out-parameter may be NULL. Main thread only. */
+void nautilus_macos_file_icon_debug_stats (guint *out_appkit_calls,
+                                           guint *out_cache_hits,
+                                           guint *out_cache_entries);
+
+/* --- Open in Terminal (nautilus-macos-terminal.m) --- */
+
+/* Open Terminal.app with a new window cd'd to the directory @path (a local
