+/* GTK #7964 workaround — native window controls hang on macOS 26.
+ *
+ * When a GtkHeaderBar/AdwHeaderBar has native window controls enabled it
+ * draws the real macOS "traffic light" as AppKit NSButtons on top of the
+ * window. On macOS 26 GDK's hit-test for those buttons
+ * (over_native_window_buttons in gdkmacosdisplay-translate.c) no longer
+ * recognizes the press, so instead of being ignored the mouse-down is
+ * forwarded to AppKit, which enters NSButtonCell's modal
+ * -trackMouse:inRect:ofView:untilMouseUp:. GTK's quartz event source has
+ * already dequeued the matching mouse-up into its own queue, so that modal
+ * loop never sees a release and never returns: the main thread wedges
+ * inside AppKit with the GLib main loop frozen. If the button that was hit
+ * is the close button, the window tears down but the wedged main thread can
+ * neither finish quitting nor service a reopen — leaving exactly the
+ * reported "running with no window, can't close or reopen" zombie (it still
+ * owns the app's LaunchServices registration). Upstream fix !9354 is already
+ * in our GTK 4.22.4 yet does not cure the hang on macOS 26.5.
+ *
+ * Fix: keep native controls OFF, so GTK falls back to its own CSS-drawn
+ * window buttons. Those are handled entirely inside GTK/GDK and never enter
+ * AppKit's NSButton tracking loop, so the deadlock cannot happen. libadwaita
+ * force-enables native controls every time it (re)creates a
+ * GtkWindowControls; the main window's split-header coordination destroys
+ * and recreates those controls whenever the sidebar is shown/hidden, so the
+ * override has to be re-applied after each such change, not only once. */
+static void
+macos_disable_native_window_controls (GtkWidget *widget)
+{
+    if (GTK_IS_WINDOW_CONTROLS (widget) &&
+        gtk_window_controls_get_use_native_controls (GTK_WINDOW_CONTROLS (widget)))
+    {
+        gtk_window_controls_set_use_native_controls (GTK_WINDOW_CONTROLS (widget), FALSE);
+    }
+
+    for (GtkWidget *child = gtk_widget_get_first_child (widget);
+         child != NULL;
+         child = gtk_widget_get_next_sibling (child))
+    {
+        macos_disable_native_window_controls (child);
+    }
+}
+
+static void
+macos_window_map_cb (GtkWidget *window,
+                     gpointer   user_data)
+{
+    macos_disable_native_window_controls (window);
+}
+
+static void
+macos_split_view_controls_notify_cb (GObject    *split_view,
+                                     GParamSpec *pspec,
+                                     gpointer    window)
+{
+    macos_disable_native_window_controls (GTK_WIDGET (window));
+}
