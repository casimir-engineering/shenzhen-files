diff --git a/src/nautilus-thumbnails-macos.c b/src/nautilus-thumbnails-macos.c
new file mode 100644
index 0000000..8dacf4f
--- /dev/null
+++ b/src/nautilus-thumbnails-macos.c
@@ -0,0 +1,554 @@
+/*
+ *  nautilus-thumbnails-macos.c: macOS implementation of the thumbnail API.
+ *
+ *  Copyright (C) 2026 The Nautilus authors
+ *
+ *  This program is free software; you can redistribute it and/or
+ *  modify it under the terms of the GNU General Public License as
+ *  published by the Free Software Foundation; either version 2 of the
+ *  License, or (at your option) any later version.
+ *
+ *  This program is distributed in the hope that it will be useful,
+ *  but WITHOUT ANY WARRANTY; without even the implied warranty of
+ *  MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU
+ *  General Public License for more details.
+ *
+ *  You should have received a copy of the GNU General Public
+ *  License along with this program; if not, see <http://www.gnu.org/licenses/>.
+ *
+ *  Implements the contract of nautilus-thumbnails.h without
+ *  GnomeDesktopThumbnailFactory (gnome-desktop is not available on macOS;
+ *  its thumbnailers rely on Linux-only sandboxing). Thumbnail generation is
+ *  delegated to QuickLook (QLThumbnailGenerator) through the bridge seam in
+ *  nautilus-macos-thumbnailer.m, and results are written through to the
+ *  freedesktop.org thumbnail cache so that restarts are warm.
+ *
+ *  Reading of previously cached thumbnails is unaffected: it happens via
+ *  GIO's thumbnail::* attributes and nautilus_thumbnail_get_path_for_uri(),
+ *  which follows the freedesktop.org thumbnail spec layout under
+ *  g_get_user_cache_dir()/thumbnails ($XDG_CACHE_HOME or ~/.cache with
+ *  Homebrew GLib on macOS — GIO's attribute reader uses the same
+ *  directory, so reader and writer always agree).
+ *
+ *  Failure bookkeeping mirrors gnome-desktop: when QuickLook cannot
+ *  thumbnail a file, a "failed thumbnail" marker (1x1 PNG carrying
+ *  Thumb::URI/Thumb::MTime) is written to
+ *  thumbnails/fail/gnome-thumbnail-factory/<md5>.png. GIO reports it as
+ *  G_FILE_ATTRIBUTE_THUMBNAILING_FAILED (nautilus-file.c keeps that in
+ *  file->details->thumbnailing_failed), and nautilus_can_thumbnail()
+ *  returns FALSE for a file with a valid fail marker — exactly like
+ *  gnome_desktop_thumbnail_factory_can_thumbnail() — so a failed file is
+ *  not retried until its mtime changes.
+ */
+#define G_LOG_DOMAIN "nautilus-thumbnails"
+
+#include <config.h>
+#include "nautilus-thumbnails.h"
+
+#include "nautilus-macos-bridge.h"
+
+#include <glib/gstdio.h>
+#include <gtk/gtk.h>
+#include <string.h>
+
+/* Async task for one thumbnail request. A pointer to this struct doubles as
+ * the (fake) GAsyncResult handed to the callback, mirroring the pattern of
+ * the generic implementation in nautilus-thumbnails.c. */
+typedef struct
+{
+    char *image_uri;
+    char *mime_type;
+    time_t mtime;
+    GdkPixbuf *pixbuf;
+    GError *error;
+
+    GCancellable *cancellable;
+    GAsyncReadyCallback callback;
+    gpointer user_data;
+} NautilusThumbnailTask;
+
+static void
+free_thumbnail_task (NautilusThumbnailTask *task)
+{
+    g_free (task->image_uri);
+    g_free (task->mime_type);
+    g_clear_object (&task->pixbuf);
+    g_clear_error (&task->error);
+    g_clear_object (&task->cancellable);
+    g_free (task);
+}
+
+guint
+nautilus_thumbnail_get_max_size (void)
+{
+    static guint max_size = 0;
+
+    if (G_UNLIKELY (max_size == 0))
+    {
+        /* Same scale-to-size mapping as the GnomeDesktopThumbnailSize based
+         * implementation: LARGE (256) up to XXLARGE (1024). */
+        GdkDisplay *display = gdk_display_get_default ();
+        GListModel *monitors = gdk_display_get_monitors (display);
+        gint max_scale = 1;
+
+        for (guint i = 0; i < g_list_model_get_n_items (monitors); i++)
+        {
+            g_autoptr (GdkMonitor) monitor = g_list_model_get_item (monitors, i);
+
+            max_scale = MAX (max_scale, gdk_monitor_get_scale_factor (monitor));
+        }
+
+        if (max_scale <= 1)
+        {
+            max_size = 256;
+        }
+        else if (max_scale <= 2)
+        {
+            max_size = 512;
+        }
+        else
+        {
+            max_size = 1024;
+        }
+    }
+
+    return max_size;
+}
+
+char *
+nautilus_thumbnail_get_path_for_uri (const char *uri)
+{
+    /* freedesktop.org thumbnail spec path, as produced by
+     * gnome_desktop_thumbnail_path_for_uri(). */
+    g_autofree char *checksum = g_compute_checksum_for_string (G_CHECKSUM_MD5, uri, -1);
+    g_autofree char *filename = g_strconcat (checksum, ".png", NULL);
+    const char *size_dir;
+
+    switch (nautilus_thumbnail_get_max_size ())
+    {
+        case 128:
+        {
+            size_dir = "normal";
+        }
+        break;
+
+        case 256:
+        {
+            size_dir = "large";
+        }
+        break;
+
+        case 512:
+        {
+            size_dir = "x-large";
+        }
+        break;
+
+        case 1024:
+        {
+            size_dir = "xx-large";
+        }
+        break;
+
+        default:
+        {
+            g_assert_not_reached ();
+        }
+    }
+
+    return g_build_filename (g_get_user_cache_dir (), "thumbnails", size_dir, filename, NULL);
+}
+
+static GHashTable *
+get_types_table (void)
+{
+    static GHashTable *image_mime_types = NULL;
+    GSList *format_list, *l;
+    char **types;
+    int i;
+
+    if (image_mime_types == NULL)
+    {
+        image_mime_types =
+            g_hash_table_new_full (g_str_hash, g_str_equal,
+                                   g_free, NULL);
+
+        format_list = gdk_pixbuf_get_formats ();
+        for (l = format_list; l; l = l->next)
+        {
+            types = gdk_pixbuf_format_get_mime_types (l->data);
+
+            for (i = 0; types[i] != NULL; i++)
+            {
+                g_hash_table_insert (image_mime_types,
+                                     types [i],
+                                     GUINT_TO_POINTER (1));
+            }
+
+            g_free (types);
+        }
+
+        g_slist_free (format_list);
+    }
+
+    return image_mime_types;
+}
+
+gboolean
+nautilus_thumbnail_is_mimetype_limited_by_size (const char *mime_type)
+{
+    /* GIO's native content types on macOS are UTIs ("public.jpeg"), while
+     * gdk-pixbuf's format table speaks MIME ("image/jpeg"). Normalize UTIs
+     * to MIME so the size limit keeps applying to plain images. */
+    if (mime_type != NULL && strchr (mime_type, '/') == NULL)
+    {
+        g_autofree char *converted = g_content_type_get_mime_type (mime_type);
+
+        if (converted != NULL)
+        {
+            return g_hash_table_lookup (get_types_table (), converted) != NULL;
+        }
+    }
+
+    return g_hash_table_lookup (get_types_table (), mime_type) != NULL;
+}
+
+/***************************************************************************
+ * Backend seam — QuickLook (QLThumbnailGenerator) via
+ * nautilus-macos-thumbnailer.m.
+ *
+ * backend_can_thumbnail() decides up front whether a file type can be
+ * thumbnailed (and refuses files with a valid fail marker), and
+ * backend_generate_async() eventually completes the task on the main loop
+ * with task->pixbuf or task->error set. Results are written through to the
+ * freedesktop thumbnail cache from a worker thread.
+ ***************************************************************************/
+
+static void
+complete_task (NautilusThumbnailTask *task)
+{
+    if (task->callback != NULL)
+    {
+        task->callback (NULL, (GAsyncResult *) task, task->user_data);
+    }
+
+    free_thumbnail_task (task);
+}
+
+static gboolean
+complete_task_in_idle_cb (gpointer data)
+{
+    complete_task (data);
+
+    return G_SOURCE_REMOVE;
+}
+
+static void
+complete_task_in_idle (NautilusThumbnailTask *task)
+{
+    g_idle_add (complete_task_in_idle_cb, task);
+}
+
+/* Fail markers live where GIO's thumbnail attribute reader looks for them
+ * (gio/glocalfileinfo.c hardcodes the "gnome-thumbnail-factory" app dir):
+ * a marker with matching Thumb::URI/Thumb::MTime makes GIO report
+ * G_FILE_ATTRIBUTE_THUMBNAILING_FAILED with a valid cache, which
+ * nautilus-file.c records as file->details->thumbnailing_failed. */
+static char *
+get_failed_thumbnail_path (const char *uri)
+{
+    g_autofree char *checksum = g_compute_checksum_for_string (G_CHECKSUM_MD5, uri, -1);
+    g_autofree char *filename = g_strconcat (checksum, ".png", NULL);
+
+    return g_build_filename (g_get_user_cache_dir (), "thumbnails", "fail",
+                             "gnome-thumbnail-factory", filename, NULL);
+}
+
+static gboolean
+has_valid_failed_thumbnail (const char *uri,
+                            time_t      modified_time)
+{
+    g_autofree char *fail_path = get_failed_thumbnail_path (uri);
+    g_autoptr (GdkPixbuf) marker = gdk_pixbuf_new_from_file (fail_path, NULL);
+
+    if (marker == NULL)
+    {
+        return FALSE;
+    }
+
+    const char *thumb_uri = gdk_pixbuf_get_option (marker, "tEXt::Thumb::URI");
+    const char *thumb_mtime_str = gdk_pixbuf_get_option (marker, "tEXt::Thumb::MTime");
+
+    return g_strcmp0 (thumb_uri, uri) == 0 &&
+           thumb_mtime_str != NULL &&
+           g_ascii_strtoll (thumb_mtime_str, NULL, 10) == (gint64) modified_time;
+}
+
+/* Write-through to the freedesktop thumbnail cache (or the fail-marker dir
+ * when pixbuf is NULL), off the main thread: the PNG encode of a 512px
+ * thumbnail is milliseconds of CPU, which multiplied by a directory full of
+ * images would stall the GTK main loop. */
+typedef struct
+{
+    char *cache_path;
+    char *uri;
+    time_t mtime;
+    GdkPixbuf *pixbuf;      /* NULL => write a 1x1 fail marker */
+} CacheWriteData;
+
+static void
+cache_write_data_free (CacheWriteData *data)
+{
+    g_free (data->cache_path);
+    g_free (data->uri);
+    g_clear_object (&data->pixbuf);
+    g_free (data);
+}
+
+static void
+cache_write_worker (GTask        *gtask,
+                    gpointer      source_object,
+                    gpointer      task_data,
+                    GCancellable *cancellable)
+{
+    CacheWriteData *data = task_data;
+    g_autofree char *dirname = g_path_get_dirname (data->cache_path);
+    g_autofree char *mtime_str = g_strdup_printf ("%" G_GINT64_FORMAT, (gint64) data->mtime);
+    g_autoptr (GdkPixbuf) pixbuf = NULL;
+    g_autoptr (GError) error = NULL;
+    g_autofree gchar *buffer = NULL;
+    gsize buffer_size = 0;
+    const char *option_keys[] =
+    {
+        "tEXt::Thumb::URI", "tEXt::Thumb::MTime", "tEXt::Software", NULL
+    };
+    const char *option_values[] =
+    {
+        data->uri, mtime_str, "Nautilus macOS (QuickLook)", NULL
+    };
+
+    if (g_mkdir_with_parents (dirname, 0700) != 0)
+    {
+        g_warning ("Could not create thumbnail cache directory %s", dirname);
+        g_task_return_boolean (gtask, FALSE);
+
+        return;
+    }
+
+    if (data->pixbuf != NULL)
+    {
+        pixbuf = g_object_ref (data->pixbuf);
+    }
+    else
+    {
+        /* Failed thumbnail: 1x1 transparent marker, as gnome-desktop wrote. */
+        pixbuf = gdk_pixbuf_new (GDK_COLORSPACE_RGB, TRUE, 8, 1, 1);
+        gdk_pixbuf_fill (pixbuf, 0x00000000);
+    }
+
+    if (!gdk_pixbuf_save_to_bufferv (pixbuf, &buffer, &buffer_size, "png",
+                                     (char **) option_keys, (char **) option_values,
+                                     &error) ||
+        !g_file_set_contents_full (data->cache_path, buffer, buffer_size,
+                                   G_FILE_SET_CONTENTS_CONSISTENT, 0600, &error))
+    {
+        g_warning ("Could not write thumbnail cache entry %s: %s",
+                   data->cache_path, error->message);
+        g_task_return_boolean (gtask, FALSE);
+
+        return;
+    }
+
+    g_debug ("Wrote %s to thumbnail cache: %s",
+             data->pixbuf != NULL ? "thumbnail" : "fail marker",
+             data->cache_path);
+    g_task_return_boolean (gtask, TRUE);
+}
+
+static void
+schedule_cache_write (const char *uri,
+                      time_t      mtime,
+                      GdkPixbuf  *pixbuf)
+{
+    CacheWriteData *data = g_new0 (CacheWriteData, 1);
+    g_autoptr (GTask) gtask = NULL;
+
+    data->uri = g_strdup (uri);
+    data->mtime = mtime;
+    data->pixbuf = (pixbuf != NULL) ? g_object_ref (pixbuf) : NULL;
+    data->cache_path = (pixbuf != NULL) ? nautilus_thumbnail_get_path_for_uri (uri)
+                                        : get_failed_thumbnail_path (uri);
+
+    gtask = g_task_new (NULL, NULL, NULL, NULL);
+    g_task_set_source_tag (gtask, schedule_cache_write);
+    g_task_set_priority (gtask, G_PRIORITY_LOW);
+    g_task_set_task_data (gtask, data, (GDestroyNotify) cache_write_data_free);
+    g_task_run_in_thread (gtask, cache_write_worker);
+}
+
+static void
+backend_thumbnail_ready_cb (GdkPixbuf *pixbuf,
+                            GError    *error,
+                            gpointer   user_data)
+{
+    NautilusThumbnailTask *task = user_data;
+
+    if (pixbuf != NULL)
+    {
+        g_autofree char *mtime_str = g_strdup_printf ("%" G_GINT64_FORMAT,
+                                                      (gint64) task->mtime);
+
+        /* nautilus_file_set_thumbnail() validates this option on the
+         * in-memory pixbuf, mirroring upstream thumbnail_generated_cb(). */
+        gdk_pixbuf_set_option (pixbuf, "tEXt::Thumb::MTime", mtime_str);
+
+        task->pixbuf = pixbuf;      /* bridge passes ownership of the ref */
+        schedule_cache_write (task->image_uri, task->mtime, pixbuf);
+
+        g_debug ("QuickLook thumbnail ready: %s (%dx%d)",
+                 task->image_uri,
+                 gdk_pixbuf_get_width (pixbuf),
+                 gdk_pixbuf_get_height (pixbuf));
+    }
+    else
+    {
+        task->error = g_error_copy (error);
+        schedule_cache_write (task->image_uri, task->mtime, NULL);
+
+        g_debug ("QuickLook thumbnail failed, writing fail marker: %s (%s)",
+                 task->image_uri, error->message);
+    }
+
+    /* The bridge already delivers from a main-loop idle. */
+    complete_task (task);
+}
+
+static gboolean
+backend_can_thumbnail (const gchar *uri,
+                       const gchar *mime_type,
+                       time_t       modified_time)
+{
+    g_autofree char *path = g_filename_from_uri (uri, NULL, NULL);
+
+    if (path == NULL)
+    {
+        /* QuickLook needs a real filesystem path; no remote thumbnailing. */
+        return FALSE;
+    }
+
+    if (!nautilus_macos_thumbnail_can_thumbnail (path, mime_type))
+    {
+        return FALSE;
+    }
+
+    /* Like gnome_desktop_thumbnail_factory_can_thumbnail(): a valid fail
+     * marker means "do not retry until the file changes". */
+    return !has_valid_failed_thumbnail (uri, modified_time);
+}
+
+static void
+backend_generate_async (NautilusThumbnailTask *task)
+{
+    g_autofree char *path = g_filename_from_uri (task->image_uri, NULL, NULL);
+
+    if (path == NULL)
+    {
+        g_set_error (&task->error,
+                     G_IO_ERROR,
+                     G_IO_ERROR_NOT_SUPPORTED,
+                     "QuickLook cannot thumbnail non-local URI %s",
+                     task->image_uri);
+        complete_task_in_idle (task);
+
+        return;
+    }
+
+    if (task->mtime == 0)
+    {
+        /* All in-tree callers pass a valid mtime; this fallback only keeps
+         * the cache attributes verifiable for hypothetical new callers. */
+        GStatBuf stat_buf;
+
+        if (g_stat (path, &stat_buf) == 0)
+        {
+            task->mtime = stat_buf.st_mtime;
+        }
+    }
+
+    nautilus_macos_thumbnail_generate_async (path,
+                                             (int) nautilus_thumbnail_get_max_size (),
+                                             backend_thumbnail_ready_cb,
+                                             task);
+}
+
+/***************************************************************************
+ * End backend seam.
+ ***************************************************************************/
+
+gboolean
+nautilus_can_thumbnail (const gchar *uri,
+                        const gchar *mime_type,
+                        time_t       modified_time)
+{
+    return backend_can_thumbnail (uri, mime_type, modified_time);
+}
+
+void
+nautilus_create_thumbnail_async (const gchar         *uri,
+                                 const gchar         *mime_type,
+                                 time_t               modified_time,
+                                 GCancellable        *cancellable,
+                                 GAsyncReadyCallback  callback,
+                                 gpointer             user_data)
+{
+    g_return_if_fail (uri != NULL && *uri != '\0');
+
+    NautilusThumbnailTask *task = g_new0 (NautilusThumbnailTask, 1);
+
+    task->image_uri = g_strdup (uri);
+    task->mime_type = g_strdup (mime_type);
+    task->mtime = modified_time;
+    task->cancellable = (cancellable != NULL) ? g_object_ref (cancellable) : NULL;
+    task->callback = callback;
+    task->user_data = user_data;
+
+    if (cancellable != NULL &&
+        g_cancellable_is_cancelled (cancellable))
+    {
+        complete_task_in_idle (task);
+
+        return;
+    }
+
+    backend_generate_async (task);
+}
+
+GdkPixbuf *
+nautilus_create_thumbnail_finish (GAsyncResult  *res,
+                                  GError       **error)
+{
+    NautilusThumbnailTask *task = (NautilusThumbnailTask *) res;
+
+    if (task->cancellable != NULL &&
+        g_cancellable_is_cancelled (task->cancellable))
+    {
+        if (error != NULL)
+        {
+            *error = g_error_new (G_IO_ERROR, G_IO_ERROR_CANCELLED, "Cancelled");
+        }
+
+        return NULL;
+    }
+
+    if (task->error != NULL)
+    {
+        if (error != NULL)
+        {
+            *error = g_error_copy (task->error);
+        }
+
+        return NULL;
+    }
+
+    return task->pixbuf != NULL ? g_object_ref (task->pixbuf) : NULL;
+}
