diff --git a/src/nautilus-previewer.c b/src/nautilus-previewer.c
index cd5a439..7cd50e2 100644
--- a/src/nautilus-previewer.c
+++ b/src/nautilus-previewer.c
@@ -38,6 +38,151 @@
 #include <gdk/x11/gdkx.h>
 #endif
 
+#ifdef __APPLE__
+
+/* On macOS there is no Sushi (and usually no session bus). The previewer
+ * entry points keep their contract but drive the native QLPreviewPanel
+ * through the macOS bridge instead of D-Bus. */
+
+#include "nautilus-file.h"
+#include "nautilus-macos-bridge.h"
+
+static NautilusWindowSlot *current_slot = NULL; /* weak ref */
+static gchar *current_uri = NULL;
+
+/* Arrow keys pressed while the QuickLook panel is key: move the selection
+ * in the files view, exactly like Sushi's SelectionEvent D-Bus signal. The
+ * selection change then re-enters nautilus_previewer_call_show_file via
+ * the files view's preview-update path, refreshing the panel. */
+static void
+macos_preview_selection_event (NautilusMacosPreviewDirection direction,
+                               gpointer                      user_data)
+{
+    GtkDirectionType gtk_direction;
+
+    if (current_slot == NULL)
+    {
+        return;
+    }
+
+    NautilusFilesView *view = nautilus_window_slot_get_current_view (current_slot);
+
+    if (view == NULL)
+    {
+        return;
+    }
+
+    switch (direction)
+    {
+        case NAUTILUS_MACOS_PREVIEW_DIRECTION_UP:
+        {
+            gtk_direction = GTK_DIR_UP;
+        }
+        break;
+
+        case NAUTILUS_MACOS_PREVIEW_DIRECTION_DOWN:
+        {
+            gtk_direction = GTK_DIR_DOWN;
+        }
+        break;
+
+        case NAUTILUS_MACOS_PREVIEW_DIRECTION_LEFT:
+        {
+            gtk_direction = GTK_DIR_LEFT;
+        }
+        break;
+
+        case NAUTILUS_MACOS_PREVIEW_DIRECTION_RIGHT:
+        default:
+        {
+            gtk_direction = GTK_DIR_RIGHT;
+        }
+        break;
+    }
+
+    nautilus_files_view_preview_selection_event (view, gtk_direction);
+}
+
+void
+nautilus_previewer_call_show_file (const gchar        *uri,
+                                   NautilusWindowSlot *slot,
+                                   gboolean            close_if_already_visible)
+{
+    g_set_weak_pointer (&current_slot, slot);
+    nautilus_macos_preview_set_selection_callback (macos_preview_selection_event, NULL);
+
+    if (close_if_already_visible &&
+        nautilus_macos_preview_is_showing () &&
+        g_strcmp0 (uri, current_uri) == 0)
+    {
+        /* Space on the file already being previewed: toggle the panel away. */
+        nautilus_macos_preview_hide ();
+        return;
+    }
+
+    /* Preview the whole selection so that a multi-select + space pages
+     * through the selected files inside the panel (Finder behavior). */
+    g_autoptr (GPtrArray) uris = g_ptr_array_new_with_free_func (g_free);
+    int selected_index = 0;
+    NautilusFilesView *view = nautilus_window_slot_get_current_view (slot);
+
+    if (view != NULL)
+    {
+        g_autolist (NautilusFile) selection = nautilus_files_view_get_selection (view);
+
+        for (GList *l = selection; l != NULL; l = l->next)
+        {
+            char *one_uri = nautilus_file_get_uri (l->data);
+
+            if (g_strcmp0 (one_uri, uri) == 0)
+            {
+                selected_index = uris->len;
+            }
+
+            g_ptr_array_add (uris, one_uri);
+        }
+    }
+
+    if (uris->len == 0)
+    {
+        g_ptr_array_add (uris, g_strdup (uri));
+        selected_index = 0;
+    }
+
+    g_ptr_array_add (uris, NULL);
+
+    nautilus_macos_preview_files ((const char *const *) uris->pdata, selected_index);
+    g_set_str (&current_uri, uri);
+}
+
+void
+nautilus_previewer_call_close (void)
+{
+    nautilus_macos_preview_hide ();
+}
+
+gboolean
+nautilus_previewer_is_visible (void)
+{
+    return nautilus_macos_preview_is_showing ();
+}
+
+void
+nautilus_previewer_setup (void)
+{
+    nautilus_macos_preview_set_selection_callback (macos_preview_selection_event, NULL);
+}
+
+void
+nautilus_previewer_teardown (GDBusConnection *connection)
+{
+    nautilus_macos_preview_set_selection_callback (NULL, NULL);
+    g_clear_pointer (&current_uri, g_free);
+    g_clear_weak_pointer (&current_slot);
+}
+
+#else /* !__APPLE__ */
+
 #define PREVIEWER2_DBUS_IFACE "org.gnome.NautilusPreviewer2"
 
 static const char *previewer_dbus_name = "org.gnome.NautilusPreviewer" PROFILE;
@@ -421,3 +566,5 @@ nautilus_previewer_is_visible (void)
 
     return FALSE;
 }
+
+#endif /* !__APPLE__ */
