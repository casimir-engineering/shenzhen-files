+/* Finder-style document icons (W11): files whose themed icon would be the
+ * generic one get the LaunchServices icon of the app owning their type
+ * instead (e.g. the KiCad logo on .kicad_pro). Precedence, simplest rule
+ * that keeps everything else intact:
+ *   1. custom icons, thumbnails (QuickLook — images/PDFs) and non-generic
+ *      themed icons (folders, text, archives, …) always win;
+ *   2. only a themed icon that resolves to "application-x-generic" (or not
+ *      at all) is replaced — plus ".app" bundles, the one directory type
+ *      whose LaunchServices icon is strictly more informative;
+ *   3. native local paths only (no path → no NSWorkspace lookup).
+ * Returns NULL whenever the regular themed lookup should proceed. */
+static GdkPaintable *
+get_macos_launchservices_icon (NautilusFile *file,
+                               int           size,
+                               int           scale)
+{
+    g_autoptr (GFile) location = nautilus_file_get_location (file);
+    const char *path = (location != NULL) ? g_file_peek_path (location) : NULL;
+
+    if (path == NULL)
+    {
+        return NULL;
+    }
+
+    if (nautilus_file_is_directory (file))
+    {
+        if (!g_str_has_suffix (path, ".app"))
+        {
+            return NULL;
+        }
+    }
