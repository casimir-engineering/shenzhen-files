+/* --- Starting Folder preference row (macOS port) ---------------------------
+ *
+ * An AdwActionRow in the General group showing the "starting-location"
+ * preference (where windows open when no explicit location is given: app
+ * launch, Dock reopen, New Window). Folder-picker button (GtkFileDialog
+ * select-folder) plus a reset-to-Home button that only shows for a custom
+ * value. Added in C so the shared .blp stays untouched. */
+
+static char *
+starting_folder_subtitle (void)
+{
+    g_autofree char *path = g_settings_get_string (nautilus_preferences,
+                                                   NAUTILUS_PREFERENCES_STARTING_LOCATION);
+
+    if (path == NULL || path[0] == '\0')
+    {
+        return g_strdup (_("Home"));
+    }
+
+    const char *home = g_get_home_dir ();
+    size_t home_len = strlen (home);
+
+    if (g_str_has_prefix (path, home) &&
+        (path[home_len] == '\0' || path[home_len] == '/'))
+    {
+        return g_strdup_printf ("~%s", path + home_len);
+    }
+
+    return g_steal_pointer (&path);
+}
+
+static void
+starting_folder_refresh_row (GtkWidget *row_widget)
+{
+    AdwActionRow *row = ADW_ACTION_ROW (row_widget);
+    GtkWidget *reset_button = g_object_get_data (G_OBJECT (row), "reset-button");
+    g_autofree char *value = g_settings_get_string (nautilus_preferences,
+                                                    NAUTILUS_PREFERENCES_STARTING_LOCATION);
+    g_autofree char *subtitle = starting_folder_subtitle ();
+
+    adw_action_row_set_subtitle (row, subtitle);
+    gtk_widget_set_visible (reset_button, value != NULL && value[0] != '\0');
+}
+
+static void
+starting_folder_selected_cb (GObject      *source,
+                             GAsyncResult *result,
+                             gpointer      user_data)
+{
+    g_autoptr (GError) error = NULL;
+    g_autoptr (GFile) folder = gtk_file_dialog_select_folder_finish (GTK_FILE_DIALOG (source),
+                                                                     result, &error);
+
+    if (folder != NULL)
+    {
+        g_autofree char *path = g_file_get_path (folder);
+
+        if (path != NULL)
+        {
+            g_settings_set_string (nautilus_preferences,
+                                   NAUTILUS_PREFERENCES_STARTING_LOCATION, path);
+        }
+    }
+}
+
+static void
+starting_folder_pick_cb (GtkButton *button,
+                         gpointer   user_data)
+{
+    GtkWidget *row = user_data;
+    g_autoptr (GtkFileDialog) dialog = gtk_file_dialog_new ();
+    g_autofree char *current = g_settings_get_string (nautilus_preferences,
