+static void
+macos_setup_window (NautilusWindow *window)
+{
+    /* Cmd accelerators for widget-scoped actions owned by other source
+     * files (view./slot. groups are inserted on the window). Bound in the
+     * BUBBLE phase on the window: the focused widget — in particular text
+     * entries with their own Cmd-X/C/V/A/Z bindings — always gets the key
+     * first, and only unconsumed presses fall through to these. */
+    static const struct
+    {
+        const char *trigger;
+        const char *action;
+    } shortcuts[] =
+    {
+        /* Text-editing-sensitive combos (menu items carry no equivalents) */
+        { "<Meta>z", "win.undo" },
+        { "<Meta><Shift>z", "win.redo" },
+        { "<Meta>x", "view.cut" },
+        { "<Meta>c", "view.copy" },
+        { "<Meta>v", "view.paste" },
+        { "<Meta>a", "view.select-all" },
+        { "<Meta>Up", "slot.up" },
+        /* Finder parity: Cmd-Down opens the selection */
+        { "<Meta>Down", "view.open-with-default-application" },
+        /* Backups/aliases for combos also present as menu key equivalents */
+        { "<Meta>BackSpace", "view.move-to-trash" },
+        { "<Meta>plus|<Meta>KP_Add", "view.zoom-in" },
+        { "<Meta>KP_Subtract", "view.zoom-out" },
+        { "<Meta>KP_0", "view.zoom-standard" },
+        { "<Meta>greater", "view.show-hidden-files" },
+        /* Browser-style bookmark shortcut (Cmd-D duplicates nothing here) */
+        { "<Meta>d", "slot.bookmark-current-directory" },
+        /* GNOME muscle memory: Cmd-L also opens the location bar */
+        { "<Meta>l", "win.macos-edit-location" },
+    };
+
+    GtkShortcutController *controller;
+    g_autoptr (GSimpleAction) edit_location = NULL;
+
+    edit_location = g_simple_action_new ("macos-edit-location", NULL);
+    g_signal_connect (edit_location, "activate",
+                      G_CALLBACK (macos_edit_location_activate), window);
+    g_action_map_add_action (G_ACTION_MAP (window), G_ACTION (edit_location));
+
+    controller = GTK_SHORTCUT_CONTROLLER (gtk_shortcut_controller_new ());
+    gtk_event_controller_set_propagation_phase (GTK_EVENT_CONTROLLER (controller),
+                                                GTK_PHASE_BUBBLE);
+
+    for (gsize i = 0; i < G_N_ELEMENTS (shortcuts); i++)
+    {
+        gtk_shortcut_controller_add_shortcut (
+            controller,
+            gtk_shortcut_new (gtk_shortcut_trigger_parse_string (shortcuts[i].trigger),
+                              gtk_named_action_new (shortcuts[i].action)));
+    }
+
+    gtk_widget_add_controller (GTK_WIDGET (window), GTK_EVENT_CONTROLLER (controller));
+}
