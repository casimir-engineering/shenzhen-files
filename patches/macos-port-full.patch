+/* "toolbar.edit-location" is a widget class action on NautilusToolbar and
+ * is not reachable from the window's action muxer (the toolbar sits on a
+ * sibling branch of the focused widget). Bridge it with a window action so
+ * the Go menu / Cmd-Shift-G / Cmd-L can open the location bar. */
+static void
+macos_edit_location_activate (GSimpleAction *action,
+                              GVariant      *parameter,
+                              gpointer       user_data)
+{
+    GtkWidget *toolbar = macos_find_descendant_by_type_name (GTK_WIDGET (user_data),
+                                                             "NautilusToolbar");
+
+    if (toolbar != NULL)
+    {
+        gtk_widget_activate_action (toolbar, "toolbar.edit-location", NULL);
+    }
+}
