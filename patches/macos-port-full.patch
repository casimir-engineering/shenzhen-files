+#ifdef __APPLE__
+
+/* ==========================================================================
+ * Finder Integration page (darwin-only, W12)
+ *
+ * Three opt-in toggles wired to the engine in nautilus-macos-integration.m,
+ * plus Revert All and a status line. The switches reflect LIVE system
+ * status when the dialog opens (LaunchServices / com.apple.finder defaults
+ * reads — never just the stored keyfile state), and building/opening the
+ * page applies NOTHING: apply/revert run only when the user flips a toggle
+ * or presses Revert All. Everything defaults to OFF and every change is
+ * revertible (the engine records pre-change system values).
+ * ========================================================================== */
+
+typedef struct
+{
+    AdwSwitchRow *rows[3];      /* indexed by NautilusMacosIntegration */
+    GtkLabel *status_label;
+    gboolean updating;          /* re-entrancy guard for programmatic sets */
+} FinderIntegrationPage;
+
+#define FINDER_INTEGRATION_PAGE_KEY "nautilus-finder-integration-page"
+#define FINDER_INTEGRATION_KIND_KEY "nautilus-finder-integration-kind"
+
+static void
+finder_integration_update_status_line (FinderIntegrationPage *page,
+                                       const char            *error_message)
+{
+    g_autofree char *handler_detail = NULL;
+    g_autofree char *favorites_detail = NULL;
+    g_autofree char *desktop_detail = NULL;
+    g_autofree char *text = NULL;
+
+    nautilus_macos_integration_status (NAUTILUS_MACOS_INTEGRATION_DEFAULT_HANDLER,
+                                       &handler_detail);
+    nautilus_macos_integration_status (NAUTILUS_MACOS_INTEGRATION_FAVORITES,
+                                       &favorites_detail);
+    nautilus_macos_integration_status (NAUTILUS_MACOS_INTEGRATION_HIDE_DESKTOP,
+                                       &desktop_detail);
+
+    text = g_strdup_printf ("%s%s%s • %s • %s",
+                            error_message != NULL ? error_message : "",
+                            error_message != NULL ? "\n" : "",
+                            handler_detail, favorites_detail, desktop_detail);
+    gtk_label_set_label (page->status_label, text);
+    gtk_widget_remove_css_class (GTK_WIDGET (page->status_label), "error");
+    if (error_message != NULL)
+    {
+        gtk_widget_add_css_class (GTK_WIDGET (page->status_label), "error");
+    }
+}
+
+/* Set every switch from live system status, without triggering apply/revert. */
+static void
+finder_integration_refresh_switches (FinderIntegrationPage *page)
+{
+    page->updating = TRUE;
+    for (int i = 0; i < 3; i++)
+    {
+        adw_switch_row_set_active (page->rows[i],
+                                   nautilus_macos_integration_status (i, NULL));
+    }
+    page->updating = FALSE;
+}
+
+static void
+finder_integration_row_toggled (GObject    *object,
+                                GParamSpec *pspec,
+                                gpointer    user_data)
+{
+    FinderIntegrationPage *page = user_data;
+    AdwSwitchRow *row = ADW_SWITCH_ROW (object);
+    NautilusMacosIntegration which =
+        GPOINTER_TO_INT (g_object_get_data (object, FINDER_INTEGRATION_KIND_KEY));
+    gboolean active = adw_switch_row_get_active (row);
+    g_autoptr (GError) error = NULL;
+    gboolean success;
+
+    if (page->updating)
+    {
+        return;
+    }
+
+    /* This is THE user gesture: the only place (besides Revert All) where
+     * the engine's apply/revert paths run. */
+    success = active ?
+              nautilus_macos_integration_apply (which, &error) :
+              nautilus_macos_integration_revert (which, &error);
+
+    if (!success)
+    {
+        /* Surface the engine's error and snap the switch back to reality. */
+        page->updating = TRUE;
+        adw_switch_row_set_active (row,
+                                   nautilus_macos_integration_status (which, NULL));
+        page->updating = FALSE;
+    }
+
+    finder_integration_update_status_line (page,
+                                           error != NULL ? error->message : NULL);
+}
+
+/* W13 handoff toggle: independent of the three W12 integrations. Flipping it
+ * arms/disarms the ⌃⌥⌘G hotkey and persists the choice. If Accessibility is
+ * not granted, enabling still records the choice but the hotkey no-ops until
+ * the user grants the permission, so we surface that in the subtitle. */
+static void
+savepanel_handoff_row_toggled (GObject    *object,
+                               GParamSpec *pspec,
+                               gpointer    user_data)
+{
+    FinderIntegrationPage *page = user_data;
+    AdwSwitchRow *row = ADW_SWITCH_ROW (object);
+    gboolean active;
+
+    if (page->updating)
+    {
+        return;
+    }
+    active = adw_switch_row_get_active (row);
+    nautilus_macos_savepanel_handoff_set_enabled (active);
+
+    if (active && !nautilus_macos_savepanel_handoff_accessibility_granted ())
+    {
+        adw_action_row_set_subtitle (
+            ADW_ACTION_ROW (row),
+            _("Enabled, but Accessibility permission is not granted yet — the "
+              "hotkey will do nothing until you allow Nautilus in System "
+              "Settings ▸ Privacy & Security ▸ Accessibility."));
+        nautilus_macos_savepanel_handoff_open_accessibility_settings ();
+    }
+    else
+    {
+        adw_action_row_set_subtitle (
+            ADW_ACTION_ROW (row),
+            _("Press ⌃⌥⌘G while another app’s Save/Open panel is open, then "
+              "choose a folder — Nautilus navigates the panel there. You still "
+              "finish saving in the native panel."));
+    }
+}
+
+static void
+finder_integration_revert_all_cb (AdwButtonRow *button_row,
+                                  gpointer      user_data)
+{
+    FinderIntegrationPage *page = user_data;
+    g_autoptr (GError) error = NULL;
+
+    nautilus_macos_integration_revert_all (&error);
+    finder_integration_refresh_switches (page);
+    finder_integration_update_status_line (page,
+                                           error != NULL ? error->message : NULL);
+}
+
+static AdwSwitchRow *
+finder_integration_add_row (AdwPreferencesGroup      *group,
+                            FinderIntegrationPage    *page,
+                            NautilusMacosIntegration  which,
+                            const char               *title,
+                            const char               *subtitle)
+{
+    GtkWidget *row = adw_switch_row_new ();
+
+    adw_preferences_row_set_title (ADW_PREFERENCES_ROW (row), title);
+    adw_action_row_set_subtitle (ADW_ACTION_ROW (row), subtitle);
+    g_object_set_data (G_OBJECT (row), FINDER_INTEGRATION_KIND_KEY,
+                       GINT_TO_POINTER (which));
+    g_signal_connect (row, "notify::active",
+                      G_CALLBACK (finder_integration_row_toggled), page);
+    adw_preferences_group_add (group, row);
+    page->rows[which] = ADW_SWITCH_ROW (row);
+
+    return ADW_SWITCH_ROW (row);
+}
+
+static AdwPreferencesPage *
+finder_integration_build_page (void)
+{
+    AdwPreferencesPage *prefs_page = ADW_PREFERENCES_PAGE (adw_preferences_page_new ());
+    AdwPreferencesGroup *toggles_group =
+        ADW_PREFERENCES_GROUP (adw_preferences_group_new ());
+    AdwPreferencesGroup *revert_group =
+        ADW_PREFERENCES_GROUP (adw_preferences_group_new ());
+    AdwPreferencesGroup *status_group =
+        ADW_PREFERENCES_GROUP (adw_preferences_group_new ());
+    FinderIntegrationPage *page = g_new0 (FinderIntegrationPage, 1);
+    GtkWidget *revert_row;
+    AdwSwitchRow *handler_row;
+    AdwSwitchRow *favorites_row;
+    g_autofree char *handler_unsupported_reason = NULL;
+    g_autofree char *probe_detail = NULL;
+
+    g_object_set_data_full (G_OBJECT (prefs_page), FINDER_INTEGRATION_PAGE_KEY,
+                            page, g_free);
+
+    adw_preferences_page_set_title (prefs_page, _("Finder Integration"));
+    adw_preferences_page_set_name (prefs_page, "finder-integration");
+    adw_preferences_page_set_icon_name (prefs_page, "folder-symbolic");
+
+    adw_preferences_group_set_title (toggles_group, _("Finder Integration"));
+    adw_preferences_group_set_description (
+        toggles_group,
+        _("All integrations are optional, off by default, and fully revertible: "
+          "Shenzhen Files remembers the previous system setting and restores it "
+          "when "
+          "a toggle is turned off."));
+
+    handler_row = finder_integration_add_row (
+        toggles_group, page,
+        NAUTILUS_MACOS_INTEGRATION_DEFAULT_HANDLER,
+        _("Open Folders by Default"),
+        _("Make Shenzhen Files the default app for opening folders. The current "
+          "handler is remembered and restored when turned off."));
+
+    favorites_row = finder_integration_add_row (
+        toggles_group, page,
+        NAUTILUS_MACOS_INTEGRATION_FAVORITES,
+        _("Sync Sidebar Favorites"),
+        _("Import Finder’s sidebar favorites as bookmarks and add Shenzhen Files "
+          "bookmarks to the Finder sidebar. Turning this off removes only "
+          "the items Shenzhen Files added — never yours."));
+
+    finder_integration_add_row (
+        toggles_group, page,
+        NAUTILUS_MACOS_INTEGRATION_HIDE_DESKTOP,
+        _("Hide Finder Desktop"),
+        _("Stop Finder from drawing icons on the desktop (Finder relaunches "
+          "when toggled). The previous setting is restored when turned off."));
+
+    /* Honest capability degradation: macOS 26+ forbids changing the folder
+     * handler entirely (every LaunchServices route refuses the change), so
+     * render the toggle insensitive with the engine's explanation. */
+    if (!nautilus_macos_integration_default_handler_supported (&handler_unsupported_reason))
+    {
+        gtk_widget_set_sensitive (GTK_WIDGET (handler_row), FALSE);
+        adw_action_row_set_subtitle (ADW_ACTION_ROW (handler_row),
+                                     handler_unsupported_reason);
+    }
+
+    /* Honest capability degradation: if the shared favorites list is not
+     * even readable on this macOS, disable the row and say why. */
+    if (!nautilus_macos_integration_favorites_probe (NULL, &probe_detail))
+    {
+        gtk_widget_set_sensitive (GTK_WIDGET (favorites_row), FALSE);
+        adw_action_row_set_subtitle (ADW_ACTION_ROW (favorites_row), probe_detail);
+    }
+
+    /* W13: "Choose in Nautilus" Save/Open-panel handoff (prototype). Its own
+     * group so it reads as a separate, Accessibility-gated feature. */
+    {
+        AdwPreferencesGroup *handoff_group =
+            ADW_PREFERENCES_GROUP (adw_preferences_group_new ());
+        GtkWidget *handoff_row = adw_switch_row_new ();
+        gboolean handoff_on = nautilus_macos_savepanel_handoff_get_enabled ();
+
+        adw_preferences_group_set_title (handoff_group,
+                                         _("Choose in Shenzhen Files (Prototype)"));
+        adw_preferences_group_set_description (
+            handoff_group,
+            _("When another app shows a native Save or Open panel, press "
+              "⌃⌥⌘G to pick a destination folder in Shenzhen Files and have the "
+              "panel jump there. Requires the Accessibility permission and is "
+              "off by default. You always complete the save in the native "
+              "panel."));
+
+        adw_preferences_row_set_title (ADW_PREFERENCES_ROW (handoff_row),
+                                       _("Enable Save/Open Panel Handoff"));
+        adw_action_row_set_subtitle (
+            ADW_ACTION_ROW (handoff_row),
+            _("Press ⌃⌥⌘G while another app’s Save/Open panel is open, then "
+              "choose a folder — Nautilus navigates the panel there. You still "
+              "finish saving in the native panel."));
+        page->updating = TRUE;
+        adw_switch_row_set_active (ADW_SWITCH_ROW (handoff_row), handoff_on);
+        page->updating = FALSE;
+        g_signal_connect (handoff_row, "notify::active",
+                          G_CALLBACK (savepanel_handoff_row_toggled), page);
+        adw_preferences_group_add (handoff_group, handoff_row);
+        adw_preferences_page_add (prefs_page, handoff_group);
+    }
+
+    revert_row = adw_button_row_new ();
+    adw_preferences_row_set_title (ADW_PREFERENCES_ROW (revert_row),
+                                   _("Revert All Integrations"));
+    gtk_widget_add_css_class (revert_row, "destructive-action");
+    g_signal_connect (revert_row, "activated",
+                      G_CALLBACK (finder_integration_revert_all_cb), page);
+    adw_preferences_group_add (revert_group, revert_row);
+
+    page->status_label = GTK_LABEL (gtk_label_new (""));
+    gtk_label_set_wrap (page->status_label, TRUE);
+    gtk_label_set_xalign (page->status_label, 0.0);
+    gtk_widget_add_css_class (GTK_WIDGET (page->status_label), "dim-label");
+    adw_preferences_group_add (status_group, GTK_WIDGET (page->status_label));
+
+    adw_preferences_page_add (prefs_page, toggles_group);
+    adw_preferences_page_add (prefs_page, revert_group);
+    adw_preferences_page_add (prefs_page, status_group);
+
+    /* Reflect REAL system status on open — reads only, never applies. */
+    finder_integration_refresh_switches (page);
+    finder_integration_update_status_line (page, NULL);
+
+    return prefs_page;
+}
