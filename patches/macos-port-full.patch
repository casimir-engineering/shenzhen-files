+ *
+ * NSMetadataQuery-backed provider used by nautilus-search-engine-spotlight.c.
+ * ========================================================================== */
+
+/* Opaque handle for one running Spotlight query. */
+typedef struct _NautilusMacosSpotlightQuery NautilusMacosSpotlightQuery;
+
+/* Called once per hit, on the GLib main loop. @path is a local filesystem
+ * path; valid only for the duration of the call. @mtime/@atime/@ctime are
+ * Unix timestamps taken from the Spotlight index (content-change,
+ * last-used and creation dates); 0 means "unknown". They are passed here
+ * so the consumer does not need an extra stat per hit. */
+typedef void (*NautilusMacosSpotlightHitFunc) (const char *path,
+                                               gint64      mtime,
+                                               gint64      atime,
+                                               gint64      ctime,
+                                               gpointer    user_data);
+
+/* Called exactly once when the query finishes or is stopped. @error is
+ * NULL on success (including "stopped"), otherwise owned by the bridge and
+ * valid only for the duration of the call. */
+typedef void (*NautilusMacosSpotlightFinishedFunc) (GError   *error,
+                                                    gpointer  user_data);
+
+/* Start a Spotlight (NSMetadataQuery) search for @query_text scoped to the
+ * directory @scope_path (recursive). Returns a handle, or NULL if the
+ * backend is unavailable (callers must then fall back to another engine;
+ * no callbacks will be delivered). Stub: logs and returns NULL. */
+NautilusMacosSpotlightQuery *nautilus_macos_spotlight_query_start (const char                         *query_text,
+                                                                   const char                         *scope_path,
+                                                                   NautilusMacosSpotlightHitFunc       hit_func,
+                                                                   NautilusMacosSpotlightFinishedFunc  finished_func,
+                                                                   gpointer                            user_data);
+
+/* Stop @query and release it. Safe to call with NULL. No callbacks are
+ * delivered after this returns (the finished callback, if still pending,
+ * fires before or during this call). Stub: no-op. */
+void nautilus_macos_spotlight_query_stop (NautilusMacosSpotlightQuery *query);
