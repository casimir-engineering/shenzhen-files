+ * General Public License for more details.
+ *
+ * You should have received a copy of the GNU General Public
+ * License along with this program; if not, see <http://www.gnu.org/licenses/>.
+ *
+ * ==========================================================================
+ * DESIGN CONTRACT — READ BEFORE EDITING
+ *
+ * A native Save/Open panel is frontmost in SOME OTHER app. The user presses
+ * a system-wide hotkey (⌃⌥⌘G); Nautilus pops a folder chooser; on a choice,
+ * Nautilus drives the OTHER app's panel to that folder via the Accessibility
+ * API and stops — the user finishes Save/Open in the native panel. This
+ * preserves the sandbox/Powerbox security model: we only NAVIGATE the panel,
+ * we never read/write the file on the user's behalf.
+ *
+ * OPT-IN and DISARMED BY DEFAULT. Two independent gates must both hold for
+ * the hotkey to do anything:
+ *   1. The [savepanel-handoff] enabled toggle in the integration keyfile.
+ *   2. The Accessibility permission (AXIsProcessTrusted), granted by the USER
+ *      in System Settings. Without it, the AX reads/writes silently fail.
+ *
+ * The hotkey is armed ONLY from nautilus_macos_savepanel_handoff_init()
+ * (launch time, when the stored toggle is ON) or the preferences switch.
+ * Nothing here touches system state otherwise.
+ *
+ * PROTOTYPE SCOPE: proven end-to-end against TextEdit's Save panel only.
+ * The AX signature and the "Go to Folder" drive sequence are tuned to the
+ * standard AppKit NSSavePanel/NSOpenPanel; sandboxed apps host the panel in
+ * a separate process (com.apple.appkit.xpc.openAndSavePanelService) whose
+ * AX tree is still reachable from the owning app element, but see the
+ * fragility notes in docs/STATUS.md for what has NOT been validated.
+ * ==========================================================================
+ */
+
+#define G_LOG_DOMAIN "nautilus-macos-bridge"
+
+#include <config.h>
+#include "nautilus-macos-bridge.h"
+
+#include <glib/gi18n.h>
+#include <gtk/gtk.h>
+
+#import <AppKit/AppKit.h>
+#import <ApplicationServices/ApplicationServices.h>
+#import <Carbon/Carbon.h>
+
+/* Hardcoded for the prototype (configurable later): ⌃⌥⌘G. */
+#define HANDOFF_HOTKEY_KEYCODE   kVK_ANSI_G
+#define HANDOFF_HOTKEY_MODIFIERS (controlKey | optionKey | cmdKey)
+#define HANDOFF_HOTKEY_SIGNATURE 'NaHo'
+#define HANDOFF_HOTKEY_ID        1
+
+/* Keyfile (shared with W12 integration state). */
+#define HANDOFF_STATE_GROUP "savepanel-handoff"
+#define HANDOFF_STATE_KEY_ENABLED "enabled"
+
+/* --- State keyfile --------------------------------------------------------- */
+
+static char *
+handoff_state_path (void)
+{
+    return g_build_filename (g_get_user_config_dir (), "nautilus",
+                             "macos-integration.ini", NULL);
+}
+
+gboolean
+nautilus_macos_savepanel_handoff_get_enabled (void)
+{
+    g_autofree char *path = handoff_state_path ();
+    g_autoptr (GKeyFile) key_file = g_key_file_new ();
+
+    g_key_file_load_from_file (key_file, path, G_KEY_FILE_KEEP_COMMENTS, NULL);
+
+    return g_key_file_get_boolean (key_file, HANDOFF_STATE_GROUP,
+                                   HANDOFF_STATE_KEY_ENABLED, NULL);
+}
+
+static void
+handoff_state_set_enabled (gboolean enabled)
+{
+    g_autofree char *path = handoff_state_path ();
+    g_autofree char *dir = g_path_get_dirname (path);
+    g_autoptr (GKeyFile) key_file = g_key_file_new ();
+    g_autoptr (GError) error = NULL;
+
+    g_key_file_load_from_file (key_file, path, G_KEY_FILE_KEEP_COMMENTS, NULL);
+    g_key_file_set_boolean (key_file, HANDOFF_STATE_GROUP,
+                            HANDOFF_STATE_KEY_ENABLED, enabled);
+
+    g_mkdir_with_parents (dir, 0700);
+    if (!g_key_file_save_to_file (key_file, path, &error))
+    {
+        g_warning ("savepanel-handoff: could not save state: %s", error->message);
+    }
+}
+
+/* --- Accessibility permission --------------------------------------------- */
+
+gboolean
+nautilus_macos_savepanel_handoff_accessibility_granted (void)
+{
+    return AXIsProcessTrusted () ? TRUE : FALSE;
+}
+
+void
+nautilus_macos_savepanel_handoff_open_accessibility_settings (void)
+{
+    @autoreleasepool
+    {
+        NSURL *url = [NSURL URLWithString:
+            @"x-apple.systempreferences:com.apple.preference.security?Privacy_Accessibility"];
+        [[NSWorkspace sharedWorkspace] openURL:url];
+    }
+}
+
+/* --- AX helpers (no GTK) --------------------------------------------------- */
+
+static NSString *
+ax_string (AXUIElementRef el, CFStringRef attr)
+{
+    CFTypeRef value = NULL;
+
+    if (el == NULL
+        || AXUIElementCopyAttributeValue (el, attr, &value) != kAXErrorSuccess
+        || value == NULL)
+    {
+        return nil;
+    }
+    if (CFGetTypeID (value) == CFStringGetTypeID ())
+    {
+        return CFBridgingRelease (value);
+    }
+    NSString *desc = [(__bridge id) value description];
+    CFRelease (value);
+    return desc;
+}
+
+static NSArray *
+ax_children (AXUIElementRef el)
+{
+    CFArrayRef kids = NULL;
+
+    if (el == NULL
+        || AXUIElementCopyAttributeValue (el, kAXChildrenAttribute, (CFTypeRef *) &kids) != kAXErrorSuccess
+        || kids == NULL)
+    {
+        return @[];
+    }
+    return CFBridgingRelease (kids);
+}
+
+/* Depth-first search for a descendant whose AXIdentifier equals @identifier.
+ * Returns a +1 retained element (caller CFReleases) or NULL. */
+static AXUIElementRef
+ax_find_by_identifier (AXUIElementRef root, NSString *identifier, int maxdepth)
+{
+    if (root == NULL || maxdepth < 0)
+    {
+        return NULL;
+    }
+    if ([ax_string (root, kAXIdentifierAttribute) isEqualToString:identifier])
+    {
+        return (AXUIElementRef) CFRetain (root);
+    }
+    for (id child in ax_children (root))
+    {
+        AXUIElementRef found =
+            ax_find_by_identifier ((__bridge AXUIElementRef) child, identifier, maxdepth - 1);
+        if (found != NULL)
+        {
+            return found;
+        }
+    }
+    return NULL;
+}
+
+/* Is @element an Open/Save panel? Standard AppKit panels carry the
+ * AXIdentifier "save-panel" (NSSavePanel) or "open-panel" (NSOpenPanel).
+ * The reliable secondary signature is the presence of the Save-As name
+ * field ("saveAsNameTextField") and/or the "Where:" popup ("where popup")
+ * plus the Cancel/OK buttons ("CancelButton"/"OKButton"). */
+static gboolean
+ax_element_is_panel (AXUIElementRef element)
+{
+    NSString *ident = ax_string (element, kAXIdentifierAttribute);
+
+    if ([ident isEqualToString:@"save-panel"] || [ident isEqualToString:@"open-panel"])
+    {
+        return TRUE;
+    }
+    /* Fallback: identify by the characteristic controls (robustness for
+     * apps whose panel window carries no identifier). */
+    AXUIElementRef ok = ax_find_by_identifier (element, @"OKButton", 8);
+    AXUIElementRef where = ax_find_by_identifier (element, @"where popup", 8);
+    gboolean is_panel = (ok != NULL && where != NULL);
+
+    if (ok != NULL)
+    {
+        CFRelease (ok);
+    }
+    if (where != NULL)
+    {
+        CFRelease (where);
+    }
+    return is_panel;
+}
+
+/* Find the panel element (window or attached sheet) in @pid. +1 retained. */
+static AXUIElementRef
+ax_find_panel_in_pid (pid_t pid)
+{
+    AXUIElementRef app = AXUIElementCreateApplication (pid);
+    CFArrayRef windows = NULL;
+    AXUIElementRef panel = NULL;
+
+    if (AXUIElementCopyAttributeValue (app, kAXWindowsAttribute, (CFTypeRef *) &windows) != kAXErrorSuccess
+        || windows == NULL)
+    {
+        CFRelease (app);
+        return NULL;
+    }
+    for (CFIndex i = 0; panel == NULL && i < CFArrayGetCount (windows); i++)
+    {
+        AXUIElementRef win = (AXUIElementRef) CFArrayGetValueAtIndex (windows, i);
+
+        if (ax_element_is_panel (win))
+        {
+            panel = (AXUIElementRef) CFRetain (win);
+            break;
+        }
+        /* Sheet-hosted panels (TextEdit's Cmd-S case). */
+        for (id child in ax_children (win))
+        {
+            AXUIElementRef el = (__bridge AXUIElementRef) child;
+
+            if ([ax_string (el, kAXRoleAttribute) isEqualToString:(__bridge NSString *) kAXSheetRole]
+                && ax_element_is_panel (el))
+            {
+                panel = (AXUIElementRef) CFRetain (el);
+                break;
+            }
+        }
+    }
+    CFRelease (windows);
+    CFRelease (app);
+    return panel;
+}
+
+int
+nautilus_macos_savepanel_find_frontmost_panel_pid (void)
+{
+    @autoreleasepool
+    {
+        NSRunningApplication *front = [[NSWorkspace sharedWorkspace] frontmostApplication];
+
+        if (front == nil)
+        {
+            return 0;
+        }
+        /* Never target ourselves. */
+        if (front.processIdentifier == getpid ())
+        {
+            return 0;
+        }
+        AXUIElementRef panel = ax_find_panel_in_pid (front.processIdentifier);
+
+        if (panel == NULL)
+        {
+            return 0;
+        }
+        CFRelease (panel);
+        return (int) front.processIdentifier;
+    }
+}
+
+/* Post a single key event (session tap) with the given modifier flags. */
+static void
+post_key (CGKeyCode key, bool down, CGEventFlags flags)
+{
+    CGEventRef ev = CGEventCreateKeyboardEvent (NULL, key, down);
+
+    CGEventSetFlags (ev, flags);
+    CGEventPost (kCGSessionEventTap, ev);
+    CFRelease (ev);
+    usleep (25 * 1000);
+}
+
+/* ⌘⇧G as a genuine modifier chord with correct flag transitions on every
+ * event, then a full release. Posting a bare G-with-combined-flags leaves
+ * the window server's modifier state inconsistent and silently swallows the
+ * unicode keystrokes typed immediately afterwards. */
+static void
+post_cmd_shift_g (void)
+{
+    post_key (kVK_Command, true, kCGEventFlagMaskCommand);
+    post_key (kVK_Shift, true, kCGEventFlagMaskCommand | kCGEventFlagMaskShift);
+    post_key (kVK_ANSI_G, true, kCGEventFlagMaskCommand | kCGEventFlagMaskShift);
+    post_key (kVK_ANSI_G, false, kCGEventFlagMaskCommand | kCGEventFlagMaskShift);
+    post_key (kVK_Shift, false, kCGEventFlagMaskCommand);
+    post_key (kVK_Command, false, 0);
+}
+
+/* Type @text as CGEvent unicode-string keystrokes (chunked; no per-key
+ * layout dependence). */
+static void
+post_unicode_string (NSString *text)
+{
+    for (NSUInteger off = 0; off < text.length; off += 8)
+    {
+        NSString *chunk = [text substringWithRange:
+                           NSMakeRange (off, MIN ((NSUInteger) 8, text.length - off))];
+        unichar buf[8];
+        [chunk getCharacters:buf range:NSMakeRange (0, chunk.length)];
+
+        CGEventRef down = CGEventCreateKeyboardEvent (NULL, 0, true);
+        CGEventRef up = CGEventCreateKeyboardEvent (NULL, 0, false);
+        CGEventKeyboardSetUnicodeString (down, chunk.length, buf);
+        CGEventKeyboardSetUnicodeString (up, chunk.length, buf);
+        CGEventPost (kCGSessionEventTap, down);
+        CGEventPost (kCGSessionEventTap, up);
+        CFRelease (down);
+        CFRelease (up);
+        usleep (60 * 1000);
+    }
+}
+
+/* Read the panel's current-location evidence into a caller-owned string. */
+static char *
+panel_location_evidence (AXUIElementRef panel)
+{
+    NSString *where = nil;
+    AXUIElementRef where_popup = ax_find_by_identifier (panel, @"where popup", 8);
+
+    if (where_popup != NULL)
+    {
+        where = ax_string (where_popup, kAXValueAttribute);
+        CFRelease (where_popup);
+    }
+    return g_strdup_printf ("Where: popup = \"%s\"", where.UTF8String ?: "(unknown)");
+}
+
+gboolean
+nautilus_macos_savepanel_drive (int          target_pid,
+                                const char  *target_path,
+                                char       **out_evidence,
+                                GError     **error)
+{
+    if (out_evidence != NULL)
+    {
+        *out_evidence = NULL;
+    }
+    if (!AXIsProcessTrusted ())
+    {
+        g_set_error_literal (error, G_IO_ERROR, G_IO_ERROR_PERMISSION_DENIED,
+                             "Accessibility permission not granted "
+                             "(System Settings ▸ Privacy & Security ▸ Accessibility).");
+        return FALSE;
+    }
+
+    @autoreleasepool
+    {
+        AXUIElementRef panel = ax_find_panel_in_pid ((pid_t) target_pid);
+
+        if (panel == NULL)
+        {
+            g_set_error (error, G_IO_ERROR, G_IO_ERROR_NOT_FOUND,
+                         "No Open/Save panel found in the target application (pid %d).",
+                         target_pid);
+            return FALSE;
+        }
+
+        NSString *path = [NSString stringWithUTF8String:target_path];
+
+        /* 1. Bring the target frontmost so keystrokes land on its panel. */
+        NSRunningApplication *ra =
+            [NSRunningApplication runningApplicationWithProcessIdentifier:(pid_t) target_pid];
+        [ra activateWithOptions:NSApplicationActivateAllWindows];
+        usleep (400 * 1000);
+
+        /* 2. Expand the panel if it is in its collapsed style (the browser /
+         *    Go-to-Folder affordance needs the expanded layout). */
+        AXUIElementRef disclosure =
+            ax_find_by_identifier (panel, @"NS_OPEN_SAVE_DISCLOSURE_TRIANGLE", 8);
+        if (disclosure != NULL)
+        {
+            if ([ax_string (disclosure, kAXValueAttribute) isEqualToString:@"0"])
+            {
+                AXUIElementPerformAction (disclosure, kAXPressAction);
+                usleep (700 * 1000);
+            }
+            CFRelease (disclosure);
+        }
+
+        /* 3. Open "Go to Folder" (⌘⇧G) unless it is already open. */
+        AXUIElementRef existing = ax_find_by_identifier (panel, @"GoToWindow", 6);
+        if (existing != NULL)
+        {
+            CFRelease (existing);
+        }
+        else
+        {
+            post_cmd_shift_g ();
+            usleep (800 * 1000);
+        }
+
+        /* 4. Find the Go-to-Folder path field. */
+        AXUIElementRef goto_sheet = ax_find_by_identifier (panel, @"GoToWindow", 6);
+        AXUIElementRef scan_root = goto_sheet != NULL ? goto_sheet : panel;
+        AXUIElementRef field = ax_find_by_identifier (scan_root, @"PathTextField", 10);
+
+        if (field == NULL)
+        {
+            if (goto_sheet != NULL)
+            {
+                CFRelease (goto_sheet);
+            }
+            CFRelease (panel);
+            g_set_error_literal (error, G_IO_ERROR, G_IO_ERROR_NOT_FOUND,
+                                 "Could not open the panel's \"Go to Folder\" field.");
+            return FALSE;
+        }
+
+        /* 5. Type the path. (The field is first responder the instant the
+         *    sheet opens; do NOT re-focus, which resets the field editor and
+         *    drops the keystrokes.) */
+        post_unicode_string (path);
+        usleep (400 * 1000);
+
+        /* 6. GUARD: only commit if focus is truly on the Go-to-Folder field,
+         *    so Return can never hit the panel's default Save/Open button. */
+        AXUIElementRef app_el = AXUIElementCreateApplication ((pid_t) target_pid);
+        AXUIElementRef focused = NULL;
+        AXUIElementCopyAttributeValue (app_el, kAXFocusedUIElementAttribute,
+                                       (CFTypeRef *) &focused);
+        NSString *focused_id = focused != NULL ?
+            ax_string (focused, kAXIdentifierAttribute) : nil;
+        CFRelease (app_el);
+        if (focused != NULL)
+        {
+            CFRelease (focused);
+        }
+        if (![focused_id isEqualToString:@"PathTextField"])
+        {
+            CFRelease (field);
+            if (goto_sheet != NULL)
+            {
+                CFRelease (goto_sheet);
+            }
+            CFRelease (panel);
+            g_set_error (error, G_IO_ERROR, G_IO_ERROR_FAILED,
+                         "Aborted before committing: focus was on \"%s\", "
+                         "not the Go-to-Folder field.",
+                         focused_id.UTF8String ?: "(none)");
+            return FALSE;
+        }
+
+        /* 7. Commit with Return. */
+        post_key (kVK_Return, true, 0);
+        post_key (kVK_Return, false, 0);
+        usleep (1000 * 1000);
+
+        if (out_evidence != NULL)
+        {
+            *out_evidence = panel_location_evidence (panel);
+        }
+
+        CFRelease (field);
+        if (goto_sheet != NULL)
+        {
+            CFRelease (goto_sheet);
+        }
+        CFRelease (panel);
+        return TRUE;
+    }
+}
+
+/* --- Folder chooser + full trigger (GTK) ---------------------------------- */
+
+typedef struct
+{
+    pid_t target_pid;
+} HandoffTrigger;
+
+static void
+handoff_chooser_done (GObject      *source,
+                      GAsyncResult *result,
+                      gpointer      user_data)
+{
+    GtkFileDialog *dialog = GTK_FILE_DIALOG (source);
+    HandoffTrigger *trigger = user_data;
+    g_autoptr (GError) error = NULL;
+    g_autoptr (GFile) folder = gtk_file_dialog_select_folder_finish (dialog, result, &error);
+
+    if (folder == NULL)
+    {
+        /* Cancelled or failed — do nothing further (no panel mutation). */
+        g_free (trigger);
+        return;
+    }
+
+    g_autofree char *path = g_file_get_path (folder);
+    g_autofree char *evidence = NULL;
+    g_autoptr (GError) drive_error = NULL;
+
+    if (path != NULL
+        && nautilus_macos_savepanel_drive (trigger->target_pid, path, &evidence, &drive_error))
+    {
+        g_message ("savepanel-handoff: navigated pid %d to \"%s\" (%s)",
+                   trigger->target_pid, path, evidence);
+    }
+    else
+    {
+        g_warning ("savepanel-handoff: drive failed: %s",
+                   drive_error != NULL ? drive_error->message : "unknown error");
+    }
+    g_free (trigger);
+}
+
+/* Fired on the main thread when the hotkey is pressed (and armed). */
+static void
+handoff_trigger (void)
+{
+    int pid = nautilus_macos_savepanel_find_frontmost_panel_pid ();
+
+    if (pid == 0)
+    {
+        g_message ("savepanel-handoff: hotkey pressed but no Open/Save panel "
+                   "is frontmost in another app — ignoring.");
+        return;
+    }
+
+    /* PROTOTYPE chooser: GTK's own directory chooser. The intended real UX is
+     * a full Nautilus browsing window whose "Choose" action returns the
+     * displayed folder; a GtkFileDialog is the least-fragile stand-in that
+     * still returns a POSIX path and lets us prove the handoff mechanism. */
+    HandoffTrigger *trigger = g_new0 (HandoffTrigger, 1);
+    trigger->target_pid = (pid_t) pid;
+
+    GtkFileDialog *dialog = gtk_file_dialog_new ();
+    gtk_file_dialog_set_title (dialog, _("Choose a Destination for the Save Panel"));
+    gtk_file_dialog_set_modal (dialog, FALSE);
+    gtk_file_dialog_select_folder (dialog, NULL, NULL, handoff_chooser_done, trigger);
+    g_object_unref (dialog);
+}
+
+/* --- Carbon global hotkey -------------------------------------------------- */
+
+static EventHotKeyRef handoff_hotkey_ref = NULL;
+static EventHandlerRef handoff_hotkey_handler = NULL;
+
+static OSStatus
+handoff_hotkey_callback (EventHandlerCallRef next,
+                         EventRef            event,
+                         void               *user_data)
+{
+    (void) next;
+    (void) user_data;
+    EventHotKeyID hotkey_id;
+
+    if (GetEventParameter (event, kEventParamDirectObject, typeEventHotKeyID, NULL,
+                           sizeof (hotkey_id), NULL, &hotkey_id) == noErr
+        && hotkey_id.id == HANDOFF_HOTKEY_ID)
+    {
+        /* The Carbon handler runs on the main run loop (GTK's macOS backend
+         * pumps the CFRunLoop). Run the trigger there directly. */
+        @autoreleasepool
+        {
+            handoff_trigger ();
+        }
+    }
+    return noErr;
+}
+
+static gboolean handoff_armed = FALSE;
+
+static void
+handoff_arm (void)
+{
+    if (handoff_armed)
+    {
+        return;
+    }
+    EventTypeSpec type = { kEventClassKeyboard, kEventHotKeyPressed };
+    EventHotKeyID hotkey_id = { HANDOFF_HOTKEY_SIGNATURE, HANDOFF_HOTKEY_ID };
+
+    if (handoff_hotkey_handler == NULL)
+    {
+        InstallApplicationEventHandler (&handoff_hotkey_callback, 1, &type, NULL,
+                                        &handoff_hotkey_handler);
+    }
+    OSStatus status = RegisterEventHotKey (HANDOFF_HOTKEY_KEYCODE, HANDOFF_HOTKEY_MODIFIERS,
+                                           hotkey_id, GetApplicationEventTarget (),
+                                           0, &handoff_hotkey_ref);
+    if (status != noErr)
+    {
+        g_warning ("savepanel-handoff: RegisterEventHotKey failed (status %d); "
+                   "hotkey not armed.", (int) status);
+        handoff_hotkey_ref = NULL;
+        return;
+    }
+    handoff_armed = TRUE;
+    g_message ("savepanel-handoff: armed (⌃⌥⌘G). Accessibility granted: %s",
+               AXIsProcessTrusted () ? "yes" : "NO — hotkey will no-op until granted");
+}
+
+static void
+handoff_disarm (void)
+{
+    if (!handoff_armed)
+    {
+        return;
+    }
+    if (handoff_hotkey_ref != NULL)
+    {
+        UnregisterEventHotKey (handoff_hotkey_ref);
+        handoff_hotkey_ref = NULL;
+    }
+    handoff_armed = FALSE;
+    g_message ("savepanel-handoff: disarmed.");
+}
+
+void
+nautilus_macos_savepanel_handoff_set_enabled (gboolean enabled)
+{
+    handoff_state_set_enabled (enabled);
+    if (enabled)
+    {
+        handoff_arm ();
+    }
+    else
+    {
+        handoff_disarm ();
+    }
+}
+
+void
+nautilus_macos_savepanel_handoff_init (void)
+{
+    if (nautilus_macos_savepanel_handoff_get_enabled ())
+    {
+        handoff_arm ();
+    }
+}
diff --git a/src/nautilus-macos-spotlight.m b/src/nautilus-macos-spotlight.m
new file mode 100644
index 0000000..0d65766
--- /dev/null
+++ b/src/nautilus-macos-spotlight.m
@@ -0,0 +1,435 @@
+/*
+ * nautilus-macos-spotlight.m: Spotlight (NSMetadataQuery) search (W4).
+ *
+ * Copyright (C) 2026 The Nautilus authors
+ *
+ * This program is free software; you can redistribute it and/or
+ * modify it under the terms of the GNU General Public License as
+ * published by the Free Software Foundation; either version 2 of the
+ * License, or (at your option) any later version.
+ *
+ * This program is distributed in the hope that it will be useful,
+ * but WITHOUT ANY WARRANTY; without even the implied warranty of
+ * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU
+ * General Public License for more details.
+ *
+ * You should have received a copy of the GNU General Public
+ * License along with this program; if not, see <http://www.gnu.org/licenses/>.
+ *
+ * Backend for nautilus-search-engine-spotlight.c: runs an NSMetadataQuery
+ * scoped to the searched directory and streams hits back to the GLib main
+ * loop.
+ *
+ * Threading model: the NSMetadataQuery is given a private serial
+ * NSOperationQueue (query.operationQueue), so gathering notifications are
+ * delivered on that queue instead of requiring the main CFRunLoop — this
+ * works both inside the GTK app (where GDK integrates the run loops) and
+ * in plain-GMainLoop test harnesses. Each notification handler collects
+ * the new slice of results and marshals it to the GLib main loop with
+ * g_idle_add_full(); all user callbacks therefore fire on the GLib main
+ * thread, matching the seam contract in nautilus-macos-bridge.h.
+ */
+
+#define G_LOG_DOMAIN "nautilus-macos-bridge"
+
+#include <config.h>
+#include "nautilus-macos-bridge.h"
+
+#import <Foundation/Foundation.h>
+
+/* One result, copied out of NSMetadataItem on the operation queue. */
+typedef struct
+{
+    char *path;
+    gint64 mtime;
+    gint64 atime;
+    gint64 ctime;
+} SpotlightHit;
+
+/* One streamed batch, marshalled from the operation queue to the GLib
+ * main loop. Holds a reference on the query handle. */
+typedef struct
+{
+    NautilusMacosSpotlightQuery *query;
+    GPtrArray *hits;     /* SpotlightHit*, may be NULL for a pure "finished" batch */
+    gboolean gathering_done;
+} SpotlightBatch;
+
+struct _NautilusMacosSpotlightQuery
+{
+    gatomicrefcount ref_count;
+
+    /* Objective-C state; created in start, torn down in stop (main thread). */
+    NSMetadataQuery *metadata_query;
+    NSOperationQueue *operation_queue;
+    id progress_observer;
+    id finished_observer;
+
+    NautilusMacosSpotlightHitFunc hit_func;
+    NautilusMacosSpotlightFinishedFunc finished_func;
+    gpointer user_data;
+
+    /* Cursor into metadata_query.results; only touched on the (serial)
+     * operation queue. */
+    NSUInteger next_result_index;
+
+    /* Set on the main thread when stop begins; read on the operation
+     * queue so in-flight result-copy loops bail out quickly instead of
+     * stalling stop's queue drain. */
+    gint cancelled;
+
+    /* Only touched on the GLib main thread. */
+    gboolean stopping;
+    gboolean finished_delivered;
+};
+
+static void
+spotlight_hit_free (gpointer data)
+{
+    SpotlightHit *hit = data;
+
+    g_free (hit->path);
+    g_free (hit);
+}
+
+static NautilusMacosSpotlightQuery *
+spotlight_query_ref (NautilusMacosSpotlightQuery *query)
+{
+    g_atomic_ref_count_inc (&query->ref_count);
+    return query;
+}
+
+static void
+spotlight_query_unref (NautilusMacosSpotlightQuery *query)
+{
+    if (g_atomic_ref_count_dec (&query->ref_count))
+    {
+        /* All Objective-C state was already released in stop. */
+        g_free (query);
+    }
+}
+
+static void
+spotlight_batch_free (gpointer data)
+{
+    SpotlightBatch *batch = data;
+
+    g_clear_pointer (&batch->hits, g_ptr_array_unref);
+    spotlight_query_unref (batch->query);
+    g_free (batch);
+}
+
+/* GLib main thread. */
+static gboolean
+deliver_batch_in_idle (gpointer data)
+{
+    SpotlightBatch *batch = data;
+    NautilusMacosSpotlightQuery *query = batch->query;
+
+    if (batch->hits != NULL)
+    {
+        for (guint i = 0; i < batch->hits->len; i++)
+        {
+            SpotlightHit *hit = g_ptr_array_index (batch->hits, i);
+
+            /* A hit callback may stop the query (directly or indirectly);
+             * re-check before every delivery. */
+            if (query->stopping)
+            {
+                break;
+            }
+
+            query->hit_func (hit->path, hit->mtime, hit->atime, hit->ctime,
+                             query->user_data);
+        }
+    }
+
+    if (batch->gathering_done &&
+        !query->stopping &&
+        !query->finished_delivered)
+    {
+        query->finished_delivered = TRUE;
+        query->finished_func (NULL, query->user_data);
+    }
+
+    return G_SOURCE_REMOVE;
+}
+
+static gint64
+date_to_unix (NSDate *date)
+{
+    return (date != nil) ? (gint64) date.timeIntervalSince1970 : 0;
+}
+
+/* Runs on the serial operation queue. Collects results the cursor has not
+ * seen yet and schedules delivery on the GLib main loop. */
+static void
+collect_new_results (NautilusMacosSpotlightQuery *query,
+                     gboolean                     gathering_done)
+{
+    NSMetadataQuery *mdq = query->metadata_query;
+    GPtrArray *hits = NULL;
+
+    if (g_atomic_int_get (&query->cancelled))
+    {
+        return;
+    }
+
+    [mdq disableUpdates];
+
+    NSUInteger count = mdq.resultCount;
+
+    if (count > query->next_result_index)
+    {
+        hits = g_ptr_array_new_with_free_func (spotlight_hit_free);
+
+        for (NSUInteger i = query->next_result_index; i < count; i++)
+        {
+            /* Result sets can be huge; abort promptly once stop begins so
+             * its waitUntilAllOperationsAreFinished doesn't stall. */
+            if (g_atomic_int_get (&query->cancelled))
+            {
+                [mdq enableUpdates];
+                g_ptr_array_unref (hits);
+                return;
+            }
+
+            NSMetadataItem *item = [mdq resultAtIndex:i];
+            NSString *path = [item valueForAttribute:NSMetadataItemPathKey];
+
+            if (path == nil)
+            {
+                continue;
+            }
+
+            SpotlightHit *hit = g_new0 (SpotlightHit, 1);
+
+            hit->path = g_strdup (path.fileSystemRepresentation);
+            hit->mtime = date_to_unix ([item valueForAttribute:NSMetadataItemFSContentChangeDateKey]);
+            hit->atime = date_to_unix ([item valueForAttribute:NSMetadataItemLastUsedDateKey]);
+            hit->ctime = date_to_unix ([item valueForAttribute:NSMetadataItemFSCreationDateKey]);
+
+            g_ptr_array_add (hits, hit);
+        }
+
+        query->next_result_index = count;
+    }
+
+    [mdq enableUpdates];
+
+    if (hits == NULL && !gathering_done)
+    {
+        return;
+    }
+
+    SpotlightBatch *batch = g_new0 (SpotlightBatch, 1);
+
+    batch->query = spotlight_query_ref (query);
+    batch->hits = hits;
+    batch->gathering_done = gathering_done;
+
+    g_idle_add_full (G_PRIORITY_DEFAULT_IDLE,
+                     deliver_batch_in_idle, batch, spotlight_batch_free);
+}
+
+/* Builds the filename-match predicate: every whitespace-separated word of
+ * @query_text must appear in the file name (case- and diacritic-
+ * insensitively), mirroring nautilus_query_matches_string() semantics.
+ *
+ * v1 deliberately matches file names only, like Nautilus's simple engine;
+ * full-text results here would surprise. A content-search variant, should
+ * an explicit FTS mode be wanted later, would OR in kMDItemTextContent:
+ *
+ *   [NSPredicate predicateWithFormat:
+ *       @"(kMDItemFSName CONTAINS[cd] %@) OR "
+ *       @"(kMDItemDisplayName CONTAINS[cd] %@) OR "
+ *       @"(kMDItemTextContent CONTAINS[cd] %@)", word, word, word]
+ *
+ * (NautilusQuery does carry a search_content flag, but it defaults to TRUE
+ * via the fts-enabled preference rather than expressing explicit intent,
+ * so it is not used as the trigger here.)
+ */
+static NSPredicate *
+build_filename_predicate (NSString *text)
+{
+    NSArray<NSString *> *words =
+        [text componentsSeparatedByCharactersInSet:
+         [NSCharacterSet whitespaceAndNewlineCharacterSet]];
+    NSMutableArray<NSPredicate *> *subpredicates =
+        [NSMutableArray arrayWithCapacity:words.count];
+
+    for (NSString *word in words)
+    {
+        if (word.length == 0)
+        {
+            continue;
+        }
+
+        [subpredicates addObject:
+         [NSPredicate predicateWithFormat:
+          @"(kMDItemFSName CONTAINS[cd] %@) OR (kMDItemDisplayName CONTAINS[cd] %@)",
+          word, word]];
+    }
+
+    if (subpredicates.count == 0)
+    {
+        return nil;
+    }
+
+    /* NSMetadataQuery rejects AND-compounds with a single subpredicate
+     * ("wrong number (1) of subpredicates"). */
+    if (subpredicates.count == 1)
+    {
+        return subpredicates.firstObject;
+    }
+
+    return [NSCompoundPredicate andPredicateWithSubpredicates:subpredicates];
+}
+
+NautilusMacosSpotlightQuery *
+nautilus_macos_spotlight_query_start (const char                         *query_text,
+                                      const char                         *scope_path,
+                                      NautilusMacosSpotlightHitFunc       hit_func,
+                                      NautilusMacosSpotlightFinishedFunc  finished_func,
+                                      gpointer                            user_data)
+{
+    g_return_val_if_fail (query_text != NULL, NULL);
+    g_return_val_if_fail (scope_path != NULL, NULL);
+    g_return_val_if_fail (hit_func != NULL, NULL);
+    g_return_val_if_fail (finished_func != NULL, NULL);
+
+    @autoreleasepool
+    {
+        NSString *text = [NSString stringWithUTF8String:query_text];
+        NSString *scope = [NSString stringWithUTF8String:scope_path];
+
+        if (text == nil || scope == nil)
+        {
+            g_debug ("spotlight: query text or scope is not valid UTF-8");
+            return NULL;
+        }
+
+        NSPredicate *predicate = build_filename_predicate (text);
+
+        if (predicate == nil)
+        {
+            g_debug ("spotlight: no searchable words in '%s'", query_text);
+            return NULL;
+        }
+
+        NautilusMacosSpotlightQuery *query = g_new0 (NautilusMacosSpotlightQuery, 1);
+
+        g_atomic_ref_count_init (&query->ref_count);
+        query->hit_func = hit_func;
+        query->finished_func = finished_func;
+        query->user_data = user_data;
+
+        query->metadata_query = [[NSMetadataQuery alloc] init];
+        query->metadata_query.predicate = predicate;
+        query->metadata_query.searchScopes =
+            @[[NSURL fileURLWithPath:scope isDirectory:YES]];
+        /* Stream gathering progress frequently instead of the 1s default. */
+        query->metadata_query.notificationBatchingInterval = 0.1;
+
+        query->operation_queue = [[NSOperationQueue alloc] init];
+        query->operation_queue.maxConcurrentOperationCount = 1;
+        query->operation_queue.name = @"org.gnome.Nautilus.spotlight";
+        query->metadata_query.operationQueue = query->operation_queue;
+
+        /* With query.operationQueue set, notifications are posted as
+         * operations on that queue; observers with queue:nil then run
+         * synchronously there. */
+        NSNotificationCenter *center = [NSNotificationCenter defaultCenter];
+
+        query->progress_observer =
+            [[center addObserverForName:NSMetadataQueryGatheringProgressNotification
+                                 object:query->metadata_query
+                                  queue:nil
+                             usingBlock:^(NSNotification *notification) {
+                collect_new_results (query, FALSE);
+            }] retain];
+        query->finished_observer =
+            [[center addObserverForName:NSMetadataQueryDidFinishGatheringNotification
+                                 object:query->metadata_query
+                                  queue:nil
+                             usingBlock:^(NSNotification *notification) {
+                collect_new_results (query, TRUE);
+            }] retain];
+
+        if (![query->metadata_query startQuery])
+        {
+            g_debug ("spotlight: NSMetadataQuery failed to start for '%s' in %s",
+                     query_text, scope_path);
+
+            [center removeObserver:query->progress_observer];
+            [query->progress_observer release];
+            [center removeObserver:query->finished_observer];
+            [query->finished_observer release];
+            [query->metadata_query release];
+            [query->operation_queue release];
+            g_free (query);
+
+            return NULL;
+        }
+
+        g_debug ("spotlight: query started for '%s' in %s", query_text, scope_path);
+
+        return query;
+    }
+}
+
+void
+nautilus_macos_spotlight_query_stop (NautilusMacosSpotlightQuery *query)
+{
+    if (query == NULL)
+    {
+        return;
+    }
+
+    /* Re-entrant guard: the finished callback below may call back into
+     * stop; the outer call owns the teardown. */
+    if (query->stopping)
+    {
+        return;
+    }
+    query->stopping = TRUE;
+    g_atomic_int_set (&query->cancelled, 1);
+
+    @autoreleasepool
+    {
+        NSNotificationCenter *center = [NSNotificationCenter defaultCenter];
+
+        [center removeObserver:query->progress_observer];
+        [query->progress_observer release];
+        query->progress_observer = nil;
+
+        [center removeObserver:query->finished_observer];
+        [query->finished_observer release];
+        query->finished_observer = nil;
+
+        /* Drain any in-flight notification handler so nothing touches the
+         * NSMetadataQuery after it is released. Handlers are quick (they
+         * only copy result attributes) and never block on the main thread,
+         * so this cannot deadlock. */
+        [query->operation_queue waitUntilAllOperationsAreFinished];
+
+        [query->metadata_query stopQuery];
+        [query->metadata_query release];
+        query->metadata_query = nil;
+
+        [query->operation_queue release];
+        query->operation_queue = nil;
+    }
+
+    /* Contract: the finished callback fires exactly once, before or during
+     * stop. Pending idle batches will see ->stopping and deliver nothing. */
+    if (!query->finished_delivered)
+    {
+        query->finished_delivered = TRUE;
+        query->finished_func (NULL, query->user_data);
+    }
+
+    g_debug ("spotlight: query stopped");
+
+    spotlight_query_unref (query);
+}
diff --git a/src/nautilus-macos-terminal.m b/src/nautilus-macos-terminal.m
new file mode 100644
index 0000000..297affa
--- /dev/null
+++ b/src/nautilus-macos-terminal.m
@@ -0,0 +1,74 @@
+/*
+ * nautilus-macos-terminal.m: "Open in Terminal" via NSWorkspace (W11).
+ *
+ * Copyright (C) 2026 The Nautilus authors
+ *
+ * This program is free software; you can redistribute it and/or
+ * modify it under the terms of the GNU General Public License as
+ * published by the Free Software Foundation; either version 2 of the
+ * License, or (at your option) any later version.
+ *
+ * This program is distributed in the hope that it will be useful,
+ * but WITHOUT ANY WARRANTY; without even the implied warranty of
+ * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU
+ * General Public License for more details.
+ *
+ * You should have received a copy of the GNU General Public
+ * License along with this program; if not, see <http://www.gnu.org/licenses/>.
+ *
+ * The darwin counterpart of GNOME's "Open in Console": handing Terminal.app
+ * a directory URL through LaunchServices opens a new window cd'd there.
+ */
+
+#define G_LOG_DOMAIN "nautilus-macos-bridge"
+
+#include <config.h>
+#include "nautilus-macos-bridge.h"
+
+#import <AppKit/AppKit.h>
+
+gboolean
+nautilus_macos_open_in_terminal (const char *path)
+{
+    g_return_val_if_fail (path != NULL, FALSE);
+
+    @autoreleasepool
+    {
+        NSURL *directory_url = [NSURL fileURLWithPath:@(path) isDirectory:YES];
+        NSURL *terminal_url =
+            [[NSWorkspace sharedWorkspace]
+             URLForApplicationWithBundleIdentifier:@"com.apple.Terminal"];
+
+        if (terminal_url == nil)
+        {
+            g_warning ("nautilus_macos_open_in_terminal: Terminal.app not found");
+            return FALSE;
+        }
+
+        NSWorkspaceOpenConfiguration *configuration =
+            [NSWorkspaceOpenConfiguration configuration];
+        configuration.activates = YES;
+
+        /* The completion handler outlives this call; capture an NSString
+         * copy, not the caller-owned C string. */
+        NSString *path_str = @(path);
+
+        [[NSWorkspace sharedWorkspace]
+                    openURLs:@[directory_url]
+         withApplicationAtURL:terminal_url
+               configuration:configuration
+           completionHandler:^(NSRunningApplication *app, NSError *error)
+        {
+            if (error != nil)
+            {
+                g_warning ("Opening %s in Terminal failed: %s",
+                           [path_str UTF8String],
+                           [[error localizedDescription] UTF8String]);
+            }
+        }];
+
+        g_debug ("nautilus_macos_open_in_terminal: dispatched for %s", path);
+
+        return TRUE;
+    }
+}
diff --git a/src/nautilus-macos-thumbnailer.m b/src/nautilus-macos-thumbnailer.m
new file mode 100644
index 0000000..faf3a57
--- /dev/null
+++ b/src/nautilus-macos-thumbnailer.m
@@ -0,0 +1,480 @@
+/*
+ * nautilus-macos-thumbnailer.m: QuickLook thumbnail generation (W3).
+ *
+ * Copyright (C) 2026 The Nautilus authors
+ *
+ * This program is free software; you can redistribute it and/or
+ * modify it under the terms of the GNU General Public License as
+ * published by the Free Software Foundation; either version 2 of the
+ * License, or (at your option) any later version.
+ *
+ * This program is distributed in the hope that it will be useful,
+ * but WITHOUT ANY WARRANTY; without even the implied warranty of
+ * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU
+ * General Public License for more details.
+ *
+ * You should have received a copy of the GNU General Public
+ * License along with this program; if not, see <http://www.gnu.org/licenses/>.
+ *
+ * Backend for the seam in nautilus-thumbnails-macos.c
+ * (backend_can_thumbnail / backend_generate_async).
+ *
+ * Generation uses QLThumbnailGenerator (QuickLookThumbnailing framework),
+ * which asks the same system thumbnail agent Finder uses, so PDF, movie and
+ * office-document thumbnails come from the OS. The resulting CGImage is
+ * converted to a GdkPixbuf by rendering into a CGBitmapContext with a known
+ * RGBA8888 layout (see pixbuf_from_cgimage() for why this was chosen over a
+ * PNG round-trip) and delivered from a GLib main-loop idle.
+ *
+ * Sizing: the @size parameter is in *pixels* (the freedesktop thumbnail
+ * cache is specified in pixels; the caller passes
+ * nautilus_thumbnail_get_max_size(), which already accounts for the largest
+ * monitor scale — 512 on a Retina display). We therefore request
+ * size:{size,size} at scale:1.0, which yields a bitmap of at most
+ * size x size device pixels. GTK scales the resulting texture for display,
+ * so no extra scale factor may be applied here (scale:2.0 would produce
+ * 2*size-pixel images, overflowing the pixel-based cache-size contract).
+ *
+ * Representation type: QLThumbnailGenerationRequestRepresentationTypeThumbnail
+ * only. Rationale: the seam contract is "callback fires exactly once", and
+ * the result is written through to the on-disk thumbnail cache. Using .all
+ * (best-delivered semantics) would deliver a low-quality interim
+ * representation (or a generic file icon) first; either we'd deliver twice,
+ * or we'd risk caching a non-thumbnail. With .thumbnail only, QuickLook
+ * fails cleanly when it cannot produce a real thumbnail, which is exactly
+ * what the fail-marker bookkeeping in nautilus-thumbnails-macos.c wants.
+ *
+ * Threading: all entry points must be called on the GLib main thread (the
+ * only caller is nautilus-thumbnails-macos.c, which runs on the main loop).
+ * QuickLook completion handlers run on a private queue; the CGImage ->
+ * GdkPixbuf conversion happens there (keeping pixel work off the GTK
+ * thread), and the result is marshalled back with g_idle_add().
+ */
+
+#define G_LOG_DOMAIN "nautilus-macos-bridge"
+
+#include <config.h>
+#include "nautilus-macos-bridge.h"
+
+#import <CoreGraphics/CoreGraphics.h>
+#import <Foundation/Foundation.h>
+#import <QuickLookThumbnailing/QuickLookThumbnailing.h>
+#import <UniformTypeIdentifiers/UniformTypeIdentifiers.h>
+
+/* Cap on concurrent QLThumbnailGenerator requests. The generator is
+ * internally concurrent (it proxies to the system thumbnail agent over
+ * XPC), but an unbounded burst — opening a folder with hundreds of images —
+ * floods the agent and the main loop. PLAN Phase 4.4 asks for a bound of
+ * roughly 4-8; 6 keeps the agent busy without visible main-loop pressure.
+ *
+ * Phase 4 seam: viewport prioritization belongs here. The FIFO below is the
+ * single choke point — replace it with a priority queue (or add a
+ * reprioritize/cancel entry point) to serve visible files first. */
+#define MAX_IN_FLIGHT_REQUESTS 6
+
+typedef struct
+{
+    char *path;
+    int size;
+    NautilusMacosThumbnailCallback callback;
+    gpointer user_data;
+} ThumbnailRequest;
+
+typedef struct
+{
+    ThumbnailRequest *request;
+    GdkPixbuf *pixbuf;
+    GError *error;
+} ThumbnailResult;
+
+/* Main-thread-only state (no locking: producers and the idle consumer all
+ * run on the GLib main thread). */
+static GQueue waiting_requests = G_QUEUE_INIT;   /* ThumbnailRequest* FIFO */
+static guint in_flight_count = 0;
+static guint peak_in_flight_count = 0;
+
+static void pump_request_queue (void);
+
+static void
+thumbnail_request_free (ThumbnailRequest *request)
+{
+    g_free (request->path);
+    g_free (request);
+}
+
+/*
+ * CGImage -> GdkPixbuf.
+ *
+ * Approach: draw the CGImage into a CGBitmapContext we control, with an
+ * explicit RGBA8888 (alpha-last, 32-bit big-endian) layout, then hand the
+ * buffer to gdk_pixbuf_new_from_data() with a destroy notify (no extra
+ * copy — the buffer was allocated for the pixbuf).
+ *
+ * Chosen over the CGImageDestination-PNG + gdk_pixbuf_new_from_stream
+ * round-trip because that costs a full PNG encode *and* decode per
+ * thumbnail before the cache write re-encodes it again, and because the
+ * bitmap-context path gives us an exactly known pixel layout instead of
+ * whatever bit depth/premultiplication the source image happens to have.
+ *
+ * CGBitmapContext only supports premultiplied alpha for drawing, while
+ * GdkPixbuf (and the PNG cache format) require straight alpha, so we
+ * un-premultiply in place. Runs on QuickLook's completion queue, not the
+ * GTK main thread.
+ */
+static void
+pixbuf_pixels_destroy_notify (guchar *pixels,
+                              gpointer data)
+{
+    g_free (pixels);
+}
+
+static GdkPixbuf *
+pixbuf_from_cgimage (CGImageRef image,
+                     GError **error)
+{
+    size_t width = CGImageGetWidth (image);
+    size_t height = CGImageGetHeight (image);
+
+    if (width == 0 || height == 0)
+    {
+        g_set_error (error, G_IO_ERROR, G_IO_ERROR_FAILED,
+                     "QuickLook returned an empty image");
+        return NULL;
+    }
+
+    size_t rowstride = width * 4;
+    guchar *pixels = g_malloc0 (rowstride * height);
+    CGColorSpaceRef color_space = CGColorSpaceCreateWithName (kCGColorSpaceSRGB);
+    CGContextRef context = CGBitmapContextCreate (pixels, width, height, 8, rowstride,
+                                                  color_space,
+                                                  kCGImageAlphaPremultipliedLast |
+                                                  kCGBitmapByteOrder32Big);
+
+    CGColorSpaceRelease (color_space);
+
+    if (context == NULL)
+    {
+        g_free (pixels);
+        g_set_error (error, G_IO_ERROR, G_IO_ERROR_FAILED,
+                     "Could not create a %zux%zu RGBA bitmap context", width, height);
+        return NULL;
+    }
+
+    CGContextDrawImage (context, CGRectMake (0, 0, width, height), image);
+    CGContextRelease (context);
+
+    /* Un-premultiply the alpha channel. */
+    for (size_t y = 0; y < height; y++)
+    {
+        guchar *row = pixels + y * rowstride;
+
+        for (size_t x = 0; x < width; x++)
+        {
+            guchar *px = row + x * 4;
+            guint alpha = px[3];
+
+            if (alpha != 0 && alpha != 255)
+            {
+                px[0] = (guchar) MIN ((px[0] * 255 + alpha / 2) / alpha, 255);
+                px[1] = (guchar) MIN ((px[1] * 255 + alpha / 2) / alpha, 255);
+                px[2] = (guchar) MIN ((px[2] * 255 + alpha / 2) / alpha, 255);
+            }
+        }
+    }
+
+    return gdk_pixbuf_new_from_data (pixels, GDK_COLORSPACE_RGB,
+                                     TRUE /* has_alpha */, 8,
+                                     (int) width, (int) height, (int) rowstride,
+                                     pixbuf_pixels_destroy_notify, NULL);
+}
+
+/*
+ * Type acceptance.
+ *
+ * QLThumbnailGenerator has no public per-type capability query, so we take
+ * the pragmatic route: accept the broad type families QuickLook reliably
+ * thumbnails out of the box (images, movies/audio, PDF, RTF, office
+ * documents). For anything we let through that QuickLook then rejects, the
+ * generation error is reported once and nautilus-thumbnails-macos.c writes
+ * a freedesktop fail marker, so the file is not retried until it changes.
+ */
+static const char *const accepted_type_identifiers[] =
+{
+    "public.image",                                    /* JPEG/PNG/HEIC/RAW/SVG/... */
+    "public.audiovisual-content",                      /* movies (frame grab), audio (artwork) */
+    "com.adobe.pdf",
+    "public.rtf",
+    "com.microsoft.word.doc",
+    "com.microsoft.excel.xls",
+    "com.microsoft.powerpoint.ppt",
+    "org.openxmlformats.wordprocessingml.document",    /* .docx */
+    "org.openxmlformats.spreadsheetml.sheet",          /* .xlsx */
+    "org.openxmlformats.presentationml.presentation",  /* .pptx */
+    "org.oasis-open.opendocument.text",
+    "org.oasis-open.opendocument.spreadsheet",
+    "org.oasis-open.opendocument.presentation",
+    "com.apple.iwork.pages.sffpages",
+    "com.apple.iwork.numbers.sffnumbers",
+    "com.apple.iwork.keynote.sffkey",
+};
+
+/* Resolved once; can_thumbnail runs for every file in a directory listing. */
+static NSArray<UTType *> *
+get_accepted_types (void)
+{
+    static NSArray<UTType *> *accepted_types = nil;
+
+    if (accepted_types == nil)
+    {
+        NSMutableArray<UTType *> *types =
+            [NSMutableArray arrayWithCapacity:G_N_ELEMENTS (accepted_type_identifiers)];
+
+        for (gsize i = 0; i < G_N_ELEMENTS (accepted_type_identifiers); i++)
+        {
+            NSString *identifier = [NSString stringWithUTF8String:accepted_type_identifiers[i]];
+            UTType *type = [UTType typeWithIdentifier:identifier];
+
+            if (type != nil)
+            {
+                [types addObject:type];
+            }
+        }
+
+        accepted_types = [types copy];   /* retained singleton (MRR) */
+    }
+
+    return accepted_types;
+}
+
+/* @content_type is whatever GIO reported for the file. On macOS GIO's
+ * native content-type system *is* UTIs, so this is usually a UTI string
+ * ("public.jpeg", "com.adobe.pdf"); but Nautilus also has code paths that
+ * hardcode MIME strings ("application/octet-stream" fallbacks), so both
+ * forms are handled. Generic or dynamic types tell us nothing — fall back
+ * to the filename extension for those. */
+static UTType *
+uttype_for_file (const char *path,
+                 const char *content_type)
+{
+    UTType *type = nil;
+
+    if (content_type != NULL)
+    {
+        NSString *type_string = [NSString stringWithUTF8String:content_type];
+
+        if (type_string != nil)
+        {
+            if ([type_string containsString:@"/"])
+            {
+                type = [UTType typeWithMIMEType:type_string];
+            }
+            else
+            {
+                type = [UTType typeWithIdentifier:type_string];
+            }
+        }
+    }
+
+    if (type == nil || type.isDynamic ||
+        [type.identifier isEqualToString:@"public.data"] ||
+        [type.identifier isEqualToString:@"public.item"] ||
+        [type.identifier isEqualToString:@"public.content"])
+    {
+        NSString *path_string = [NSString stringWithUTF8String:path];
+        NSString *extension = path_string.pathExtension;
+
+        if (extension != nil && extension.length > 0)
+        {
+            UTType *extension_type = [UTType typeWithFilenameExtension:extension];
+
+            if (extension_type != nil)
+            {
+                type = extension_type;
+            }
+        }
+    }
+
+    return type;
+}
+
+gboolean
+nautilus_macos_thumbnail_can_thumbnail (const char *path,
+                                        const char *mime_type)
+{
+    g_return_val_if_fail (path != NULL, FALSE);
+
+    /* Never thumbnail directories, even ones named like "Photos.jpg".
+     * GIO reports "public.folder" on macOS; "inode/directory" covers
+     * Nautilus's hardcoded-MIME code paths. */
+    if (g_strcmp0 (mime_type, "inode/directory") == 0 ||
+        g_strcmp0 (mime_type, "public.folder") == 0)
+    {
+        return FALSE;
+    }
+
+    @autoreleasepool
+    {
+        UTType *type = uttype_for_file (path, mime_type);
+
+        if (type == nil)
+        {
+            return FALSE;
+        }
+
+        for (UTType *accepted in get_accepted_types ())
+        {
+            if ([type conformsToType:accepted])
+            {
+                return TRUE;
+            }
+        }
+    }
+
+    return FALSE;
+}
+
+/* Runs on the main loop: hand the finished thumbnail (or error) to the
+ * caller and start the next queued request. Per the bridge contract the
+ * pixbuf reference is transferred to the callback; the error stays ours. */
+static gboolean
+deliver_result_in_idle_cb (gpointer data)
+{
+    ThumbnailResult *result = data;
+    ThumbnailRequest *request = result->request;
+
+    in_flight_count -= 1;
+    pump_request_queue ();
+
+    request->callback (result->pixbuf, result->error, request->user_data);
+
+    g_clear_error (&result->error);
+    g_free (result);
+    thumbnail_request_free (request);
+
+    return G_SOURCE_REMOVE;
+}
+
+static void
+start_request (ThumbnailRequest *request)
+{
+    @autoreleasepool
+    {
+        NSString *path_string = [NSString stringWithUTF8String:request->path];
+
+        if (path_string == nil)
+        {
+            ThumbnailResult *result = g_new0 (ThumbnailResult, 1);
+
+            result->request = request;
+            g_set_error (&result->error, G_IO_ERROR, G_IO_ERROR_INVALID_FILENAME,
+                         "Path is not valid UTF-8: %s", request->path);
+            g_idle_add (deliver_result_in_idle_cb, result);
+
+            return;
+        }
+
+        NSURL *url = [NSURL fileURLWithPath:path_string isDirectory:NO];
+        QLThumbnailGenerationRequest *ql_request =
+            [[[QLThumbnailGenerationRequest alloc]
+                 initWithFileAtURL:url
+                              size:CGSizeMake (request->size, request->size)
+                             scale:1.0
+               representationTypes:QLThumbnailGenerationRequestRepresentationTypeThumbnail]
+             autorelease];
+
+        [[QLThumbnailGenerator sharedGenerator]
+            generateBestRepresentationForRequest:ql_request
+                               completionHandler:^(QLThumbnailRepresentation *representation,
+                                                   NSError *ns_error)
+        {
+            /* QuickLook's private queue: convert here, deliver via idle. */
+            @autoreleasepool
+            {
+                ThumbnailResult *result = g_new0 (ThumbnailResult, 1);
+
+                result->request = request;
+
+                if (representation != nil)
+                {
+                    result->pixbuf = pixbuf_from_cgimage (representation.CGImage,
+                                                          &result->error);
+                }
+                else
+                {
+                    const char *description = "unknown QuickLook error";
+
+                    if (ns_error != nil && ns_error.localizedDescription != nil)
+                    {
+                        description = ns_error.localizedDescription.UTF8String;
+                    }
+
+                    g_set_error (&result->error, G_IO_ERROR, G_IO_ERROR_FAILED,
+                                 "QuickLook could not thumbnail %s: %s",
+                                 request->path, description);
+                }
+
+                g_idle_add (deliver_result_in_idle_cb, result);
+            }
+        }];
+    }
+}
+
+static void
+pump_request_queue (void)
+{
+    while (in_flight_count < MAX_IN_FLIGHT_REQUESTS &&
+           !g_queue_is_empty (&waiting_requests))
+    {
+        ThumbnailRequest *request = g_queue_pop_head (&waiting_requests);
+
+        in_flight_count += 1;
+        peak_in_flight_count = MAX (peak_in_flight_count, in_flight_count);
+
+        start_request (request);
+    }
+}
+
+void
+nautilus_macos_thumbnail_generate_async (const char                     *path,
+                                         int                             size,
+                                         NautilusMacosThumbnailCallback  callback,
+                                         gpointer                        user_data)
+{
+    g_return_if_fail (path != NULL);
+    g_return_if_fail (size > 0);
+    g_return_if_fail (callback != NULL);
+
+    ThumbnailRequest *request = g_new0 (ThumbnailRequest, 1);
+
+    request->path = g_strdup (path);
+    request->size = size;
+    request->callback = callback;
+    request->user_data = user_data;
+
+    g_debug ("QuickLook thumbnail request: %s (size %d, in flight %u, queued %u)",
+             path, size, in_flight_count, g_queue_get_length (&waiting_requests));
+
+    g_queue_push_tail (&waiting_requests, request);
+    pump_request_queue ();
+}
+
+void
+nautilus_macos_thumbnail_debug_stats (guint *out_in_flight,
+                                      guint *out_queued,
+                                      guint *out_peak_in_flight)
+{
+    if (out_in_flight != NULL)
+    {
+        *out_in_flight = in_flight_count;
+    }
+
+    if (out_queued != NULL)
+    {
+        *out_queued = g_queue_get_length (&waiting_requests);
+    }
+
+    if (out_peak_in_flight != NULL)
+    {
+        *out_peak_in_flight = peak_in_flight_count;
+    }
+}
diff --git a/src/nautilus-macos-trash.m b/src/nautilus-macos-trash.m
new file mode 100644
index 0000000..fde4122
--- /dev/null
+++ b/src/nautilus-macos-trash.m
@@ -0,0 +1,93 @@
+/*
+ * nautilus-macos-trash.m: Finder Trash integration (W2).
+ *
+ * Copyright (C) 2026 The Nautilus authors
+ *
+ * This program is free software; you can redistribute it and/or
+ * modify it under the terms of the GNU General Public License as
+ * published by the Free Software Foundation; either version 2 of the
+ * License, or (at your option) any later version.
+ *
+ * This program is distributed in the hope that it will be useful,
+ * but WITHOUT ANY WARRANTY; without even the implied warranty of
+ * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU
+ * General Public License for more details.
+ *
+ * You should have received a copy of the GNU General Public
+ * License along with this program; if not, see <http://www.gnu.org/licenses/>.
+ *
+ * Trashing files works through GIO (g_file_trash). Browsing the trash does
+ * not (no gvfs trash:/// backend, and ~/.Trash is TCC-protected), so the
+ * v1 behavior is to hand off to Finder's Trash window from here.
+ */
+
+#define G_LOG_DOMAIN "nautilus-macos-bridge"
+
+#include <config.h>
+#include "nautilus-macos-bridge.h"
+
+#import <AppKit/AppKit.h>
+
+/* Ask Finder itself to open its Trash window. Requires the Automation
+ * (Apple Events) TCC permission the first time; returns FALSE if the user
+ * denied it or scripting fails. */
+static gboolean
+open_trash_via_applescript (void)
+{
+    @autoreleasepool
+    {
+        NSAppleScript *script =
+            [[[NSAppleScript alloc] initWithSource:
+              @"tell application \"Finder\"\n"
+               "    activate\n"
+               "    open trash\n"
+               "end tell"] autorelease];
+        NSDictionary *error_info = nil;
+
+        [script executeAndReturnError:&error_info];
+
+        if (error_info != nil)
+        {
+            g_warning ("Opening Finder Trash via AppleScript failed: %s",
+                       [[error_info description] UTF8String]);
+            return FALSE;
+        }
+
+        return TRUE;
+    }
+}
+
+gboolean
+nautilus_macos_trash_open_in_finder (void)
+{
+    @autoreleasepool
+    {
+        NSFileManager *fm = [NSFileManager defaultManager];
+        NSURL *trash_url = [fm URLForDirectory:NSTrashDirectory
+                                      inDomain:NSUserDomainMask
+                             appropriateForURL:nil
+                                        create:NO
+                                         error:nil];
+
+        if (trash_url == nil)
+        {
+            NSString *fallback = [NSHomeDirectory () stringByAppendingPathComponent:@".Trash"];
+            trash_url = [NSURL fileURLWithPath:fallback isDirectory:YES];
+        }
+
+        /* Handing the trash folder URL to LaunchServices opens Finder's
+         * Trash window (Finder recognizes ~/.Trash as the Trash). This
+         * needs no TCC permission, unlike scripting Finder directly. */
+        if ([[NSWorkspace sharedWorkspace] openURL:trash_url])
+        {
+            g_debug ("nautilus_macos_trash_open_in_finder: opened %s via NSWorkspace",
+                     [[trash_url path] UTF8String]);
+            return TRUE;
+        }
+
+        g_debug ("nautilus_macos_trash_open_in_finder: NSWorkspace refused, "
+                 "falling back to AppleScript");
+
+        return open_trash_via_applescript ();
+    }
+}
diff --git a/src/nautilus-macos-updater.m b/src/nautilus-macos-updater.m
new file mode 100644
index 0000000..b1e1e16
--- /dev/null
+++ b/src/nautilus-macos-updater.m
@@ -0,0 +1,1989 @@
+/*
+ * nautilus-macos-updater.m: GitHub-release self-updater (Shenzhen Files).
+ *
+ * Copyright (C) 2026 The Nautilus authors
+ *
+ * This program is free software; you can redistribute it and/or
+ * modify it under the terms of the GNU General Public License as
+ * published by the Free Software Foundation; either version 2 of the
+ * License, or (at your option) any later version.
+ *
+ * This program is distributed in the hope that it will be useful,
+ * but WITHOUT ANY WARRANTY; without even the implied warranty of
+ * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU
+ * General Public License for more details.
+ *
+ * You should have received a copy of the GNU General Public
+ * License along with this program; if not, see <http://www.gnu.org/licenses/>.
+ *
+ * Ported from shenzhen-pdf's SPDFUpdater.mm (portable/mac). Same design:
+ * silent daily check against the GitHub releases/latest API (flock'd 24h
+ * gate in ~/Library/Application Support/Shenzhen Files/update.json, hourly
+ * re-arm + day-change/wake catch-ups), a user-initiated "Check for
+ * Updates…" path that bypasses the gate, an Install/Skip/Later alert, a
+ * determinate download panel, DMG mount + ditto extract, and a detached
+ * post-update helper that swaps the bundle with a move-aside two-rename,
+ * re-registers LaunchServices and relaunches.
+ *
+ * DIVERGENCE from shenzhen-pdf (deliberate): Shenzhen Files is ad-hoc
+ * signed, so SPDF's offline Developer ID + notarization verification is
+ * unavailable. The trust boundary here is TLS to api.github.com /
+ * github.com plus the release asset's sha256 digest from the GitHub API
+ * (REQUIRED — an asset without a digest is rejected), plus a bundle-id and
+ * version pin on the extracted app. If the app ever moves to Developer ID
+ * signing, port spdf_verify_signed_bundle back in.
+ */
+
+#define G_LOG_DOMAIN "nautilus-macos-bridge"
+
+#include <config.h>
+#include "nautilus-macos-bridge.h"
+
+#include <glib.h>
+
+#import <AppKit/AppKit.h>
+#import <CommonCrypto/CommonDigest.h>
+
+#include <fcntl.h>
+#include <unistd.h>
+#include <signal.h>
+#include <sys/stat.h>
+
+/* ---------------------------------------------------------------------------
+ * Constants
+ * ------------------------------------------------------------------------- */
+
+static NSString *const kSZFAppBundleID = @"com.intuition.shenzhenfiles";
+static NSString *const kSZFReleasesLatestURL =
+    @"https://api.github.com/repos/casimir-engineering/shenzhen-files/releases/latest";
+static NSString *const kSZFAssetName = @"ShenzhenFiles-mac-arm64.dmg";
+static NSString *const kSZFStagedAppName = @"Shenzhen Files.app";
+static NSString *const kSZFSupportDirName = @"Shenzhen Files";
+
+static const NSTimeInterval kSZFDailyInterval = 86400.0;      /* 24h gate */
+static const NSTimeInterval kSZFIdleDelay = 5.0;              /* post-launch settle */
+static const NSTimeInterval kSZFRecurringCadence = 3600.0;    /* re-arm poll */
+static const NSTimeInterval kSZFRecurringLeeway = 600.0;
+static const NSTimeInterval kSZFNetworkTimeout = 15.0;
+static const NSTimeInterval kSZFLeaseStaleAfter = 3600.0;     /* 1h liveness ceiling */
+static const NSTimeInterval kSZFLaterSnooze = 7.0 * 86400.0;  /* "Later" nag cap */
+static const long long kSZFMaxDownloadBytes = 256LL * 1024 * 1024;
+static const NSUInteger kSZFMaxRedirects = 5;
+static const NSInteger kSZFSiblingQuitTimeoutSeconds = 20;
+
+static NSString *const kSZFUpdaterErrorDomain = @"SZFUpdaterErrorDomain";
+
+/* ---------------------------------------------------------------------------
+ * Version comparison (pure; "YY.M.DD-BUILD" split on "[. -]")
+ * ------------------------------------------------------------------------- */
+
+static NSArray<NSNumber *> *
+szf_version_components (NSString *version)
+{
+    if (![version isKindOfClass:NSString.class] || version.length == 0)
+    {
+        return nil;
+    }
+    NSCharacterSet *seps = [NSCharacterSet characterSetWithCharactersInString:@". -"];
+    NSArray<NSString *> *parts = [version componentsSeparatedByCharactersInSet:seps];
+    NSMutableArray<NSNumber *> *out = [NSMutableArray array];
+    for (NSString *part in parts)
+    {
+        if (part.length == 0)
+        {
+            continue;
+        }
+        NSScanner *scanner = [NSScanner scannerWithString:part];
+        long long value = 0;
+        if (![scanner scanLongLong:&value] || !scanner.atEnd)
+        {
+            return nil;             /* non-numeric field => malformed */
+        }
+        [out addObject:@(value)];
+    }
+    return out.count ? out : nil;
+}
+
+static NSComparisonResult
+szf_compare_versions (NSString *a, NSString *b)
+{
+    NSArray<NSNumber *> *ca = szf_version_components (a);
+    NSArray<NSNumber *> *cb = szf_version_components (b);
+    if (!ca || !cb)
+    {
+        return NSOrderedSame;       /* malformed => no ordering decision */
+    }
+    NSUInteger n = MAX (ca.count, cb.count);
+    for (NSUInteger i = 0; i < n; ++i)
+    {
+        long long va = i < ca.count ? ca[i].longLongValue : 0;
+        long long vb = i < cb.count ? cb[i].longLongValue : 0;
+        if (va < vb)
+        {
+            return NSOrderedAscending;
+        }
+        if (va > vb)
+        {
+            return NSOrderedDescending;
+        }
+    }
+    return NSOrderedSame;
+}
+
+/* Daily-check scheduling decision (pure). 0 => due now; >0 => seconds until
+ * the rolling 24h gate opens; backwards clock => gate stays closed. */
+static NSTimeInterval
+szf_daily_check_delay (BOOL haveLastCheck, NSTimeInterval lastCheckEpoch,
+                       NSTimeInterval nowEpoch)
+{
+    if (!haveLastCheck)
+    {
+        return 0;                   /* fresh install: due immediately */
+    }
+    NSTimeInterval elapsed = nowEpoch - lastCheckEpoch;
+    if (elapsed >= kSZFDailyInterval)
+    {
+        return 0;
+    }
+    return kSZFDailyInterval - elapsed;
+}
+
+static NSError *
+szf_make_error (NSString *message)
+{
+    return [NSError errorWithDomain:kSZFUpdaterErrorDomain
+                               code:-1
+                           userInfo:@{ NSLocalizedDescriptionKey: message ?: @"Update failed." }];
+}
+
+/* ---------------------------------------------------------------------------
+ * Integrity verification (ad-hoc build: sha256 digest + bundle-id pin)
+ * ------------------------------------------------------------------------- */
+
+static NSString *
+szf_sha256_hex_for_file (NSURL *url)
+{
+    NSFileHandle *fh = [NSFileHandle fileHandleForReadingFromURL:url error:nil];
+    if (!fh)
+    {
+        return nil;
+    }
+    CC_SHA256_CTX ctx;
+    CC_SHA256_Init (&ctx);
+    for (;;)
+    {
+        @autoreleasepool
+        {
+            NSData *chunk = [fh readDataOfLength:1 << 20];
+            if (chunk.length == 0)
+            {
+                break;
+            }
+            CC_SHA256_Update (&ctx, chunk.bytes, (CC_LONG) chunk.length);
+        }
+    }
+    [fh closeFile];
+    unsigned char digest[CC_SHA256_DIGEST_LENGTH];
+    CC_SHA256_Final (digest, &ctx);
+    NSMutableString *hex = [NSMutableString stringWithCapacity:CC_SHA256_DIGEST_LENGTH * 2];
+    for (int i = 0; i < CC_SHA256_DIGEST_LENGTH; ++i)
+    {
+        [hex appendFormat:@"%02x", digest[i]];
+    }
+    return hex;
+}
+
+/* The extracted app must be Shenzhen Files (bundle-id pin) at the published
+ * version. TRUST NOTE: with ad-hoc signing this is an identity check, not an
+ * anti-tamper boundary — that boundary is the TLS + sha256-digest check on
+ * the DMG the app was extracted from. */
+static BOOL
+szf_verify_extracted_app (NSString *appPath, NSString *tag, NSError **error)
+{
+    NSBundle *bundle = [NSBundle bundleWithPath:appPath];
+    NSString *bundleID = bundle.bundleIdentifier;
+    if (![bundleID isEqualToString:kSZFAppBundleID])
+    {
+        if (error)
+        {
+            *error = szf_make_error (@"The update is not Shenzhen Files.");
+        }
+        return NO;
+    }
+    NSString *shortVersion = bundle.infoDictionary[@"CFBundleShortVersionString"];
+    NSArray<NSNumber *> *tagP = szf_version_components (tag);
+    NSArray<NSNumber *> *appP = szf_version_components (shortVersion);
+    /* Compare only the YY.M.DD primary key (tag carries -BUILD; plist may not). */
+    if (tagP.count >= 3 && appP.count >= 3)
+    {
+        if (!(tagP[0].longLongValue == appP[0].longLongValue &&
+              tagP[1].longLongValue == appP[1].longLongValue &&
+              tagP[2].longLongValue == appP[2].longLongValue))
+        {
+            if (error)
+            {
+                *error = szf_make_error (@"The update did not match the published version.");
+            }
+            return NO;
+        }
+    }
+    return YES;
+}
+
+static NSString *
+szf_bundle_short_version (NSString *appPath)
+{
+    return [NSBundle bundleWithPath:appPath].infoDictionary[@"CFBundleShortVersionString"];
+}
+
+/* ---------------------------------------------------------------------------
+ * Release-notes formatting for the alert (port of
+ * spdf_format_release_notes_for_alert)
+ * ------------------------------------------------------------------------- */
+
+static NSString *
+szf_format_release_notes_for_alert (NSString *body)
+{
+    if (![body isKindOfClass:NSString.class] || body.length == 0)
+    {
+        return @"";
+    }
+    NSCharacterSet *ws = NSCharacterSet.whitespaceCharacterSet;
+    NSString *text = [body stringByReplacingOccurrencesOfString:@"\r\n" withString:@"\n"];
+    text = [text stringByReplacingOccurrencesOfString:@"\r" withString:@"\n"];
+
+    NSMutableArray<NSString *> *lines = [NSMutableArray array];
+    for (NSString *rawLine in [text componentsSeparatedByString:@"\n"])
+    {
+        NSString *line = [rawLine stringByTrimmingCharactersInSet:ws];
+        /* Release bodies put highlights above the first horizontal rule;
+         * the alert shows only that section. */
+        if ([line hasPrefix:@"---"] || [line hasPrefix:@"***"] || [line hasPrefix:@"___"])
+        {
+            break;
+        }
+        while ([line hasPrefix:@"#"])
+        {
+            line = [line substringFromIndex:1];
+        }
+        if ([line hasPrefix:@"> "])
+        {
+            line = [line substringFromIndex:2];
+        }
+        line = [line stringByTrimmingCharactersInSet:ws];
+        BOOL isBullet = NO;
+        for (NSString *bullet in @[ @"- ", @"* ", @"+ " ])
+        {
+            if ([line hasPrefix:bullet])
+            {
+                line = [@"• " stringByAppendingString:[line substringFromIndex:2]];
+                isBullet = YES;
+                break;
+            }
+        }
+        for (NSString *marker in @[ @"**", @"`", @"_" ])
+        {
+            line = [line stringByReplacingOccurrencesOfString:marker withString:@""];
+        }
+        BOOL continuation = !isBullet && line.length && [rawLine hasPrefix:@"  "] &&
+                            lines.count && ((NSString *) lines.lastObject).length;
+        if (continuation)
+        {
+            lines[lines.count - 1] = [lines.lastObject stringByAppendingFormat:@" %@", line];
+        }
+        else if (line.length)
+        {
+            [lines addObject:line];
+        }
+    }
+    text = [lines componentsJoinedByString:@"\n"];
+
+    /* Neutralize control + bidi characters so a crafted release body can't
+     * spoof the version line that follows in the alert. */
+    NSMutableCharacterSet *strip = [NSMutableCharacterSet new];
+    [strip formUnionWithCharacterSet:NSCharacterSet.controlCharacterSet];
+    [strip addCharactersInRange:NSMakeRange (0x202A, 5)];
+    [strip addCharactersInRange:NSMakeRange (0x2066, 4)];
+    NSMutableString *cleaned = [NSMutableString stringWithCapacity:text.length];
+    [text enumerateSubstringsInRange:NSMakeRange (0, text.length)
+                             options:NSStringEnumerationByComposedCharacterSequences
+                          usingBlock:^(NSString *sub, NSRange r, NSRange er, BOOL *stop) {
+                              (void) r;
+                              (void) er;
+                              (void) stop;
+                              unichar c = sub.length ? [sub characterAtIndex:0] : 0;
+                              if (sub.length == 1 && [strip characterIsMember:c] && c != '\n')
+                              {
+                                  return;
+                              }
+                              [cleaned appendString:sub];
+                          }];
+    text = [cleaned stringByTrimmingCharactersInSet:NSCharacterSet.whitespaceAndNewlineCharacterSet];
+    if (text.length > 500)
+    {
+        NSRange lastBreak = [[text substringToIndex:500] rangeOfString:@"\n"
+                                                               options:NSBackwardsSearch];
+        NSUInteger cut = lastBreak.location != NSNotFound ? lastBreak.location : 500;
+        text = [[[text substringToIndex:cut]
+                   stringByTrimmingCharactersInSet:NSCharacterSet.whitespaceAndNewlineCharacterSet]
+                   stringByAppendingString:@"\n…"];
+    }
+    return text;
+}
+
+/* ---------------------------------------------------------------------------
+ * Foundation/AppKit-only post-update swap/relaunch helper (--post-update)
+ * ------------------------------------------------------------------------- */
+
+static NSString *
+szf_support_dir_static (void)
+{
+    NSURL *base = [NSFileManager.defaultManager URLsForDirectory:NSApplicationSupportDirectory
+                                                       inDomains:NSUserDomainMask].firstObject;
+    return [base.path stringByAppendingPathComponent:kSZFSupportDirName];
+}
+
+static NSUInteger
+szf_running_instance_count (void)
+{
+    NSUInteger count = 0;
+    for (NSRunningApplication *app in
+         [NSRunningApplication runningApplicationsWithBundleIdentifier:kSZFAppBundleID])
+    {
+        if (app.processIdentifier != getpid ())
+        {
+            ++count;
+        }
+    }
+    return count;
+}
+
+/* Clear updateInProgress and pendingTag from update.json on a helper abort.
+ * Foundation-only flock read-modify-write. */
+static void
+szf_helper_clear_update_state (void)
+{
+    NSString *dir = szf_support_dir_static ();
+    NSString *lockPath = [dir stringByAppendingPathComponent:@"update.lock"];
+    NSString *jsonPath = [dir stringByAppendingPathComponent:@"update.json"];
+    int fd = open (lockPath.fileSystemRepresentation, O_CREAT | O_RDWR, 0600);
+    if (fd >= 0)
+    {
+        flock (fd, LOCK_EX);
+    }
+    NSMutableDictionary *update = [NSMutableDictionary dictionary];
+    NSData *data = [NSData dataWithContentsOfFile:jsonPath];
+    if (data)
+    {
+        id obj = [NSJSONSerialization JSONObjectWithData:data
+                                                 options:NSJSONReadingMutableContainers
+                                                   error:nil];
+        if ([obj isKindOfClass:NSDictionary.class])
+        {
+            update = obj;
+        }
+    }
+    [update removeObjectForKey:@"updateInProgress"];
+    [update removeObjectForKey:@"pendingTag"];
+    NSData *out = [NSJSONSerialization dataWithJSONObject:update
+                                                  options:NSJSONWritingPrettyPrinted | NSJSONWritingSortedKeys
+                                                    error:nil];
+    if (out)
+    {
+        [out writeToFile:jsonPath atomically:YES];
+    }
+    if (fd >= 0)
+    {
+        flock (fd, LOCK_UN);
+        close (fd);
+    }
+}
+
+static void
+szf_helper_relaunch_original (NSString *targetBundlePath)
+{
+    NSURL *originalURL = [NSURL fileURLWithPath:targetBundlePath];
+    LSRegisterURL ((__bridge CFURLRef) originalURL, true);
+    [NSWorkspace.sharedWorkspace openApplicationAtURL:originalURL
+                                        configuration:[NSWorkspaceOpenConfiguration configuration]
+                                    completionHandler:nil];
+}
+
+static BOOL
+szf_run_tool (NSString *launchPath, NSArray<NSString *> *args, NSData **outData)
+{
+    NSTask *task = [[NSTask alloc] init];
+    task.executableURL = [NSURL fileURLWithPath:launchPath];
+    task.arguments = args;
+    NSPipe *outPipe = [NSPipe pipe];
+    task.standardOutput = outPipe;
+    task.standardError = [NSFileHandle fileHandleWithNullDevice];
+    if (![task launchAndReturnError:nil])
+    {
+        return NO;
+    }
+    NSData *data = [outPipe.fileHandleForReading readDataToEndOfFile];
+    [task waitUntilExit];
+    if (task.terminationStatus != 0)
+    {
+        return NO;
+    }
+    if (outData)
+    {
+        *outData = data;
+    }
+    return YES;
+}
+
+int
+nautilus_macos_updater_run_post_update_helper (const char *staged_c,
+                                               const char *target_c)
+{
+    @autoreleasepool
+    {
+        NSString *stagedAppPath = staged_c ? @(staged_c) : nil;
+        NSString *targetBundlePath = target_c ? @(target_c) : nil;
+        if (stagedAppPath.length == 0 || targetBundlePath.length == 0)
+        {
+            return 1;
+        }
+        setsid ();          /* detach so we outlive the exiting parent */
+
+        NSFileManager *fm = NSFileManager.defaultManager;
+
+        /* Identity re-check of the staged bundle immediately before the swap
+         * (bundle-id + version were verified pre-spawn; ad-hoc build has no
+         * signature to re-verify — see file header). */
+        NSError *verifyErr = nil;
+        NSString *pendingTag = szf_bundle_short_version (stagedAppPath);
+        if (!szf_verify_extracted_app (stagedAppPath, pendingTag, &verifyErr))
+        {
+            [fm removeItemAtPath:stagedAppPath error:nil];
+            szf_helper_clear_update_state ();
+            szf_helper_relaunch_original (targetBundlePath);
+            return 1;
+        }
+        chmod (stagedAppPath.stringByDeletingLastPathComponent.fileSystemRepresentation, 0700);
+
+        /* Bounded poll until all old-bundle instances exit; escalate to
+         * forceTerminate on timeout, then a short settle. */
+        NSTimeInterval waited = 0;
+        while (szf_running_instance_count () > 0 && waited < kSZFSiblingQuitTimeoutSeconds)
+        {
+            [NSThread sleepForTimeInterval:0.5];
+            waited += 0.5;
+        }
+        if (szf_running_instance_count () > 0)
+        {
+            for (NSRunningApplication *app in
+                 [NSRunningApplication runningApplicationsWithBundleIdentifier:kSZFAppBundleID])
+            {
+                if (app.processIdentifier != getpid ())
+                {
+                    [app forceTerminate];
+                }
+            }
+            NSTimeInterval forced = 0;
+            while (szf_running_instance_count () > 0 && forced < 5.0)
+            {
+                [NSThread sleepForTimeInterval:0.5];
+                forced += 0.5;
+            }
+        }
+        if (szf_running_instance_count () > 0)
+        {
+            [fm removeItemAtPath:stagedAppPath error:nil];
+            szf_helper_clear_update_state ();
+            szf_helper_relaunch_original (targetBundlePath);
+            return 1;
+        }
+        [NSThread sleepForTimeInterval:0.5];
+
+        NSString *oldPath = [targetBundlePath stringByAppendingString:@".old"];
+        [fm removeItemAtPath:oldPath error:nil];
+
+        /* Move-aside two-rename swap. */
+        BOOL targetExists = [fm fileExistsAtPath:targetBundlePath];
+        if (targetExists)
+        {
+            if (rename (targetBundlePath.fileSystemRepresentation,
+                        oldPath.fileSystemRepresentation) != 0)
+            {
+                szf_helper_clear_update_state ();
+                szf_helper_relaunch_original (targetBundlePath);
+                return 1;
+            }
+        }
+        if (rename (stagedAppPath.fileSystemRepresentation,
+                    targetBundlePath.fileSystemRepresentation) != 0)
+        {
+            if (targetExists)
+            {
+                rename (oldPath.fileSystemRepresentation,
+                        targetBundlePath.fileSystemRepresentation);
+            }
+            szf_helper_clear_update_state ();
+            szf_helper_relaunch_original (targetBundlePath);
+            return 1;
+        }
+
+        /* Final identity check at the final path, then strip quarantine so
+         * Gatekeeper does not translocate the relaunched process. */
+        if (!szf_verify_extracted_app (targetBundlePath, pendingTag, NULL))
+        {
+            [fm removeItemAtPath:targetBundlePath error:nil];
+            if (targetExists)
+            {
+                rename (oldPath.fileSystemRepresentation,
+                        targetBundlePath.fileSystemRepresentation);
+            }
+            szf_helper_clear_update_state ();
+            szf_helper_relaunch_original (targetBundlePath);
+            return 1;
+        }
+        szf_run_tool (@"/usr/bin/xattr",
+                      @[ @"-dr", @"com.apple.quarantine", targetBundlePath ], NULL);
+
+        /* Re-register LaunchServices on the final path, then relaunch. */
+        NSURL *finalURL = [NSURL fileURLWithPath:targetBundlePath];
+        LSRegisterURL ((__bridge CFURLRef) finalURL, true);
+
+        NSWorkspaceOpenConfiguration *config = [NSWorkspaceOpenConfiguration configuration];
+        config.createsNewApplicationInstance = YES;
+        dispatch_semaphore_t sem = dispatch_semaphore_create (0);
+        [NSWorkspace.sharedWorkspace openApplicationAtURL:finalURL
+                                            configuration:config
+                                        completionHandler:^(NSRunningApplication *app, NSError *err) {
+                                            (void) app;
+                                            (void) err;
+                                            dispatch_semaphore_signal (sem);
+                                        }];
+        dispatch_semaphore_wait (sem, dispatch_time (DISPATCH_TIME_NOW,
+                                                     (int64_t) (20 * NSEC_PER_SEC)));
+
+        /* .old is retained until the relaunched process's pendingTag/update_ok
+         * handshake confirms the new version came up (consume-marker path). */
+        return 0;
+    }
+}
+
+/* ---------------------------------------------------------------------------
+ * SZFUpdater
+ * ------------------------------------------------------------------------- */
+
+@interface SZFUpdater : NSObject <NSURLSessionTaskDelegate, NSURLSessionDownloadDelegate>
++ (instancetype) shared;
+- (void) consumePendingUpdateMarkerAndSweep;
+- (void) scheduleDailyUpdateCheckIfNeeded;
+- (void) armRecurringUpdateCheck;
+- (void) checkForUpdatesUserInitiated: (BOOL) userInitiated;
+@end
+
+@implementation SZFUpdater
+{
+    dispatch_queue_t _queue;            /* Background-QoS serial queue */
+    BOOL _updateInProgress;             /* in-process driver flag (main thread) */
+    dispatch_source_t _recurringTimer;
+
+    NSURLSession *_downloadSession;
+    NSURLSessionDownloadTask *_downloadTask;
+    NSUInteger _redirectCount;
+    long long _expectedAssetSize;
+    NSURL *_downloadStagingURL;
+    void (^_downloadCompletion)(NSURL *_Nullable location, NSError *_Nullable error);
+
+    NSPanel *_progressPanel;
+    NSTextField *_progressTitleLabel;
+    NSTextField *_progressDetailLabel;
+    NSProgressIndicator *_progressIndicator;
+    NSButton *_progressCancelButton;
+    BOOL _userCancelled;
+
+    NSDictionary *_pendingPromptInfo;   /* deferred (non-active) prompt */
+}
+
++ (instancetype) shared
+{
+    static SZFUpdater *shared = nil;
+    static dispatch_once_t once;
+    dispatch_once (&once, ^{ shared = [[SZFUpdater alloc] init]; });
+    return shared;
+}
+
+- (instancetype) init
+{
+    if ((self = [super init]))
+    {
+        dispatch_queue_attr_t attr =
+            dispatch_queue_attr_make_with_qos_class (DISPATCH_QUEUE_SERIAL,
+                                                     QOS_CLASS_BACKGROUND, 0);
+        _queue = dispatch_queue_create ("com.intuition.shenzhenfiles.updater", attr);
+        [[NSNotificationCenter defaultCenter] addObserver:self
+                                                 selector:@selector (applicationDidBecomeActive:)
+                                                     name:NSApplicationDidBecomeActiveNotification
+                                                   object:nil];
+    }
+    return self;
+}
+
+/* ----- bundle guard ------------------------------------------------------- */
+
+/* Self-updating only makes sense for the installed bundle; dev runs of
+ * build/src/nautilus have no bundle to swap. */
+- (BOOL) runningFromBundle
+{
+    NSString *path = NSBundle.mainBundle.bundlePath;
+    return path != nil && [path hasSuffix:@".app"] &&
+           [NSBundle.mainBundle.bundleIdentifier isEqualToString:kSZFAppBundleID];
+}
+
+/* ----- support dir / update.json (flock'd) -------------------------------- */
+
+- (NSString *) supportDirectory
+{
+    NSString *dir = szf_support_dir_static ();
+    [NSFileManager.defaultManager createDirectoryAtPath:dir
+                            withIntermediateDirectories:YES
+                                             attributes:nil
+                                                  error:nil];
+    return dir;
+}
+
+- (NSString *) pathForStateFile: (NSString *) name
+{
+    return [[self supportDirectory] stringByAppendingPathComponent:name];
+}
+
+- (NSMutableDictionary *) readUpdateJSON
+{
+    NSData *data = [NSData dataWithContentsOfFile:[self pathForStateFile:@"update.json"]];
+    if (!data)
+    {
+        return [NSMutableDictionary dictionary];
+    }
+    id obj = [NSJSONSerialization JSONObjectWithData:data
+                                             options:NSJSONReadingMutableContainers
+                                               error:nil];
+    if (![obj isKindOfClass:NSDictionary.class])
+    {
+        return [NSMutableDictionary dictionary];
+    }
+    return obj;
+}
+
+- (void) writeUpdateJSON: (NSDictionary *) object
+{
+    NSData *data = [NSJSONSerialization dataWithJSONObject:object
+                                                   options:NSJSONWritingPrettyPrinted | NSJSONWritingSortedKeys
+                                                     error:nil];
+    if (data)
+    {
+        [data writeToFile:[self pathForStateFile:@"update.json"] atomically:YES];
+    }
+}
+
+- (void) withLockedUpdateStore: (BOOL (^)(NSMutableDictionary *update)) block
+{
+    if (!block)
+    {
+        return;
+    }
+    NSString *lockPath = [self pathForStateFile:@"update.lock"];
+    int fd = open (lockPath.fileSystemRepresentation, O_CREAT | O_RDWR, 0600);
+    if (fd >= 0)
+    {
+        flock (fd, LOCK_EX);
+    }
+    NSMutableDictionary *update = [self readUpdateJSON];
+    BOOL changed = block (update);
+    if (changed)
+    {
+        [self writeUpdateJSON:update];
+    }
+    if (fd >= 0)
+    {
+        flock (fd, LOCK_UN);
+        close (fd);
+    }
+}
+
+/* ----- self version -------------------------------------------------------- */
+
+/* "YY.M.DD-BUILD" from the running bundle's Info.plist. Fails closed. */
+- (NSString *) runningVersion
+{
+    NSDictionary *info = NSBundle.mainBundle.infoDictionary;
+    NSString *shortVersion = info[@"CFBundleShortVersionString"];
+    if (![shortVersion isKindOfClass:NSString.class] || shortVersion.length == 0)
+    {
+        return nil;
+    }
+    if (!szf_version_components (shortVersion))
+    {
+        return nil;
+    }
+    NSString *build = info[(NSString *) kCFBundleVersionKey];
+    if (![build isKindOfClass:NSString.class] || build.length == 0)
+    {
+        build = @"1";
+    }
+    return [NSString stringWithFormat:@"%@-%@", shortVersion, build];
+}
+
+- (NSString *) userAgent
+{
+    NSString *version = [self runningVersion] ?: @"unknown";
+    return [NSString stringWithFormat:
+                     @"ShenzhenFiles/%@ (macOS; +https://github.com/casimir-engineering/shenzhen-files)",
+                     version];
+}
+
+/* ----- skip-version persistence (update.json, no separate prefs UI) ------- */
+
+- (NSString *) skippedUpdateVersion
+{
+    __block NSString *tag = nil;
+    [self withLockedUpdateStore:^BOOL (NSMutableDictionary *update) {
+        id t = update[@"skippedTag"];
+        if ([t isKindOfClass:NSString.class])
+        {
+            tag = t;
+        }
+        return NO;
+    }];
+    return tag;
+}
+
+- (void) setSkippedUpdateVersion: (NSString *) tag
+{
+    [self withLockedUpdateStore:^BOOL (NSMutableDictionary *update) {
+        update[@"skippedTag"] = tag ?: @"";
+        return YES;
+    }];
+}
+
+/* ----- daily scheduling ----------------------------------------------------- */
+
+/* Cross-process flock'd 24h gate, stamped pre-network (a crash still burns
+ * the day); exactly one process can claim a given day's slot. */
+- (BOOL) claimDailyCheckSlot
+{
+    __block BOOL claimed = NO;
+    [self withLockedUpdateStore:^BOOL (NSMutableDictionary *update) {
+        NSTimeInterval now = [NSDate date].timeIntervalSince1970;
+        NSNumber *last = update[@"lastUpdateCheck"];
+        BOOL haveLast = [last isKindOfClass:NSNumber.class];
+        if (szf_daily_check_delay (haveLast, haveLast ? last.doubleValue : 0, now) != 0)
+        {
+            return NO;
+        }
+        update[@"lastUpdateCheck"] = @(now);
+        claimed = YES;
+        return YES;
+    }];
+    return claimed;
+}
+
+- (void) scheduleDailyUpdateCheckIfNeeded
+{
+    if (![self runningFromBundle])
+    {
+        return;
+    }
+    if (![self claimDailyCheckSlot])
+    {
+        return;
+    }
+    [self sweepStaleStagingDirs];
+    dispatch_after (dispatch_time (DISPATCH_TIME_NOW, (int64_t) (kSZFIdleDelay * NSEC_PER_SEC)),
+                    _queue, ^{ [self performNetworkCheckUserInitiated:NO]; });
+}
+
+- (void) armRecurringUpdateCheck
+{
+    if (![self runningFromBundle])
+    {
+        return;
+    }
+    static dispatch_once_t once;
+    dispatch_once (&once, ^{
+        _recurringTimer = dispatch_source_create (DISPATCH_SOURCE_TYPE_TIMER, 0, 0, _queue);
+        dispatch_source_set_timer (_recurringTimer,
+                                   dispatch_time (DISPATCH_TIME_NOW,
+                                                  (int64_t) (kSZFRecurringCadence * NSEC_PER_SEC)),
+                                   (uint64_t) (kSZFRecurringCadence * NSEC_PER_SEC),
+                                   (uint64_t) (kSZFRecurringLeeway * NSEC_PER_SEC));
+        dispatch_source_set_event_handler (_recurringTimer,
+                                           ^{ [self recurringUpdateTriggerFired]; });
+        dispatch_resume (_recurringTimer);
+        /* Dispatch timers do not fire across sleep; wall-clock catch-ups. */
+        [[NSNotificationCenter defaultCenter] addObserver:self
+                                                 selector:@selector (recurringUpdateCatchUp:)
+                                                     name:NSCalendarDayChangedNotification
+                                                   object:nil];
+        [[NSWorkspace.sharedWorkspace notificationCenter] addObserver:self
+                                                             selector:@selector (recurringUpdateCatchUp:)
+                                                                 name:NSWorkspaceDidWakeNotification
+                                                               object:nil];
+    });
+}
+
+- (void) recurringUpdateCatchUp: (NSNotification *) note
+{
+    (void) note;
+    dispatch_async (_queue, ^{ [self recurringUpdateTriggerFired]; });
+}
+
+- (void) recurringUpdateTriggerFired
+{
+    if (![self claimDailyCheckSlot])
+    {
+        return;
+    }
+    [self sweepStaleStagingDirs];
+    [self performNetworkCheckUserInitiated:NO];
+}
+
+- (void) checkForUpdatesUserInitiated: (BOOL) userInitiated
+{
+    if (![self runningFromBundle])
+    {
+        if (userInitiated)
+        {
+            [self showInfoOnMain:@"Software Update"
+                          detail:@"Updates only work for the installed Shenzhen Files.app bundle."];
+        }
+        return;
+    }
+    if (userInitiated)
+    {
+        if (_updateInProgress || [self liveLeaseHeldByOther])
+        {
+            [self showInfoOnMain:@"An update is already in progress." detail:@""];
+            return;
+        }
+    }
+    dispatch_async (_queue, ^{ [self performNetworkCheckUserInitiated:userInitiated]; });
+}
+
+/* ----- network check --------------------------------------------------------- */
+
+- (void) performNetworkCheckUserInitiated: (BOOL) userInitiated
+{
+    NSString *running = [self runningVersion];
+    if (running == nil)
+    {
+        if (userInitiated)
+        {
+            [self showErrorOnMain:@"Could not determine the installed version."];
+        }
+        return;
+    }
+
+    NSURLSessionConfiguration *config = [NSURLSessionConfiguration ephemeralSessionConfiguration];
+    config.waitsForConnectivity = NO;
+    NSURLSession *session = [NSURLSession sessionWithConfiguration:config];
+
+    NSMutableURLRequest *request =
+        [NSMutableURLRequest requestWithURL:[NSURL URLWithString:kSZFReleasesLatestURL]];
+    request.timeoutInterval = kSZFNetworkTimeout;
+    [request setValue:[self userAgent] forHTTPHeaderField:@"User-Agent"];
+    [request setValue:@"application/vnd.github+json" forHTTPHeaderField:@"Accept"];
+    [request setValue:@"2022-11-28" forHTTPHeaderField:@"X-GitHub-Api-Version"];
+
+    __block NSString *etag = nil;
+    [self withLockedUpdateStore:^BOOL (NSMutableDictionary *update) {
+        id e = update[@"etag"];
+        if ([e isKindOfClass:NSString.class])
+        {
+            etag = e;
+        }
+        return NO;
+    }];
+    /* Manual path omits If-None-Match so the full decision logic always runs;
+     * the silent path uses the ETag so a 304 short-circuits. */
+    if (etag.length && !userInitiated)
+    {
+        [request setValue:etag forHTTPHeaderField:@"If-None-Match"];
+    }
+
+    dispatch_semaphore_t sem = dispatch_semaphore_create (0);
+    __block NSData *responseData = nil;
+    __block NSHTTPURLResponse *httpResponse = nil;
+    __block NSError *netError = nil;
+    NSURLSessionDataTask *task =
+        [session dataTaskWithRequest:request
+                   completionHandler:^(NSData *data, NSURLResponse *response, NSError *error) {
+                       responseData = data;
+                       if ([response isKindOfClass:NSHTTPURLResponse.class])
+                       {
+                           httpResponse = (NSHTTPURLResponse *) response;
+                       }
+                       netError = error;
+                       dispatch_semaphore_signal (sem);
+                   }];
+    [task resume];
+    dispatch_semaphore_wait (sem, DISPATCH_TIME_FOREVER);
+    [session finishTasksAndInvalidate];
+
+    if (netError || !httpResponse)
+    {
+        if (userInitiated)
+        {
+            [self showErrorOnMain:@"Could not reach the update server."];
+        }
+        return;
+    }
+    if (httpResponse.statusCode == 304)
+    {
+        if (userInitiated)
+        {
+            [self showUpToDate];
+        }
+        return;
+    }
+    if (httpResponse.statusCode != 200)
+    {
+        if (userInitiated)
+        {
+            [self showErrorOnMain:@"The update server returned an unexpected response."];
+        }
+        return;
+    }
+
+    NSString *newEtag = httpResponse.allHeaderFields[@"Etag"]
+                        ?: httpResponse.allHeaderFields[@"ETag"];
+
+    id json = responseData ? [NSJSONSerialization JSONObjectWithData:responseData
+                                                             options:0
+                                                               error:nil]
+                           : nil;
+    if (![json isKindOfClass:NSDictionary.class])
+    {
+        if (userInitiated)
+        {
+            [self showErrorOnMain:@"The update server response was malformed."];
+        }
+        return;
+    }
+    NSDictionary *release = json;
+    NSString *tag = release[@"tag_name"];
+    BOOL draft = [release[@"draft"] boolValue];
+    BOOL prerelease = [release[@"prerelease"] boolValue];
+    NSString *notes = [release[@"body"] isKindOfClass:NSString.class] ? release[@"body"] : nil;
+
+    NSString *downloadURL = nil;
+    long long assetSize = 0;
+    NSString *assetDigest = nil;
+    for (NSDictionary *asset in (release[@"assets"] ?: @[]))
+    {
+        if (![asset isKindOfClass:NSDictionary.class])
+        {
+            continue;
+        }
+        if ([asset[@"name"] isEqualToString:kSZFAssetName])
+        {
+            downloadURL = asset[@"browser_download_url"];
+            assetSize = [asset[@"size"] longLongValue];
+            id digest = asset[@"digest"];
+            if ([digest isKindOfClass:NSString.class])
+            {
+                assetDigest = digest;
+            }
+            break;
+        }
+    }
+
+    /* Persist etag + advance the downgrade high-water mark. */
+    __block NSString *highestSeen = nil;
+    [self withLockedUpdateStore:^BOOL (NSMutableDictionary *update) {
+        BOOL changed = NO;
+        if (newEtag.length)
+        {
+            update[@"etag"] = newEtag;
+            changed = YES;
+        }
+        id hv = update[@"highestVersionSeen"];
+        highestSeen = [hv isKindOfClass:NSString.class] ? hv : nil;
+        if (tag.length && szf_compare_versions (tag, highestSeen) == NSOrderedDescending)
+        {
+            update[@"highestVersionSeen"] = tag;
+            highestSeen = tag;
+            changed = YES;
+        }
+        return changed;
+    }];
+
+    BOOL isNewer = (tag.length &&
+                    szf_compare_versions (tag, running) == NSOrderedDescending);
+    BOOL notDowngrade = (tag.length &&
+                         szf_compare_versions (tag, highestSeen) != NSOrderedAscending);
+    /* Ad-hoc trust model: the digest is REQUIRED (see file header). */
+    BOOL hasAsset = (downloadURL.length > 0 && assetDigest.length > 0);
+    BOOL available = isNewer && notDowngrade && hasAsset && !draft && !prerelease;
+
+    if (!available)
+    {
+        if (userInitiated)
+        {
+            [self showUpToDate];
+        }
+        return;
+    }
+
+    /* Silent path honours Skip + Later snooze; manual path ignores both. */
+    if (!userInitiated)
+    {
+        if ([tag isEqualToString:[self skippedUpdateVersion]])
+        {
+            return;
+        }
+        __block BOOL snoozed = NO;
+        [self withLockedUpdateStore:^BOOL (NSMutableDictionary *update) {
+            NSString *deferredTag = update[@"deferredTag"];
+            NSNumber *remindAfter = update[@"remindAfter"];
+            if ([deferredTag isEqualToString:tag] &&
+                [remindAfter isKindOfClass:NSNumber.class] &&
+                [NSDate date].timeIntervalSince1970 < remindAfter.doubleValue)
+            {
+                snoozed = YES;
+            }
+            return NO;
+        }];
+        if (snoozed)
+        {
+            return;
+        }
+    }
+
+    NSDictionary *promptInfo = @{
+        @"tag": tag ?: @"",
+        @"downloadURL": downloadURL ?: @"",
+        @"assetSize": @(assetSize),
+        @"assetDigest": assetDigest ?: @"",
+        @"notes": notes ?: @"",
+        @"userInitiated": @(userInitiated),
+    };
+    dispatch_async (dispatch_get_main_queue (), ^{ [self presentUpdateAvailable:promptInfo]; });
+}
+
+/* ----- update-available prompt ------------------------------------------------ */
+
+- (void) presentUpdateAvailable: (NSDictionary *) info
+{
+    BOOL userInitiated = [info[@"userInitiated"] boolValue];
+    if (!userInitiated && !NSApp.isActive)
+    {
+        _pendingPromptInfo = info;      /* surface on next activation */
+        return;
+    }
+
+    NSString *tag = info[@"tag"];
+    NSString *running = [self runningVersion] ?: @"";
+    NSAlert *alert = [[NSAlert alloc] init];
+    alert.messageText = @"A new version of Shenzhen Files is available";
+    NSString *detail = [NSString stringWithFormat:
+                        @"Shenzhen Files %@ is available — you have %@. "
+                        @"Would you like to install it now?", tag, running];
+    NSString *notes = info[@"notes"];
+    if ([notes isKindOfClass:NSString.class] && notes.length)
+    {
+        NSString *plain = szf_format_release_notes_for_alert (notes);
+        if (plain.length)
+        {
+            detail = [detail stringByAppendingFormat:@"\n\n%@", plain];
+        }
+    }
+    alert.informativeText = detail;
+    [alert addButtonWithTitle:@"Install and Relaunch"];
+    [alert addButtonWithTitle:@"Skip This Version"];
+    [alert addButtonWithTitle:@"Later"];
+
+    NSModalResponse response = [alert runModal];
+    [self handlePromptResponse:response info:info];
+}
+
+- (void) handlePromptResponse: (NSModalResponse) response info: (NSDictionary *) info
+{
+    NSString *tag = info[@"tag"];
+    if (response == NSAlertFirstButtonReturn)
+    {
+        dispatch_async (_queue, ^{ [self downloadAndInstall:info]; });
+    }
+    else if (response == NSAlertSecondButtonReturn)
+    {
+        [self setSkippedUpdateVersion:tag];
+    }
+    else
+    {
+        [self withLockedUpdateStore:^BOOL (NSMutableDictionary *update) {
+            update[@"deferredTag"] = tag;
+            update[@"remindAfter"] = @([NSDate date].timeIntervalSince1970 + kSZFLaterSnooze);
+            return YES;
+        }];
+    }
+}
+
+- (void) applicationDidBecomeActive: (NSNotification *) note
+{
+    (void) note;
+    if (!_pendingPromptInfo)
+    {
+        return;
+    }
+    NSDictionary *info = _pendingPromptInfo;
+    _pendingPromptInfo = nil;
+    [self presentUpdateAvailable:info];
+}
+
+/* ----- download + install ----------------------------------------------------- */
+
+- (void) downloadAndInstall: (NSDictionary *) info
+{
+    if (![self acquireLease])
+    {
+        [self showInfoOnMain:@"An update is already in progress." detail:@""];
+        return;
+    }
+    _updateInProgress = YES;
+
+    NSError *error = nil;
+    BOOL helperLaunched = NO;
+    @try
+    {
+        [self runInstallPipeline:info error:&error helperLaunched:&helperLaunched];
+    }
+    @catch (NSException *exception)
+    {
+        error = szf_make_error (exception.reason ?: @"The update could not be installed.");
+    }
+
+    /* On success the detached helper owns the swap window; the relaunched
+     * process clears the lease after the handshake. */
+    if (!helperLaunched)
+    {
+        _updateInProgress = NO;
+        [self releaseLease];
+    }
+
+    if (error)
+    {
+        [self dismissProgressOnMain];
+        [self showErrorOnMain:error.localizedDescription];
+    }
+}
+
+- (void) runInstallPipeline: (NSDictionary *) info
+                      error: (NSError **) outError
+             helperLaunched: (BOOL *) outHelperLaunched
+{
+    NSFileManager *fm = NSFileManager.defaultManager;
+    NSString *tag = info[@"tag"];
+    NSString *downloadURLString = info[@"downloadURL"];
+    long long assetSize = [info[@"assetSize"] longLongValue];
+
+    NSURL *bundleURL = NSBundle.mainBundle.bundleURL;
+    NSString *bundlePath = bundleURL.path;
+
+    /* Translocation / non-Applications guard. */
+    if ([bundlePath containsString:@"/AppTranslocation/"] ||
+        [bundlePath hasPrefix:@"/private/var/folders"])
+    {
+        if (outError)
+        {
+            *outError = szf_make_error (@"To enable automatic updates, move Shenzhen Files "
+                                        @"to your Applications folder.");
+        }
+        return;
+    }
+
+    /* Staging dir on the same volume as the install target (atomic rename). */
+    NSURL *parentURL = bundleURL.URLByDeletingLastPathComponent;
+    NSURL *stagingURL = [fm URLForDirectory:NSItemReplacementDirectory
+                                   inDomain:NSUserDomainMask
+                          appropriateForURL:parentURL
+                                     create:YES
+                                      error:nil];
+    if (!stagingURL)
+    {
+        if (outError)
+        {
+            *outError = szf_make_error (@"Could not create a staging directory for the update.");
+        }
+        return;
+    }
+
+    /* Free-space pre-check (~3x DMG). */
+    NSDictionary *attrs = [fm attributesOfFileSystemForPath:stagingURL.path error:nil];
+    long long freeBytes = [attrs[NSFileSystemFreeSize] longLongValue];
+    if (assetSize > 0 && freeBytes > 0 && freeBytes < assetSize * 3)
+    {
+        if (outError)
+        {
+            *outError = szf_make_error (@"There is not enough disk space to install the update.");
+        }
+        return;
+    }
+
+    /* Download (determinate progress wired to asset.size). */
+    [self showProgressOnMain:tag assetSize:assetSize];
+    NSURL *dmgURL = [self downloadAssetFrom:downloadURLString
+                                  assetSize:assetSize
+                                 stagingURL:stagingURL
+                                      error:outError];
+    if (!dmgURL)
+    {
+        return;                     /* *outError set, or user-cancelled (silent) */
+    }
+
+    /* Size + sha256 digest — the anti-tamper boundary on the ad-hoc build. */
+    NSDictionary *dmgAttrs = [fm attributesOfItemAtPath:dmgURL.path error:nil];
+    long long actualSize = [dmgAttrs[NSFileSize] longLongValue];
+    if (assetSize > 0 && actualSize != assetSize)
+    {
+        if (outError)
+        {
+            *outError = szf_make_error (@"The downloaded update was incomplete.");
+        }
+        return;
+    }
+    [self setProgressIndeterminateOnMain:@"Verifying download…"];
+    NSString *expectedDigest = info[@"assetDigest"];
+    NSString *hexDigest = [expectedDigest hasPrefix:@"sha256:"]
+                          ? [expectedDigest substringFromIndex:7]
+                          : expectedDigest;
+    NSString *computed = szf_sha256_hex_for_file (dmgURL);
+    if (hexDigest.length == 0 || computed.length == 0 ||
+        [computed caseInsensitiveCompare:hexDigest] != NSOrderedSame)
+    {
+        if (outError)
+        {
+            *outError = szf_make_error (@"The downloaded update could not be verified "
+                                        @"and was not installed.");
+        }
+        return;
+    }
+
+    /* Mount, discover the inner .app, ditto extract, detach. */
+    [self setProgressIndeterminateOnMain:@"Preparing update…"];
+    NSString *mountPoint = nil;
+    NSString *extractedApp = nil;
+    @try
+    {
+        mountPoint = [self attachDMG:dmgURL error:outError];
+        if (!mountPoint)
+        {
+            return;
+        }
+
+        NSString *innerApp = [self discoverInnerAppAtMount:mountPoint error:outError];
+        if (!innerApp)
+        {
+            return;
+        }
+
+        extractedApp = [stagingURL.path stringByAppendingPathComponent:kSZFStagedAppName];
+        [fm removeItemAtPath:extractedApp error:nil];
+        NSData *unused = nil;
+        if (!szf_run_tool (@"/usr/bin/ditto", @[ innerApp, extractedApp ], &unused))
+        {
+            if (outError)
+            {
+                *outError = szf_make_error (@"The update could not be extracted.");
+            }
+            return;
+        }
+    }
+    @finally
+    {
+        if (mountPoint)
+        {
+            [self detachMount:mountPoint];
+        }
+    }
+
+    /* Identity + version pin on the extracted app. */
+    if (!szf_verify_extracted_app (extractedApp, tag, outError))
+    {
+        return;
+    }
+
+    /* Strip quarantine defensively. */
+    szf_run_tool (@"/usr/bin/xattr", @[ @"-dr", @"com.apple.quarantine", extractedApp ], NULL);
+
+    /* Point-of-no-return confirm, then spawn the detached helper. */
+    __block BOOL proceed = NO;
+    dispatch_sync (dispatch_get_main_queue (), ^{ proceed = [self confirmInstallNow]; });
+    if (!proceed)
+    {
+        [self dismissProgressOnMain];
+        return;
+    }
+
+    [self withLockedUpdateStore:^BOOL (NSMutableDictionary *update) {
+        update[@"pendingTag"] = tag;
+        update[@"updateInProgress"] = @{
+            @"pid": @(getpid ()),
+            @"timestamp": @([NSDate date].timeIntervalSince1970),
+        };
+        return YES;
+    }];
+
+    [self dismissProgressOnMain];
+    [self spawnPostUpdateHelperStaged:extractedApp target:bundlePath];
+    if (outHelperLaunched)
+    {
+        *outHelperLaunched = YES;
+    }
+
+    /* Parent exits so the detached helper can swap. [NSApp terminate:] routes
+     * through GTK's NSApplicationDelegate and quits the GApplication cleanly;
+     * the helper's bounded poll + forceTerminate escalation is the backstop. */
+    dispatch_async (dispatch_get_main_queue (), ^{ [NSApp terminate:nil]; });
+}
+
+/* ----- download task ----------------------------------------------------------- */
+
+- (NSURL *) downloadAssetFrom: (NSString *) urlString
+                    assetSize: (long long) assetSize
+                   stagingURL: (NSURL *) stagingURL
+                        error: (NSError **) outError
+{
+    NSURL *url = [NSURL URLWithString:urlString];
+    if (![url.scheme isEqualToString:@"https"])
+    {
+        if (outError)
+        {
+            *outError = szf_make_error (@"The update download URL was not secure.");
+        }
+        return nil;
+    }
+    _redirectCount = 0;
+    _expectedAssetSize = assetSize;
+    _downloadStagingURL = stagingURL;
+    _userCancelled = NO;
+
+    NSURLSessionConfiguration *config = [NSURLSessionConfiguration ephemeralSessionConfiguration];
+    config.waitsForConnectivity = NO;
+    _downloadSession = [NSURLSession sessionWithConfiguration:config
+                                                     delegate:self
+                                                delegateQueue:nil];
+
+    NSMutableURLRequest *request = [NSMutableURLRequest requestWithURL:url];
+    request.timeoutInterval = 60.0;
+    [request setValue:[self userAgent] forHTTPHeaderField:@"User-Agent"];
+
+    dispatch_semaphore_t sem = dispatch_semaphore_create (0);
+    __block NSURL *resultURL = nil;
+    __block NSError *resultError = nil;
+    _downloadCompletion = ^(NSURL *location, NSError *error) {
+        resultURL = location;
+        resultError = error;
+        dispatch_semaphore_signal (sem);
+    };
+    _downloadTask = [_downloadSession downloadTaskWithRequest:request];
+    [_downloadTask resume];
+    dispatch_semaphore_wait (sem, DISPATCH_TIME_FOREVER);
+    [_downloadSession finishTasksAndInvalidate];
+    _downloadSession = nil;
+    _downloadTask = nil;
+    _downloadCompletion = nil;
+
+    if (_userCancelled)
+    {
+        return nil;                 /* silent */
+    }
+    if (resultError || !resultURL)
+    {
+        if (outError)
+        {
+            *outError = szf_make_error (@"The update could not be downloaded.");
+        }
+        return nil;
+    }
+
+    NSString *dest = [stagingURL.path stringByAppendingPathComponent:kSZFAssetName];
+    [NSFileManager.defaultManager removeItemAtPath:dest error:nil];
+    if (![NSFileManager.defaultManager moveItemAtURL:resultURL
+                                               toURL:[NSURL fileURLWithPath:dest]
+                                               error:nil])
+    {
+        if (outError)
+        {
+            *outError = szf_make_error (@"The downloaded update could not be saved.");
+        }
+        return nil;
+    }
+    return [NSURL fileURLWithPath:dest];
+}
+
+/* https-only on every redirect hop + bounded redirect count. */
+- (void)                    URLSession: (NSURLSession *) session
+                                  task: (NSURLSessionTask *) task
+            willPerformHTTPRedirection: (NSHTTPURLResponse *) response
+                            newRequest: (NSURLRequest *) request
+                     completionHandler: (void (^)(NSURLRequest *_Nullable)) completionHandler
+{
+    (void) session;
+    (void) task;
+    (void) response;
+    if (++_redirectCount > kSZFMaxRedirects || ![request.URL.scheme isEqualToString:@"https"])
+    {
+        completionHandler (nil);
+        return;
+    }
+    completionHandler (request);
+}
+
+- (void)        URLSession: (NSURLSession *) session
+              downloadTask: (NSURLSessionDownloadTask *) downloadTask
+              didWriteData: (int64_t) bytesWritten
+         totalBytesWritten: (int64_t) totalBytesWritten
+ totalBytesExpectedToWrite: (int64_t) totalBytesExpectedToWrite
+{
+    (void) session;
+    (void) bytesWritten;
+    /* Zip-bomb cap: the written-bytes ceiling is the hard bound. */
+    long long ceiling = _expectedAssetSize > 0
+                        ? MIN (_expectedAssetSize + 1, kSZFMaxDownloadBytes)
+                        : kSZFMaxDownloadBytes;
+    if (totalBytesWritten > ceiling ||
+        (totalBytesExpectedToWrite > 0 && totalBytesExpectedToWrite > kSZFMaxDownloadBytes))
+    {
+        [downloadTask cancel];
+        return;
+    }
+    long long total = _expectedAssetSize > 0 ? _expectedAssetSize : totalBytesExpectedToWrite;
+    dispatch_async (dispatch_get_main_queue (), ^{
+        [self updateProgress:(double) totalBytesWritten total:(double) total];
+    });
+}
+
+- (void)          URLSession: (NSURLSession *) session
+                downloadTask: (NSURLSessionDownloadTask *) downloadTask
+   didFinishDownloadingToURL: (NSURL *) location
+{
+    (void) session;
+    (void) downloadTask;
+    /* Move directly into the same-volume staging dir (rename, not a
+     * cross-volume copy); the per-task temp file is deleted on return. */
+    NSURL *destDir = _downloadStagingURL ?: [NSURL fileURLWithPath:NSTemporaryDirectory ()];
+    NSURL *tmp = [destDir URLByAppendingPathComponent:[[NSUUID UUID] UUIDString]];
+    NSError *err = nil;
+    if (![NSFileManager.defaultManager moveItemAtURL:location toURL:tmp error:&err])
+    {
+        if (_downloadCompletion)
+        {
+            _downloadCompletion (nil, err);
+        }
+        return;
+    }
+    if (_downloadCompletion)
+    {
+        _downloadCompletion (tmp, nil);
+    }
+}
+
+- (void) URLSession: (NSURLSession *) session
+               task: (NSURLSessionTask *) task
+didCompleteWithError: (NSError *) error
+{
+    (void) session;
+    (void) task;
+    if (error && _downloadCompletion)
+    {
+        _downloadCompletion (nil, error);
+    }
+}
+
+/* ----- hdiutil mount / discover / detach --------------------------------------- */
+
+- (NSString *) attachDMG: (NSURL *) dmgURL error: (NSError **) outError
+{
+    NSData *plistData = nil;
+    if (!szf_run_tool (@"/usr/bin/hdiutil",
+                       @[ @"attach", @"-nobrowse", @"-readonly", @"-noautoopen", @"-plist",
+                          dmgURL.path ],
+                       &plistData))
+    {
+        if (outError)
+        {
+            *outError = szf_make_error (@"The update disk image could not be opened.");
+        }
+        return nil;
+    }
+    id plist = [NSPropertyListSerialization propertyListWithData:plistData
+                                                         options:0
+                                                          format:nil
+                                                           error:nil];
+    NSArray *entities = [plist isKindOfClass:NSDictionary.class] ? plist[@"system-entities"] : nil;
+    NSString *mountPoint = nil;
+    for (NSDictionary *entity in entities)
+    {
+        NSString *mp = entity[@"mount-point"];
+        if ([mp isKindOfClass:NSString.class] && mp.length)
+        {
+            mountPoint = mp;
+            break;
+        }
+    }
+    if (!mountPoint)
+    {
+        if (outError)
+        {
+            *outError = szf_make_error (@"The update disk image had no mount point.");
+        }
+        return nil;
+    }
+    return mountPoint;
+}
+
+- (NSString *) discoverInnerAppAtMount: (NSString *) mountPoint error: (NSError **) outError
+{
+    NSFileManager *fm = NSFileManager.defaultManager;
+    NSArray<NSString *> *entries = [fm contentsOfDirectoryAtPath:mountPoint error:nil];
+    NSString *found = nil;
+    NSUInteger matches = 0;
+    for (NSString *entry in entries)
+    {
+        if (![entry.pathExtension isEqualToString:@"app"])
+        {
+            continue;
+        }
+        NSString *full = [mountPoint stringByAppendingPathComponent:entry];
+        NSDictionary *attrs = [fm attributesOfItemAtPath:full error:nil];
+        if ([attrs[NSFileType] isEqualToString:NSFileTypeSymbolicLink])
+        {
+            continue;               /* skip the Applications symlink */
+        }
+        NSString *bundleID = [NSBundle bundleWithPath:full].bundleIdentifier;
+        if (![bundleID isEqualToString:kSZFAppBundleID])
+        {
+            continue;
+        }
+        found = full;
+        ++matches;
+    }
+    if (matches != 1)
+    {
+        if (outError)
+        {
+            *outError = szf_make_error (@"The update disk image did not contain Shenzhen Files.");
+        }
+        return nil;
+    }
+    return found;
+}
+
+- (void) detachMount: (NSString *) mountPoint
+{
+    if (!szf_run_tool (@"/usr/bin/hdiutil", @[ @"detach", mountPoint ], NULL))
+    {
+        szf_run_tool (@"/usr/bin/hdiutil", @[ @"detach", @"-force", mountPoint ], NULL);
+    }
+}
+
+/* Sweep orphaned staging dirs older than the lease ceiling. */
+- (void) sweepStaleStagingDirs
+{
+    NSFileManager *fm = NSFileManager.defaultManager;
+    NSURL *bundleURL = NSBundle.mainBundle.bundleURL;
+    NSURL *parentURL = bundleURL.URLByDeletingLastPathComponent;
+
+    NSURL *probe = [fm URLForDirectory:NSItemReplacementDirectory
+                              inDomain:NSUserDomainMask
+                     appropriateForURL:parentURL
+                                create:YES
+                                 error:nil];
+    if (!probe)
+    {
+        return;
+    }
+    NSURL *container = probe.URLByDeletingLastPathComponent;
+    [fm removeItemAtURL:probe error:nil];
+
+    NSDate *cutoff = [NSDate dateWithTimeIntervalSinceNow:-kSZFLeaseStaleAfter];
+    NSArray<NSURL *> *entries =
+        [fm contentsOfDirectoryAtURL:container
+          includingPropertiesForKeys:@[ NSURLContentModificationDateKey ]
+                             options:0
+                               error:nil];
+    for (NSURL *entry in entries)
+    {
+        NSString *staged = [entry.path stringByAppendingPathComponent:kSZFStagedAppName];
+        NSString *stagedDmg = [entry.path stringByAppendingPathComponent:kSZFAssetName];
+        if (![fm fileExistsAtPath:staged] && ![fm fileExistsAtPath:stagedDmg])
+        {
+            continue;
+        }
+        NSDate *mtime = nil;
+        [entry getResourceValue:&mtime forKey:NSURLContentModificationDateKey error:nil];
+        if (mtime && [mtime compare:cutoff] == NSOrderedDescending)
+        {
+            continue;               /* recent; leave it */
+        }
+        [fm removeItemAtURL:entry error:nil];
+    }
+}
+
+/* Launch-time post-update health handshake. */
+- (void) consumePendingUpdateMarkerAndSweep
+{
+    if (![self runningFromBundle])
+    {
+        return;
+    }
+
+    NSFileManager *fm = NSFileManager.defaultManager;
+    NSString *bundlePath = NSBundle.mainBundle.bundleURL.path;
+    NSString *oldPath = [bundlePath stringByAppendingString:@".old"];
+    NSString *running = [self runningVersion];
+
+    __block NSString *pendingTag = nil;
+    [self withLockedUpdateStore:^BOOL (NSMutableDictionary *update) {
+        id pt = update[@"pendingTag"];
+        if ([pt isKindOfClass:NSString.class] && [(NSString *) pt length])
+        {
+            pendingTag = pt;
+        }
+        return NO;
+    }];
+
+    if (pendingTag.length == 0)
+    {
+        if ([fm fileExistsAtPath:oldPath])
+        {
+            NSDictionary *attrs = [fm attributesOfItemAtPath:oldPath error:nil];
+            NSDate *mtime = attrs[NSFileModificationDate];
+            if (!mtime || [mtime timeIntervalSinceNow] < -kSZFLeaseStaleAfter)
+            {
+                [fm removeItemAtPath:oldPath error:nil];
+            }
+        }
+        [self sweepStaleStagingDirs];
+        return;
+    }
+
+    BOOL versionMatches = NO;
+    if (running.length)
+    {
+        NSArray<NSNumber *> *tagP = szf_version_components (pendingTag);
+        NSArray<NSNumber *> *runP = szf_version_components (running);
+        if (tagP.count >= 3 && runP.count >= 3)
+        {
+            versionMatches = (tagP[0].longLongValue == runP[0].longLongValue &&
+                              tagP[1].longLongValue == runP[1].longLongValue &&
+                              tagP[2].longLongValue == runP[2].longLongValue);
+        }
+    }
+
+    if (versionMatches)
+    {
+        NSString *okTag = pendingTag;
+        [self withLockedUpdateStore:^BOOL (NSMutableDictionary *update) {
+            update[@"update_ok"] = okTag;
+            [update removeObjectForKey:@"pendingTag"];
+            [update removeObjectForKey:@"updateInProgress"];
+            return YES;
+        }];
+        [fm removeItemAtPath:oldPath error:nil];
+        [self sweepStaleStagingDirs];
+        dispatch_async (dispatch_get_main_queue (), ^{
+            NSAlert *alert = [[NSAlert alloc] init];
+            alert.messageText = [NSString stringWithFormat:@"You're now on Shenzhen Files %@.",
+                                                           okTag];
+            alert.informativeText = @"";
+            [alert runModal];
+        });
+        return;
+    }
+
+    /* pendingTag set but the running version does NOT match: the swap never
+     * took, or the new version failed and the user reopened the old bundle.
+     * Reveal the retained .old for recovery and clear the lifecycle state. */
+    if ([fm fileExistsAtPath:oldPath])
+    {
+        dispatch_async (dispatch_get_main_queue (), ^{
+            [NSWorkspace.sharedWorkspace
+                activateFileViewerSelectingURLs:@[ [NSURL fileURLWithPath:oldPath] ]];
+        });
+    }
+    [self withLockedUpdateStore:^BOOL (NSMutableDictionary *update) {
+        [update removeObjectForKey:@"pendingTag"];
+        [update removeObjectForKey:@"updateInProgress"];
+        return YES;
+    }];
+    [self sweepStaleStagingDirs];
+}
+
+/* ----- liveness lease ----------------------------------------------------------- */
+
+- (BOOL) acquireLease
+{
+    __block BOOL acquired = NO;
+    [self withLockedUpdateStore:^BOOL (NSMutableDictionary *update) {
+        NSDictionary *lease = update[@"updateInProgress"];
+        if ([lease isKindOfClass:NSDictionary.class])
+        {
+            pid_t pid = (pid_t) [lease[@"pid"] intValue];
+            NSTimeInterval ts = [lease[@"timestamp"] doubleValue];
+            BOOL alive = (pid > 0 && kill (pid, 0) == 0);
+            BOOL recent = ([NSDate date].timeIntervalSince1970 - ts) < kSZFLeaseStaleAfter;
+            if (alive && recent && pid != getpid ())
+            {
+                return NO;          /* genuinely held */
+            }
+        }
+        update[@"updateInProgress"] = @{
+            @"pid": @(getpid ()),
+            @"timestamp": @([NSDate date].timeIntervalSince1970),
+        };
+        acquired = YES;
+        return YES;
+    }];
+    return acquired;
+}
+
+- (BOOL) liveLeaseHeldByOther
+{
+    __block BOOL held = NO;
+    [self withLockedUpdateStore:^BOOL (NSMutableDictionary *update) {
+        NSDictionary *lease = update[@"updateInProgress"];
+        if ([lease isKindOfClass:NSDictionary.class])
+        {
+            pid_t pid = (pid_t) [lease[@"pid"] intValue];
+            NSTimeInterval ts = [lease[@"timestamp"] doubleValue];
+            BOOL alive = (pid > 0 && kill (pid, 0) == 0);
+            BOOL recent = ([NSDate date].timeIntervalSince1970 - ts) < kSZFLeaseStaleAfter;
+            if (alive && recent && pid != getpid ())
+            {
+                held = YES;
+            }
+        }
+        return NO;
+    }];
+    return held;
+}
+
+- (void) releaseLease
+{
+    [self withLockedUpdateStore:^BOOL (NSMutableDictionary *update) {
+        if (update[@"updateInProgress"])
+        {
+            [update removeObjectForKey:@"updateInProgress"];
+            return YES;
+        }
+        return NO;
+    }];
+}
+
+/* ----- helper spawn --------------------------------------------------------------- */
+
+/* Spawn Contents/MacOS/nautilus --post-update <staged> <target>. The raw
+ * binary (not the launcher) is fine: nautilus-main.c short-circuits into
+ * nautilus_macos_updater_run_post_update_helper() before any GTK/GLib env
+ * is needed. */
+- (void) spawnPostUpdateHelperStaged: (NSString *) stagedApp target: (NSString *) targetBundle
+{
+    NSString *executable =
+        [NSBundle.mainBundle.bundlePath stringByAppendingPathComponent:@"Contents/MacOS/nautilus"];
+    NSTask *task = [[NSTask alloc] init];
+    task.executableURL = [NSURL fileURLWithPath:executable];
+    task.arguments = @[ @"--post-update", stagedApp, targetBundle ];
+    task.standardOutput = [NSFileHandle fileHandleWithNullDevice];
+    task.standardError = [NSFileHandle fileHandleWithNullDevice];
+    [task launchAndReturnError:nil];
+}
+
+/* ----- UI: progress panel ----------------------------------------------------------- */
+
+- (void) showProgressOnMain: (NSString *) tag assetSize: (long long) assetSize
+{
+    dispatch_async (dispatch_get_main_queue (), ^{
+        [self buildProgressPanel:tag assetSize:assetSize];
+    });
+}
+
+- (void) buildProgressPanel: (NSString *) tag assetSize: (long long) assetSize
+{
+    if (!_progressPanel)
+    {
+        _progressPanel = [[NSPanel alloc] initWithContentRect:NSMakeRect (0, 0, 460, 156)
+                                                    styleMask:NSWindowStyleMaskTitled
+                                                      backing:NSBackingStoreBuffered
+                                                        defer:NO];
+        _progressPanel.releasedWhenClosed = NO;
+
+        NSView *content = [[NSView alloc] initWithFrame:_progressPanel.contentView.bounds];
+        content.translatesAutoresizingMaskIntoConstraints = NO;
+        _progressPanel.contentView = content;
+
+        _progressTitleLabel = [NSTextField labelWithString:@""];
+        _progressTitleLabel.translatesAutoresizingMaskIntoConstraints = NO;
+        _progressTitleLabel.font = [NSFont systemFontOfSize:14 weight:NSFontWeightSemibold];
+        [content addSubview:_progressTitleLabel];
+
+        _progressDetailLabel = [NSTextField labelWithString:@""];
+        _progressDetailLabel.translatesAutoresizingMaskIntoConstraints = NO;
+        _progressDetailLabel.lineBreakMode = NSLineBreakByTruncatingMiddle;
+        [content addSubview:_progressDetailLabel];
+
+        _progressIndicator = [[NSProgressIndicator alloc] init];
+        _progressIndicator.translatesAutoresizingMaskIntoConstraints = NO;
+        _progressIndicator.style = NSProgressIndicatorStyleBar;
+        _progressIndicator.indeterminate = NO;
+        _progressIndicator.minValue = 0.0;
+        [content addSubview:_progressIndicator];
+
+        _progressCancelButton = [NSButton buttonWithTitle:@"Cancel"
+                                                   target:self
+                                                   action:@selector (cancelUpdate:)];
+        _progressCancelButton.translatesAutoresizingMaskIntoConstraints = NO;
+        [content addSubview:_progressCancelButton];
+
+        [NSLayoutConstraint activateConstraints:@[
+            [_progressTitleLabel.topAnchor constraintEqualToAnchor:content.topAnchor constant:16],
+            [_progressTitleLabel.leadingAnchor constraintEqualToAnchor:content.leadingAnchor constant:18],
+            [_progressTitleLabel.trailingAnchor constraintEqualToAnchor:content.trailingAnchor constant:-18],
+            [_progressDetailLabel.topAnchor constraintEqualToAnchor:_progressTitleLabel.bottomAnchor constant:8],
+            [_progressDetailLabel.leadingAnchor constraintEqualToAnchor:_progressTitleLabel.leadingAnchor],
+            [_progressDetailLabel.trailingAnchor constraintEqualToAnchor:_progressTitleLabel.trailingAnchor],
+            [_progressIndicator.topAnchor constraintEqualToAnchor:_progressDetailLabel.bottomAnchor constant:14],
+            [_progressIndicator.leadingAnchor constraintEqualToAnchor:_progressTitleLabel.leadingAnchor],
+            [_progressIndicator.trailingAnchor constraintEqualToAnchor:_progressTitleLabel.trailingAnchor],
+            [_progressCancelButton.topAnchor constraintEqualToAnchor:_progressIndicator.bottomAnchor constant:16],
+            [_progressCancelButton.trailingAnchor constraintEqualToAnchor:_progressTitleLabel.trailingAnchor],
+        ]];
+    }
+
+    _progressPanel.title = @"Software Update";
+    _progressTitleLabel.stringValue = [NSString stringWithFormat:@"Downloading Shenzhen Files %@",
+                                                                 tag ?: @""];
+    _progressDetailLabel.stringValue = @"Starting…";
+    _progressIndicator.indeterminate = (assetSize <= 0);
+    _progressIndicator.minValue = 0.0;
+    _progressIndicator.maxValue = MAX (1.0, (double) assetSize);
+    _progressIndicator.doubleValue = 0.0;
+    _progressCancelButton.enabled = YES;
+    if (_progressIndicator.indeterminate)
+    {
+        [_progressIndicator startAnimation:nil];
+    }
+    else
+    {
+        [_progressIndicator stopAnimation:nil];
+    }
+    [_progressPanel center];
+    [_progressPanel makeKeyAndOrderFront:nil];
+}
+
+- (void) updateProgress: (double) written total: (double) total
+{
+    if (!_progressPanel || _progressIndicator.indeterminate)
+    {
+        return;
+    }
+    _progressIndicator.doubleValue = written;
+    double mbW = written / (1024.0 * 1024.0);
+    double mbT = total / (1024.0 * 1024.0);
+    _progressDetailLabel.stringValue = [NSString stringWithFormat:@"%.1f MB of %.1f MB", mbW, mbT];
+}
+
+- (void) setProgressIndeterminateOnMain: (NSString *) detail
+{
+    dispatch_async (dispatch_get_main_queue (), ^{
+        if (!self->_progressPanel)
+        {
+            return;
+        }
+        self->_progressIndicator.indeterminate = YES;
+        [self->_progressIndicator startAnimation:nil];
+        self->_progressDetailLabel.stringValue = detail ?: @"";
+    });
+}
+
+- (void) dismissProgressOnMain
+{
+    dispatch_async (dispatch_get_main_queue (), ^{
+        [self->_progressPanel orderOut:nil];
+    });
+}
+
+- (void) cancelUpdate: (id) sender
+{
+    (void) sender;
+    _userCancelled = YES;
+    [_downloadTask cancel];
+    [_progressPanel orderOut:nil];
+}
+
+- (BOOL) confirmInstallNow
+{
+    NSAlert *alert = [[NSAlert alloc] init];
+    alert.messageText = @"Shenzhen Files will close all windows and reopen to finish updating.";
+    alert.informativeText = @"";
+    [alert addButtonWithTitle:@"Install Now"];
+    [alert addButtonWithTitle:@"Cancel"];
+    return [alert runModal] == NSAlertFirstButtonReturn;
+}
+
+/* ----- UI: simple alerts --------------------------------------------------------------- */
+
+- (void) showUpToDate
+{
+    NSString *version = [self runningVersion] ?: @"";
+    dispatch_async (dispatch_get_main_queue (), ^{
+        NSAlert *alert = [[NSAlert alloc] init];
+        alert.messageText = @"You're up to date.";
+        alert.informativeText = [NSString stringWithFormat:
+                                 @"Shenzhen Files %@ is the latest version.", version];
+        [alert runModal];
+    });
+}
+
+- (void) showErrorOnMain: (NSString *) detail
+{
+    dispatch_async (dispatch_get_main_queue (), ^{
+        NSAlert *alert = [[NSAlert alloc] init];
+        alert.messageText = @"Software Update";
+        alert.informativeText = detail ?: @"";
+        [alert runModal];
+    });
+}
+
+- (void) showInfoOnMain: (NSString *) message detail: (NSString *) detail
+{
+    dispatch_async (dispatch_get_main_queue (), ^{
+        NSAlert *alert = [[NSAlert alloc] init];
+        alert.messageText = message ?: @"";
+        alert.informativeText = detail ?: @"";
+        [alert runModal];
+    });
+}
+
+@end
+
+/* ---------------------------------------------------------------------------
+ * C entry points (bridge API)
+ * ------------------------------------------------------------------------- */
+
+void
+nautilus_macos_updater_startup (void)
+{
+    @autoreleasepool
+    {
+        SZFUpdater *updater = [SZFUpdater shared];
+        [updater consumePendingUpdateMarkerAndSweep];
+        [updater scheduleDailyUpdateCheckIfNeeded];
+        [updater armRecurringUpdateCheck];
+    }
+}
+
+void
+nautilus_macos_updater_check_interactive (void)
+{
+    @autoreleasepool
+    {
+        [[SZFUpdater shared] checkForUpdatesUserInitiated:YES];
+    }
+}
