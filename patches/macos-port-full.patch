+/* macOS pasteboard interop.
+ *
+ * GTK's macOS backend maps the "text/uri-list" mime type to the
+ * public.file-url / public.url pasteboard types and exports the serialized
+ * bytes verbatim as the URL data (gdk/macos/gdkmacospasteboard.c).  AppKit
+ * expects the data of a public.file-url item to be exactly one bare URL
+ * string, but GTK's stock text/uri-list serializer terminates every URI
+ * with CRLF (RFC 2483), so Finder reads a URL with a trailing "%0D%0A" and
+ * rejects the drag.  Since GTK 4.20 the last registered serializer for a
+ * mime type wins, so we override it with one that emits no trailing CRLF:
+ * single-file drags to Finder then work.  Multiple URIs still cannot be
+ * represented in the single pasteboard item GTK puts on the drag session;
+ * we keep them CRLF-joined so GTK-based readers keep working.
+ */
+static void
+macos_file_uri_serializer_finish (GObject      *source,
+                                  GAsyncResult *result,
+                                  gpointer      serializer)
+{
+    GError *error = NULL;
+
+    if (!g_output_stream_write_all_finish (G_OUTPUT_STREAM (source), result, NULL, &error))
+    {
+        gdk_content_serializer_return_error (serializer, error);
+    }
+    else
+    {
+        gdk_content_serializer_return_success (serializer);
+    }
+}
+
+static void
+macos_file_uri_serializer (GdkContentSerializer *serializer)
+{
+    const GValue *value = gdk_content_serializer_get_value (serializer);
+    GString *str = g_string_new (NULL);
+
+    if (G_VALUE_HOLDS (value, G_TYPE_FILE))
+    {
+        GFile *file = g_value_get_object (value);
+
+        if (file != NULL)
+        {
+            g_autofree char *uri = g_file_get_uri (file);
+            g_string_append (str, uri);
+        }
+    }
+    else if (G_VALUE_HOLDS (value, GDK_TYPE_FILE_LIST))
+    {
+        for (GSList *l = g_value_get_boxed (value); l != NULL; l = l->next)
+        {
+            g_autofree char *uri = g_file_get_uri (l->data);
+
+            if (str->len > 0)
+            {
+                g_string_append (str, "\r\n");
+            }
+            g_string_append (str, uri);
+        }
+    }
+
+    g_output_stream_write_all_async (gdk_content_serializer_get_output_stream (serializer),
+                                     str->str,
+                                     str->len,
+                                     gdk_content_serializer_get_priority (serializer),
+                                     gdk_content_serializer_get_cancellable (serializer),
+                                     macos_file_uri_serializer_finish,
+                                     serializer);
+    gdk_content_serializer_set_task_data (serializer, g_string_free (str, FALSE), g_free);
+}
+
+/* GTK ≤ 4.22's macOS backend builds the text/uri-list for a drop coming
+ * from another application by percent-encoding the whole "file://<path>"
+ * string with URLPathAllowedCharacterSet (gdkmacospasteboard.c,
+ * _gdk_macos_pasteboard_read_async), which also encodes the scheme colon.
+ * The resulting "file%3A///..." URIs are unparseable for GLib, so every
+ * GFile dropped in from Finder has a NULL path.  Detect that exact shape
+ * and undo the single encoding pass; the remainder after "file://" is the
+ * raw path, so any percent sequence in the real file name survives.
+ */
+static GFile *
+file_for_dropped_uri (const char *uri)
+{
+    if (g_ascii_strncasecmp (uri, "file%3a//", strlen ("file%3a//")) == 0)
+    {
+        g_autofree char *unescaped = g_uri_unescape_string (uri, NULL);
+
+        if (unescaped != NULL && g_str_has_prefix (unescaped, "file://"))
+        {
+            return g_file_new_for_path (unescaped + strlen ("file://"));
+        }
+    }
+
+    return g_file_new_for_uri (uri);
+}
+
+static GFile *
+file_with_repaired_uri (GFile *file)
+{
+    g_autofree char *uri = NULL;
+
+    if (g_file_peek_path (file) != NULL)
+    {
+        return g_object_ref (file);
+    }
+
+    uri = g_file_get_uri (file);
+
+    return file_for_dropped_uri (uri);
+}
+
+/* Deserializer override for cross-application drops (in-app drags transfer
+ * the GValue directly and never hit this path).  Same logic as GTK's stock
+ * file_uri_deserializer, plus the URI repair above.  Registered last, so it
+ * wins the lookup and fixes drops for every drop target in the process,
+ * including the sidebar and path bar.
+ */
+static void
+macos_file_uri_deserializer_finish (GObject      *source,
+                                    GAsyncResult *result,
+                                    gpointer      deserializer)
+{
+    GOutputStream *stream = G_OUTPUT_STREAM (source);
+    GError *error = NULL;
+    g_autofree char *str = NULL;
+    g_auto (GStrv) uris = NULL;
+    GValue *value;
+
+    if (g_output_stream_splice_finish (stream, result, &error) < 0)
+    {
+        gdk_content_deserializer_return_error (deserializer, error);
+        return;
+    }
+
+    if (g_output_stream_write (stream, "", 1, NULL, &error) < 0 ||
+        !g_output_stream_close (stream, NULL, &error))
+    {
+        gdk_content_deserializer_return_error (deserializer, error);
+        return;
+    }
+
+    str = g_memory_output_stream_steal_data (G_MEMORY_OUTPUT_STREAM (stream));
+    uris = g_uri_list_extract_uris (str);
+
+    value = gdk_content_deserializer_get_value (deserializer);
+    if (G_VALUE_HOLDS (value, G_TYPE_FILE))
+    {
+        if (uris[0] != NULL)
+        {
+            g_value_take_object (value, file_for_dropped_uri (uris[0]));
+        }
+    }
+    else
+    {
+        GSList *l = NULL;
+
+        for (gsize i = 0; uris[i] != NULL; i++)
+        {
+            l = g_slist_prepend (l, file_for_dropped_uri (uris[i]));
+        }
+
+        g_value_take_boxed (value, g_slist_reverse (l));
+    }
+
+    gdk_content_deserializer_return_success (deserializer);
+}
+
+static void
+macos_file_uri_deserializer (GdkContentDeserializer *deserializer)
+{
+    g_autoptr (GOutputStream) output = g_memory_output_stream_new_resizable ();
+
+    g_output_stream_splice_async (output,
+                                  gdk_content_deserializer_get_input_stream (deserializer),
+                                  G_OUTPUT_STREAM_SPLICE_CLOSE_SOURCE,
+                                  gdk_content_deserializer_get_priority (deserializer),
+                                  gdk_content_deserializer_get_cancellable (deserializer),
+                                  macos_file_uri_deserializer_finish,
+                                  deserializer);
+}
+
+/* Multi-file drag-out augmentation.
+ *
+ * GTK's macOS drag puts a SINGLE NSPasteboardItem on the drag pasteboard
+ * (gdkmacosdrag.c, _gdk_macos_drag_begin), while AppKit's convention is one
+ * item per file, so Finder only ever sees one file no matter how many are
+ * dragged.  We cannot add items to the session from here, but we CAN add
+ * the legacy pasteboard-level NSFilenamesPboardType property list once the
+ * session owns the pasteboard: AppKit's compatibility shim then re-exposes
+ * it as one public.file-url item per file (verified: readObjects(NSURL)
+ * returns every file, and the shim even repairs the first item's URL data).
+ *
+ * Implemented with objc_msgSend via dlsym so this stays a plain C file with
+ * no new link-time dependencies: AppKit and libobjc are always loaded in a
+ * GTK4-macOS process.  Scheduled from an idle because the NSDraggingSession
+ * begins synchronously right after GtkDragSource::prepare returns; the idle
+ * runs once the session has claimed the drag pasteboard.
+ */
+typedef void *NautilusObjcId;
+typedef void *NautilusObjcSel;
+typedef NautilusObjcId (*NautilusObjcGetClassFunc) (const char *);
+typedef NautilusObjcSel (*NautilusSelRegisterNameFunc) (const char *);
+typedef NautilusObjcId (*NautilusMsgSendIdCstrFunc) (NautilusObjcId, NautilusObjcSel, const char *);
+typedef NautilusObjcId (*NautilusMsgSendIdIdFunc) (NautilusObjcId, NautilusObjcSel, NautilusObjcId);
+typedef NautilusObjcId (*NautilusMsgSendIdFunc) (NautilusObjcId, NautilusObjcSel);
+typedef void (*NautilusMsgSendVoidIdFunc) (NautilusObjcId, NautilusObjcSel, NautilusObjcId);
+typedef long (*NautilusMsgSendLongIdIdFunc) (NautilusObjcId, NautilusObjcSel, NautilusObjcId, NautilusObjcId);
+typedef signed char (*NautilusMsgSendBoolIdIdFunc) (NautilusObjcId, NautilusObjcSel, NautilusObjcId, NautilusObjcId);
+
+static gboolean
+drag_pasteboard_add_filenames (GStrv paths)
+{
+    static NautilusObjcGetClassFunc objc_get_class;
+    static NautilusSelRegisterNameFunc sel_register_name;
+    static void *msg_send;
+    NautilusObjcId nsstring;
+    NautilusObjcId nsmutablearray;
+    NautilusObjcId nspasteboard;
+    NautilusObjcSel string_with_utf8;
+    NautilusObjcSel add_object;
+    NautilusObjcId pasteboard;
+    NautilusObjcId array;
+    NautilusObjcId type;
+    NautilusObjcId types;
+
+    if (msg_send == NULL)
+    {
+        objc_get_class = (NautilusObjcGetClassFunc) dlsym (RTLD_DEFAULT, "objc_getClass");
+        sel_register_name = (NautilusSelRegisterNameFunc) dlsym (RTLD_DEFAULT, "sel_registerName");
+        msg_send = dlsym (RTLD_DEFAULT, "objc_msgSend");
+    }
+    if (objc_get_class == NULL || sel_register_name == NULL || msg_send == NULL)
+    {
+        return FALSE;
+    }
+
+    nsstring = objc_get_class ("NSString");
+    nsmutablearray = objc_get_class ("NSMutableArray");
+    nspasteboard = objc_get_class ("NSPasteboard");
+    if (nsstring == NULL || nsmutablearray == NULL || nspasteboard == NULL)
+    {
+        return FALSE;
+    }
+
+    string_with_utf8 = sel_register_name ("stringWithUTF8String:");
+    add_object = sel_register_name ("addObject:");
+
+    /* +[NSPasteboard pasteboardWithName:NSPasteboardNameDrag] */
+    pasteboard = ((NautilusMsgSendIdIdFunc) msg_send) (
+        nspasteboard,
+        sel_register_name ("pasteboardWithName:"),
+        ((NautilusMsgSendIdCstrFunc) msg_send) (nsstring, string_with_utf8,
+                                                "Apple CFPasteboard drag"));
+    if (pasteboard == NULL)
+    {
+        return FALSE;
+    }
+
+    array = ((NautilusMsgSendIdFunc) msg_send) (nsmutablearray,
+                                                sel_register_name ("array"));
+    for (gsize i = 0; paths[i] != NULL; i++)
+    {
+        NautilusObjcId s = ((NautilusMsgSendIdCstrFunc) msg_send) (nsstring,
+                                                                   string_with_utf8,
+                                                                   paths[i]);
+
+        if (s != NULL)
+        {
+            ((NautilusMsgSendVoidIdFunc) msg_send) (array, add_object, s);
+        }
+    }
+
+    type = ((NautilusMsgSendIdCstrFunc) msg_send) (nsstring, string_with_utf8,
+                                                   "NSFilenamesPboardType");
+    types = ((NautilusMsgSendIdIdFunc) msg_send) (nsmutablearray,
+                                                  sel_register_name ("arrayWithObject:"),
+                                                  type);
+
+    ((NautilusMsgSendLongIdIdFunc) msg_send) (pasteboard,
+                                              sel_register_name ("addTypes:owner:"),
+                                              types, NULL);
+
+    return ((NautilusMsgSendBoolIdIdFunc) msg_send) (pasteboard,
+                                                     sel_register_name ("setPropertyList:forType:"),
+                                                     array, type);
+}
+
+static gboolean
+augment_drag_pasteboard_idle (gpointer data)
+{
+    GStrv paths = data;
+
+    if (!drag_pasteboard_add_filenames (paths))
+    {
+        g_debug ("nautilus-dnd: failed to augment drag pasteboard with file names");
+    }
+
+    return G_SOURCE_REMOVE;
+}
+
+static void
+schedule_drag_pasteboard_augmentation (GList *selection)
+{
+    g_autoptr (GStrvBuilder) builder = g_strv_builder_new ();
+    GStrv paths;
+    guint n_paths = 0;
+
+    for (GList *l = selection; l != NULL; l = l->next)
+    {
+        g_autoptr (GFile) location = nautilus_file_get_activation_location (l->data);
+        g_autofree char *path = g_file_get_path (location);
+
+        if (path == NULL)
+        {
+            /* Non-native file: Finder can't use it, and a partial legacy
+             * list would misrepresent the drag.  Leave GTK's item alone. */
+            return;
+        }
+
+        g_strv_builder_add (builder, path);
+        n_paths++;
+    }
+
+    if (n_paths == 0)
+    {
+        return;
+    }
+
+    paths = g_strv_builder_end (builder);
+    g_idle_add_full (G_PRIORITY_DEFAULT_IDLE,
+                     augment_drag_pasteboard_idle,
+                     paths,
+                     (GDestroyNotify) g_strfreev);
+}
+
+void
+nautilus_dnd_init_macos (void)
+{
+    static gsize registered = 0;
+
+    if (g_once_init_enter (&registered))
+    {
+        /* Must run after gtk_init(): GDK registers its built-in
+         * (de)serializers there, and the last registration for a mime type
+         * wins.  Called lazily from the DnD entry points below; a startup
+         * call would additionally cover the first-ever Finder drop for
+         * drop targets outside this file. */
+        gdk_content_register_serializer (G_TYPE_FILE, "text/uri-list",
+                                         macos_file_uri_serializer, NULL, NULL);
+        gdk_content_register_serializer (GDK_TYPE_FILE_LIST, "text/uri-list",
+                                         macos_file_uri_serializer, NULL, NULL);
+        gdk_content_register_deserializer ("text/uri-list", GDK_TYPE_FILE_LIST,
+                                           macos_file_uri_deserializer, NULL, NULL);
+        gdk_content_register_deserializer ("text/uri-list", G_TYPE_FILE,
+                                           macos_file_uri_deserializer, NULL, NULL);
+
+        g_once_init_leave (&registered, 1);
+    }
+}
