+    /* Cell binding runs on the GTK main thread, which is the AppKit main
+     * thread on the macOS backend, so the bridge may call NSWorkspace
+     * directly (it returns NULL off-main as a safety net). */
+    g_autoptr (GdkTexture) texture = nautilus_macos_file_icon_texture (path, size * scale);
+
+    if (texture == NULL)
+    {
+        return NULL;
+    }
+
+    /* The texture holds size×scale DEVICE pixels, but a GdkTexture's
+     * intrinsic size is its pixel size and consumers (NautilusImage's
+     * fallback path, DnD icons, …) treat intrinsic size as LOGICAL points,
+     * so returning it directly renders the icon scale× oversized on HiDPI.
+     * Do what the thumbnail path above does: snapshot the texture into a
+     * size×size logical box and return that paintable — GSK still samples
+     * the full-resolution texture when rendering at the monitor scale. */
+    g_autoptr (GtkSnapshot) snapshot = gtk_snapshot_new ();
+
+    gdk_paintable_snapshot (GDK_PAINTABLE (texture),
+                            GDK_SNAPSHOT (snapshot),
+                            size, size);
+
+    return gtk_snapshot_to_paintable (snapshot, NULL);
