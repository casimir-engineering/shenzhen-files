+/* ==========================================================================
+ * macOS native menu bar (Phase 3 task 1)
+ *
+ * GTK4's macOS backend renders gtk_application_set_menubar() as the native
+ * NSMenu bar (gtk/gtkapplication-quartz-menu.c). The application menu
+ * (About / Preferences / Services / Hide / Quit) is built automatically by
+ * GTK from its own template and wires app.about and app.preferences, both
+ * of which Nautilus provides, so only File/Edit/View/Go/Window/Help are
+ * built here.
+ *
+ * Dispatch notes (verified against GTK 4.22 sources):
+ *   - Menu items activate through the *focused* widget's action muxer
+ *     (GNSMenuItem didSelectItem), so widget-scoped groups ("view",
+ *     "slot" — both inserted on the window) resolve fine, and items grey
+ *     out automatically via validateMenuItem.
+ *   - An "accel" attribute becomes the NSMenuItem key equivalent, which
+ *     AppKit intercepts *before* GTK sees the key event. Items whose
+ *     combos must keep working inside text entries (Cmd-X/C/V/A/Z, Cmd-Up)
+ *     therefore carry *no* accel attribute; their keys are bound in a
+ *     bubble-phase shortcut controller per window (macos_setup_window()),
+ *     where focused text widgets get first pick.
+ * ========================================================================== */
+
+static void
+macos_menu_append (GMenu      *menu,
+                   const char *label,
+                   const char *detailed_action,
+                   const char *accel)
+{
+    g_autoptr (GMenuItem) item = g_menu_item_new (label, detailed_action);
+
+    if (accel != NULL)
+    {
+        g_menu_item_set_attribute (item, "accel", "s", accel);
+    }
+
+    g_menu_append_item (menu, item);
+}
+
+static void
+macos_menu_append_with_target (GMenu      *menu,
+                               const char *label,
+                               const char *action,
+                               GVariant   *target,
+                               const char *accel)
+{
+    g_autoptr (GMenuItem) item = g_menu_item_new (label, NULL);
+
+    g_menu_item_set_action_and_target_value (item, action, target);
+    if (accel != NULL)
+    {
+        g_menu_item_set_attribute (item, "accel", "s", accel);
+    }
+
+    g_menu_append_item (menu, item);
+}
+
+static GMenuModel *
+macos_build_file_menu (void)
+{
+    GMenu *menu = g_menu_new ();
+    g_autoptr (GMenu) new_section = g_menu_new ();
+    g_autoptr (GMenu) open_section = g_menu_new ();
+    g_autoptr (GMenu) info_section = g_menu_new ();
+    g_autoptr (GMenu) search_section = g_menu_new ();
+    g_autoptr (GMenu) close_section = g_menu_new ();
+
+    /* app.clone-window displays Cmd-N automatically via its remapped
+     * application accelerator (registered before the menubar is built).
+     * The win.* accelerators are registered when the first window is
+     * created — after the NSMenu items exist and too late for the quartz
+     * backend to pick up — so those items carry explicit accel attributes
+     * matching the remapped registrations. */
+    macos_menu_append (new_section, _("New Window"), "app.clone-window", NULL);
+    macos_menu_append (new_section, _("New Tab"), "win.new-tab", "<Meta>t");
+    macos_menu_append (new_section, _("New Folder"), "view.new-folder", "<Meta><Shift>n");
+
+    macos_menu_append (open_section, _("Open"), "view.open-with-default-application", "<Meta>o");
+    macos_menu_append (open_section, _("Open in New Tab"), "view.open-item-new-tab", NULL);
+    macos_menu_append (open_section, _("Open in New Window"), "view.open-item-new-window", NULL);
+
+    macos_menu_append (info_section, _("Get Info"), "view.properties", "<Meta>i");
+    macos_menu_append (info_section, _("Rename…"), "view.rename", "F2");
+
+    macos_menu_append (search_section, _("Find"), "slot.focus-search", "<Meta>f");
+    macos_menu_append (search_section, _("Search Everywhere"), "slot.search-global", "<Meta><Shift>f");
+
+    /* Cmd-W (via remapped win.close-current-view accel) closes the current
+     * tab, falling back to closing the window on the last tab — matching
+     * Finder-with-tabs behavior. */
+    macos_menu_append (close_section, _("Close Tab"), "win.close-current-view", "<Meta>w");
+    macos_menu_append (close_section, _("Close Window"), "window.close", "<Meta><Shift>w");
+
+    g_menu_append_section (menu, NULL, G_MENU_MODEL (new_section));
+    g_menu_append_section (menu, NULL, G_MENU_MODEL (open_section));
+    g_menu_append_section (menu, NULL, G_MENU_MODEL (info_section));
+    g_menu_append_section (menu, NULL, G_MENU_MODEL (search_section));
+    g_menu_append_section (menu, NULL, G_MENU_MODEL (close_section));
+
+    return G_MENU_MODEL (menu);
+}
