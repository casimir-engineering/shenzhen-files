diff --git a/src/nautilus-search-engine-spotlight.c b/src/nautilus-search-engine-spotlight.c
new file mode 100644
index 0000000..964bbbd
--- /dev/null
+++ b/src/nautilus-search-engine-spotlight.c
@@ -0,0 +1,394 @@
+/*
+ * nautilus-search-engine-spotlight.c: Spotlight search provider (W4).
+ *
+ * Copyright (C) 2026 The Nautilus authors
+ *
+ * This program is free software; you can redistribute it and/or
+ * modify it under the terms of the GNU General Public License as
+ * published by the Free Software Foundation; either version 2 of the
+ * License, or (at your option) any later version.
+ *
+ * This program is distributed in the hope that it will be useful,
+ * but WITHOUT ANY WARRANTY; without even the implied warranty of
+ * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU
+ * General Public License for more details.
+ *
+ * You should have received a copy of the GNU General Public
+ * License along with this program; if not, see <http://www.gnu.org/licenses/>.
+ *
+ * A NautilusSearchProvider backed by Spotlight (NSMetadataQuery) through
+ * the C seam in nautilus-macos-bridge.h. It runs alongside the simple
+ * engine; NautilusSearchEngine dedups hits by URI, so whichever provider
+ * reports a file first wins and the other's duplicate is dropped.
+ *
+ * Scope/recursion decision: Spotlight is inherently recursive, so this
+ * provider only handles recursive queries (should_search rejects
+ * non-recursive ones and the single-level scan is left entirely to the
+ * simple engine).
+ */
+#define G_LOG_DOMAIN "nautilus-search"
+
+#include <config.h>
+#include "nautilus-search-engine-spotlight.h"
+
+#include "nautilus-macos-bridge.h"
+#include "nautilus-query.h"
+#include "nautilus-search-hit.h"
+#include "nautilus-search-provider.h"
+#include "nautilus-ui-utilities.h"
+
+#include <glib.h>
+#include <gio/gio.h>
+
+struct _NautilusSearchEngineSpotlight
+{
+    NautilusSearchProvider parent_instance;
+
+    /* Non-NULL while a bridge query is running. */
+    NautilusMacosSpotlightQuery *query_handle;
+    GFile *scope_location;
+
+    guint flush_idle_id;
+};
+
+G_DEFINE_FINAL_TYPE (NautilusSearchEngineSpotlight,
+                     nautilus_search_engine_spotlight,
+                     NAUTILUS_TYPE_SEARCH_PROVIDER)
+
+static void
+finalize (GObject *object)
+{
+    NautilusSearchEngineSpotlight *self = NAUTILUS_SEARCH_ENGINE_SPOTLIGHT (object);
+
+    /* The bridge query holds a borrowed pointer to self; it must have been
+     * stopped (and its finished callback delivered) before the provider is
+     * released. */
+    g_warn_if_fail (self->query_handle == NULL);
+
+    g_clear_handle_id (&self->flush_idle_id, g_source_remove);
+    g_clear_object (&self->scope_location);
+
+    G_OBJECT_CLASS (nautilus_search_engine_spotlight_parent_class)->finalize (object);
+}
+
+/* Mirrors the simple engine's hidden/backup filter: a hit is skipped when
+ * any path component below the search root is hidden (dot-prefixed) or a
+ * backup file (trailing '~'), because simple neither reports such entries
+ * nor descends into them. Spotlight rarely indexes hidden files at all;
+ * this keeps the two providers consistent when it does. */
+static gboolean
+relative_path_is_hidden_or_backup (const char *relative_path)
+{
+    g_auto (GStrv) components = g_strsplit (relative_path, G_DIR_SEPARATOR_S, -1);
+
+    for (guint i = 0; components[i] != NULL; i++)
+    {
+        if (components[i][0] == '.' ||
+            g_str_has_suffix (components[i], "~"))
+        {
+            return TRUE;
+        }
+    }
+
+    return FALSE;
+}
+
+static gboolean
+matches_date_range (NautilusQuery *query,
+                    GDateTime     *mtime,
+                    GDateTime     *atime,
+                    GDateTime     *ctime)
+{
+    g_autoptr (GPtrArray) date_range = nautilus_query_get_date_range (query);
+
+    if (date_range == NULL)
+    {
+        return TRUE;
+    }
+
+    GDateTime *target_date;
+
+    switch (nautilus_query_get_search_type (query))
+    {
+        case NAUTILUS_SEARCH_TIME_TYPE_LAST_ACCESS:
+        {
+            target_date = atime;
+        }
+        break;
+
+        case NAUTILUS_SEARCH_TIME_TYPE_LAST_MODIFIED:
+        {
+            target_date = mtime;
+        }
+        break;
+
+        case NAUTILUS_SEARCH_TIME_TYPE_CREATED:
+        {
+            target_date = ctime;
+        }
+        break;
+
+        default:
+        {
+            target_date = NULL;
+        }
+    }
+
+    return nautilus_date_time_is_between_dates (target_date,
+                                                g_ptr_array_index (date_range, 0),
+                                                g_ptr_array_index (date_range, 1));
+}
+
+static gboolean
+matches_mime_types (NautilusQuery *query,
+                    GFile         *file,
+                    GCancellable  *cancellable)
+{
+    if (!nautilus_query_has_mime_types (query))
+    {
+        return TRUE;
+    }
+
+    /* Only queries with an active MIME filter pay for this extra stat. */
+    g_autoptr (GFileInfo) info = g_file_query_info (
+        file,
+        G_FILE_ATTRIBUTE_STANDARD_CONTENT_TYPE ","
+        G_FILE_ATTRIBUTE_STANDARD_FAST_CONTENT_TYPE,
+        G_FILE_QUERY_INFO_NOFOLLOW_SYMLINKS,
+        cancellable, NULL);
+
+    if (info == NULL)
+    {
+        return FALSE;
+    }
+
+    const char *mime_type = g_file_info_get_attribute_string (
+        info, G_FILE_ATTRIBUTE_STANDARD_CONTENT_TYPE);
+
+    if (mime_type == NULL)
+    {
+        mime_type = g_file_info_get_attribute_string (
+            info, G_FILE_ATTRIBUTE_STANDARD_FAST_CONTENT_TYPE);
+    }
+
+    return nautilus_query_matches_mime_type (query, mime_type);
+}
+
+static GDateTime *
+date_time_from_unix (gint64 unix_time)
+{
+    return (unix_time != 0) ? g_date_time_new_from_unix_local (unix_time) : NULL;
+}
+
+/* Spotlight delivers hits in bursts (one idle per gathering notification),
+ * with potentially long gaps in between. Flushing from a one-shot idle
+ * queued behind the bridge's delivery idle pushes each complete burst to
+ * the UI immediately, instead of letting hits sit until the next burst. */
+static gboolean
+flush_hits_idle_cb (gpointer user_data)
+{
+    NautilusSearchEngineSpotlight *self = user_data;
+
+    self->flush_idle_id = 0;
+    nautilus_search_provider_flush_hits (self);
+
+    return G_SOURCE_REMOVE;
+}
+
+/* Bridge hit callback; GLib main thread. */
+static void
+spotlight_hit_cb (const char *path,
+                  gint64      mtime_unix,
+                  gint64      atime_unix,
+                  gint64      ctime_unix,
+                  gpointer    user_data)
+{
+    NautilusSearchEngineSpotlight *self = user_data;
+    NautilusQuery *query = nautilus_search_provider_get_query (self);
+    GCancellable *cancellable = nautilus_search_provider_get_cancellable (self);
+
+    if (query == NULL || nautilus_search_provider_should_stop (self))
+    {
+        return;
+    }
+
+    g_autoptr (GFile) file = g_file_new_for_path (path);
+
+    /* NSMetadataQuery is scoped to the directory already; this guards
+     * against the scope directory itself and any stray out-of-scope
+     * result. */
+    if (self->scope_location == NULL ||
+        !g_file_has_prefix (file, self->scope_location))
+    {
+        return;
+    }
+
+    if (!nautilus_query_get_show_hidden_files (query))
+    {
+        g_autofree char *relative_path =
+            g_file_get_relative_path (self->scope_location, file);
+
+        if (relative_path == NULL ||
+            relative_path_is_hidden_or_backup (relative_path))
+        {
+            return;
+        }
+    }
+
+    /* Re-rank with Nautilus's own matcher so scores are comparable with
+     * (and hits a strict subset of) the simple engine's. Spotlight's
+     * case/diacritic-insensitive CONTAINS can occasionally accept a name
+     * this rejects; dropping such hits keeps the providers consistent. */
+    g_autofree char *display_name = g_filename_display_basename (path);
+    gdouble match = nautilus_query_matches_string (query, display_name);
+
+    if (match < 0)
+    {
+        return;
+    }
+
+    if (!matches_mime_types (query, file, cancellable))
+    {
+        return;
+    }
+
+    g_autoptr (GDateTime) mtime = date_time_from_unix (mtime_unix);
+    g_autoptr (GDateTime) atime = date_time_from_unix (atime_unix);
+    g_autoptr (GDateTime) ctime = date_time_from_unix (ctime_unix);
+
+    if (!matches_date_range (query, mtime, atime, ctime))
+    {
+        return;
+    }
+
+    g_autofree char *uri = g_file_get_uri (file);
+    NautilusSearchHit *hit = nautilus_search_hit_new (uri);
+
+    nautilus_search_hit_set_fts_rank (hit, match);
+    nautilus_search_hit_set_modification_time (hit, mtime);
+    nautilus_search_hit_set_access_time (hit, atime);
+    nautilus_search_hit_set_creation_time (hit, ctime);
+
+    nautilus_search_provider_add_hit (self, hit);
+
+    if (self->flush_idle_id == 0)
+    {
+        self->flush_idle_id = g_idle_add (flush_hits_idle_cb, self);
+    }
+}
+
+/* Bridge finished callback; GLib main thread. Fires exactly once per
+ * bridge query: either when gathering completes or from within
+ * nautilus_macos_spotlight_query_stop(). */
+static void
+spotlight_finished_cb (GError   *error,
+                       gpointer  user_data)
+{
+    NautilusSearchEngineSpotlight *self = user_data;
+    NautilusMacosSpotlightQuery *handle = g_steal_pointer (&self->query_handle);
+
+    if (error != NULL)
+    {
+        g_debug ("Spotlight query finished with error: %s", error->message);
+    }
+
+    /* Natural-finish path: release the bridge query (we do not consume the
+     * live-update phase). No-op when already called from within stop. */
+    nautilus_macos_spotlight_query_stop (handle);
+
+    /* provider_finished flushes any remaining hits itself. */
+    g_clear_handle_id (&self->flush_idle_id, g_source_remove);
+    g_clear_object (&self->scope_location);
+
+    nautilus_search_provider_finished (NAUTILUS_SEARCH_PROVIDER (self));
+}
+
+static const char *
+get_name (NautilusSearchProvider *provider)
+{
+    return "spotlight";
+}
+
+static gboolean
+should_search (NautilusSearchProvider *provider,
+               NautilusQuery          *query)
+{
+    g_autoptr (GFile) location = nautilus_query_get_location (query);
+    g_autofree char *text = nautilus_query_get_text (query);
+
+    /* Spotlight only searches the whole subtree; non-recursive queries are
+     * left to the simple engine's single-level scan. */
+    return location != NULL &&
+           g_file_is_native (location) &&
+           text != NULL &&
+           nautilus_query_recursive (query);
+}
+
+static void
+start_search (NautilusSearchProvider *provider)
+{
+    NautilusSearchEngineSpotlight *self = NAUTILUS_SEARCH_ENGINE_SPOTLIGHT (provider);
+    NautilusQuery *query = nautilus_search_provider_get_query (self);
+    g_autoptr (GFile) location = nautilus_query_get_location (query);
+    g_autofree char *text = nautilus_query_get_text (query);
+    g_autofree char *scope_path = g_file_get_path (location);
+
+    g_return_if_fail (self->query_handle == NULL);
+
+    if (scope_path == NULL)
+    {
+        nautilus_search_provider_finished (provider);
+        return;
+    }
+
+    g_set_object (&self->scope_location, location);
+
+    self->query_handle = nautilus_macos_spotlight_query_start (text,
+                                                               scope_path,
+                                                               spotlight_hit_cb,
+                                                               spotlight_finished_cb,
+                                                               self);
+
+    if (self->query_handle == NULL)
+    {
+        /* Backend unavailable; the simple engine runs in parallel and
+         * covers the query. */
+        g_clear_object (&self->scope_location);
+        nautilus_search_provider_finished (provider);
+    }
+}
+
+static void
+stop_search (NautilusSearchProvider *provider)
+{
+    NautilusSearchEngineSpotlight *self = NAUTILUS_SEARCH_ENGINE_SPOTLIGHT (provider);
+    NautilusMacosSpotlightQuery *handle = g_steal_pointer (&self->query_handle);
+
+    /* Delivers spotlight_finished_cb synchronously (which then sees
+     * query_handle == NULL and only finishes the provider). */
+    nautilus_macos_spotlight_query_stop (handle);
+}
+
+static void
+nautilus_search_engine_spotlight_class_init (NautilusSearchEngineSpotlightClass *class)
+{
+    GObjectClass *gobject_class = G_OBJECT_CLASS (class);
+    NautilusSearchProviderClass *search_provider_class = NAUTILUS_SEARCH_PROVIDER_CLASS (class);
+
+    gobject_class->finalize = finalize;
+    search_provider_class->get_name = get_name;
+    search_provider_class->should_search = should_search;
+    search_provider_class->start_search = start_search;
+    search_provider_class->stop_search = stop_search;
+}
+
+static void
+nautilus_search_engine_spotlight_init (NautilusSearchEngineSpotlight *self)
+{
+}
+
+NautilusSearchEngineSpotlight *
+nautilus_search_engine_spotlight_new (void)
+{
+    return g_object_new (NAUTILUS_TYPE_SEARCH_ENGINE_SPOTLIGHT, NULL);
+}
