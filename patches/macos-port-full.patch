+/* ==========================================================================
+ * Section W12 — Finder integration (nautilus-macos-integration.m)
+ *
+ * Fully OPT-IN, fully REVERSIBLE Finder-replacement integrations. All state
+ * (including pre-change system values, so revert restores the user's
+ * original configuration) lives in the keyfile
+ * $XDG_CONFIG_HOME/nautilus/macos-integration.ini.
+ *
+ * NOTHING here mutates system state at startup: apply/revert run only from
+ * the explicit preferences toggles / Revert All button. Launch-time-safe
+ * entry points are limited to status reads, the first-run-dialog gate and
+ * the passive NSServices provider registration.
+ *
+ * DRY-RUN: NAUTILUS_INTEGRATION_DRY_RUN=1 logs every system mutation
+ * ("DRY-RUN: …" via g_message) instead of executing it; keyfile/bookmarks
+ * bookkeeping inside $XDG_CONFIG_HOME still runs (harness support).
+ * NAUTILUS_INTEGRATION_MOCK_FAVORITES=<path> substitutes a plain-text file
+ * for the shared Finder favorites list (harness support).
+ * ========================================================================== */
+
+/* The three independent, individually-toggleable integrations. */
+typedef enum
+{
+    NAUTILUS_MACOS_INTEGRATION_DEFAULT_HANDLER,     /* public.folder default app */
+    NAUTILUS_MACOS_INTEGRATION_FAVORITES,           /* Finder sidebar favorites sync */
+    NAUTILUS_MACOS_INTEGRATION_HIDE_DESKTOP,        /* com.apple.finder CreateDesktop */
+} NautilusMacosIntegration;
+
+/* TRUE when NAUTILUS_INTEGRATION_DRY_RUN is set (see section comment). */
+gboolean nautilus_macos_integration_is_dry_run (void);
+
+/* Stored toggle state from the keyfile (what WE believe we enabled). */
+gboolean nautilus_macos_integration_get_enabled (NautilusMacosIntegration which);
+
+/* LIVE system status (default-handler: LaunchServices query; hide-desktop:
+ * com.apple.finder defaults read; favorites: recorded sync state). Always
+ * read-only. @detail (nullable) receives a human-readable status string,
+ * caller-owned. */
+gboolean nautilus_macos_integration_status (NautilusMacosIntegration   which,
+                                            char                     **detail);
+
+/* Apply / revert one integration. Records the pre-change system value
+ * before changing anything, so revert restores the user's original state.
+ * Both are user-gesture-only entry points (preferences toggles); they must
+ * never be called at startup. Return FALSE + @error with a user-showable
+ * message on failure (e.g. macOS 26 refusing the default-handler change). */
+gboolean nautilus_macos_integration_apply (NautilusMacosIntegration   which,
+                                           GError                   **error);
+gboolean nautilus_macos_integration_revert (NautilusMacosIntegration   which,
+                                            GError                   **error);
+
+/* Revert every integration that is currently enabled. Keeps going past
+ * individual failures; returns FALSE with the FIRST error if any failed. */
+gboolean nautilus_macos_integration_revert_all (GError **error);
+
+/* Read-only capability probe of the shared Finder favorites list
+ * (LSSharedFileList): lists the current favorites, touches nothing.
+ * Returns TRUE if the list is readable, with the item count in @out_count
+ * (nullable) and a report string in @out_detail (nullable, caller-owned). */
+gboolean nautilus_macos_integration_favorites_probe (guint  *out_count,
+                                                     char  **out_detail);
+
+/* One-time-ever first-run choice dialog gate ("integration-choice-made"
+ * keyfile flag). Callers must set the flag the moment they SCHEDULE the
+ * dialog — before it shows — so it can never re-prompt (same pattern as
+ * the FDA first-launch prompt). */
+gboolean nautilus_macos_integration_should_show_first_run_dialog (void);
+void nautilus_macos_integration_set_first_run_choice_made (void);
+
+/* Present the first-run AdwAlertDialog: "Use as a Standalone App" (default;
+ * does nothing) vs "Set Up Finder Integration…" (only opens the preferences
+ * page — nothing auto-applies; every toggle starts OFF). */
+void nautilus_macos_integration_show_first_run_dialog (GtkWindow *parent);
+
+/* Register the NSServices provider backing the "Open in Nautilus" service
+ * declared in Info.plist. Passive: changes nothing system-wide. Idempotent;
+ * call once at startup. */
+void nautilus_macos_integration_register_services_provider (void);
+
+/* Read-only capability probe for the DEFAULT_HANDLER integration: FALSE
+ * when this macOS forbids changing the public.folder default entirely
+ * (empirically macOS 26+: the NSWorkspace API returns paramErr with no
+ * consent dialog, the legacy LSSetDefaultRoleHandlerForContentType API
+ * returns -50 for every role, hand-written LSHandlers plist entries are
+ * ignored, and `lsregister -kill` has been removed from the OS). The UI
+ * must then render the toggle insensitive. @out_reason (nullable) receives
+ * a user-showable explanation when FALSE, caller-owned. Safe at startup. */
+gboolean nautilus_macos_integration_default_handler_supported (char **out_reason);
+
+/* Insert a native "Finder Integration…" NSMenuItem into the application
+ * (app-name) menu, right below "Check Permissions…" — same deferred,
+ * idempotent NSMenu insertion pattern (implemented in nautilus-macos-menu.m;
+ * declared here to keep the W1 section untouched). Activates the
+ * app.finder-integration GAction. */
+void nautilus_macos_menu_add_finder_integration_item (void);
+
+/* ==========================================================================
+ * End section W12
+ * ========================================================================== */
+
+/* ==========================================================================
+ * Section W13 — "Choose in Nautilus" Save/Open-panel handoff
+ * (nautilus-macos-savepanel-handoff.m)
+ *
+ * PROTOTYPE. Fully OPT-IN, off by default, gated by the Accessibility
+ * (AXIsProcessTrusted) permission the USER grants. When ARMED (the toggle
+ * is ON and Accessibility is granted), a system-wide hotkey (⌃⌥⌘G, Carbon
+ * RegisterEventHotKey) lets the user pick a destination folder in Nautilus
+ * while a native NSSavePanel/NSOpenPanel is frontmost in ANOTHER app;
+ * Nautilus then drives that panel to the chosen folder via the AX API
+ * (the panel's "Go to Folder" affordance). The user still completes
+ * Save/Open in the native panel — the sandbox/Powerbox model is preserved,
+ * this only NAVIGATES the panel.
+ *
+ * State keyfile: $XDG_CONFIG_HOME/nautilus/macos-integration.ini,
+ * [savepanel-handoff] group (shares the W12 integration keyfile).
+ *
+ * NOTHING here mutates state or arms the hotkey unless the stored toggle is
+ * ON: nautilus_macos_savepanel_handoff_init() reads the keyfile and arms
+ * only if enabled. Everything defaults to disarmed.
+ * ========================================================================== */
+
+/* Stored toggle state (keyfile). Default FALSE. */
+gboolean nautilus_macos_savepanel_handoff_get_enabled (void);
+
+/* Persist the toggle AND arm/disarm the hotkey to match. Safe to call from
+ * the preferences switch. When enabling without Accessibility granted, the
+ * toggle is still stored but the hotkey cannot fire until the permission is
+ * granted (see nautilus_macos_savepanel_handoff_accessibility_granted). */
+void nautilus_macos_savepanel_handoff_set_enabled (gboolean enabled);
+
+/* TRUE if this process is AX-trusted (AXIsProcessTrusted). Mirrors the FDA
+ * dev-vs-bundle caveat: TCC/AX check the RESPONSIBLE process, so a
+ * terminal/IDE-launched dev build reports the launcher's grant, not
+ * "Nautilus"'s. Truthful for the Finder/LaunchServices-launched .app. */
+gboolean nautilus_macos_savepanel_handoff_accessibility_granted (void);
+
+/* Open System Settings on Privacy & Security → Accessibility. */
+void nautilus_macos_savepanel_handoff_open_accessibility_settings (void);
+
+/* Launch-time entry point: if the stored toggle is ON, arm the hotkey;
+ * otherwise do nothing. Idempotent. Never arms when the toggle is OFF. */
+void nautilus_macos_savepanel_handoff_init (void);
+
+/* --- Testable core (no GTK dependency) ------------------------------------
+ * These are the pieces the hotkey path composes; exposed so a headless
+ * harness can exercise the AX mechanism against a target app directly. */
+
+/* PID of the frontmost application that currently has an Open/Save panel
+ * (window or attached sheet with AXIdentifier "save-panel"/"open-panel"),
+ * or 0 if none. Read-only. */
+int nautilus_macos_savepanel_find_frontmost_panel_pid (void);
+
+/* Drive the Open/Save panel owned by @target_pid to @target_path via AX:
+ * re-activate the target, expand the panel if collapsed, open "Go to
+ * Folder" (⌘⇧G), type the path, and commit with Return (guarded: Return is
+ * only sent when the Go-to-Folder field really holds focus, so the panel's
+ * default Save/Open button can never be triggered by mistake). On success
+ * returns TRUE and, if @out_evidence is non-NULL, a caller-owned
+ * human-readable string with the panel's post-navigation AX state (the
+ * "Where:" popup value / current directory). Returns FALSE + @error on
+ * failure (no panel, AX refused, permission not granted, …). */
+gboolean nautilus_macos_savepanel_drive (int          target_pid,
+                                         const char  *target_path,
+                                         char       **out_evidence,
+                                         GError     **error);
+
+/* ==========================================================================
+ * End section W13
+ * ========================================================================== */
+
+/* ==========================================================================
+ * Section W14 — Shenzhen Files self-updater (nautilus-macos-updater.m)
+ *
+ * GitHub-releases self-updater, ported from shenzhen-pdf's SPDFUpdater
+ * (see the file header in nautilus-macos-updater.m for the design and for
+ * the ad-hoc-signing trust-model divergence). All entry points no-op when
+ * the process is not the installed com.intuition.shenzhenfiles bundle.
+ * ========================================================================== */
+
+/* Startup hook: post-update health handshake (consume pendingTag, drop the
+ * retained .app.old, show the one-time success banner), then the silent
+ * daily check (flock'd 24h gate) and the hourly re-arm timer with
+ * day-change / wake catch-ups. Call once from application startup, after
+ * the AppKit side exists. */
+void nautilus_macos_updater_startup (void);
+
+/* User-initiated "Check for Updates…" path: bypasses the 24h gate, ignores
+ * Skip/Later, and surfaces both the up-to-date and failure states. */
+void nautilus_macos_updater_check_interactive (void);
+
+/* Foundation/AppKit-only swap/relaunch helper behind main()'s --post-update
+ * short-circuit. Runs from the OLD in-place binary: waits for app instances
+ * to exit, swaps the bundle with a move-aside two-rename, re-registers
+ * LaunchServices and relaunches. Returns a process exit code. */
+int nautilus_macos_updater_run_post_update_helper (const char *staged_app_path,
+                                                   const char *target_bundle_path);
+
+/* Insert a native "Check for Updates…" NSMenuItem into the application
+ * (app-name) menu, right below "Finder Integration…" — same deferred,
+ * idempotent NSMenu insertion pattern (implemented in nautilus-macos-menu.m).
+ * Invokes nautilus_macos_updater_check_interactive(). */
+void nautilus_macos_menu_add_check_updates_item (void);
+
+/* ==========================================================================
+ * End section W14
+ * ========================================================================== */
+
+G_END_DECLS
diff --git a/src/nautilus-macos-fda.m b/src/nautilus-macos-fda.m
new file mode 100644
index 0000000..c19a79e
--- /dev/null
+++ b/src/nautilus-macos-fda.m
@@ -0,0 +1,454 @@
+/*
+ * nautilus-macos-fda.m: Full Disk Access onboarding (W6).
+ *
+ * Copyright (C) 2026 The Nautilus authors
+ *
+ * This program is free software; you can redistribute it and/or
+ * modify it under the terms of the GNU General Public License as
+ * published by the Free Software Foundation; either version 2 of the
+ * License, or (at your option) any later version.
+ *
+ * This program is distributed in the hope that it will be useful,
+ * but WITHOUT ANY WARRANTY; without even the implied warranty of
+ * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU
+ * General Public License for more details.
+ *
+ * You should have received a copy of the GNU General Public
+ * License along with this program; if not, see <http://www.gnu.org/licenses/>.
+ *
+ * Why Nautilus wants Full Disk Access (FDA): browsing ~/.Trash is
+ * TCC-blocked without it (PLAN.md §5 Phase 3 task 2), and FDA also unlocks
+ * Desktop/Documents/Downloads without per-folder permission popups, plus
+ * unrestricted search. The flow mirrors shenzhen-pdf
+ * (portable/mac/ShenzhenPDFMac.mm): explain why, deep-link to the Full
+ * Disk Access pane of System Settings, tell the user to relaunch, and
+ * never nag once dismissed.
+ *
+ * ==========================================================================
+ * DEV-VS-BUNDLE TCC CAVEAT — READ BEFORE TRUSTING nautilus_macos_fda_is_granted
+ *
+ * TCC attributes file access to the RESPONSIBLE PROCESS. When the binary is
+ * launched from a terminal or an IDE, that responsible process is the
+ * terminal/IDE — so if e.g. iTerm or Cursor already has Full Disk Access,
+ * the probe below succeeds and this function returns TRUE even though
+ * "Nautilus" has no grant of its own. Conversely a bare Terminal without
+ * FDA makes it return FALSE no matter what. The check is only truthful for
+ * the final signed .app bundle launched via Finder/LaunchServices — which
+ * is the case that matters for the shipped product.
+ * ==========================================================================
+ */
+
+#define G_LOG_DOMAIN "nautilus-macos-bridge"
+
+#include <config.h>
+#include "nautilus-macos-bridge.h"
+
+#include <adwaita.h>
+#include <glib/gi18n.h>
+
+#import <AppKit/AppKit.h>
+
+#include <dirent.h>
+#include <errno.h>
+#include <fcntl.h>
+#include <unistd.h>
+
+/* --- Detection ----------------------------------------------------------- */
+
+typedef enum
+{
+    PROBE_DENIED,           /* EPERM/EACCES: TCC said no */
+    PROBE_GRANTED,          /* read succeeded */
+    PROBE_INCONCLUSIVE      /* ENOENT etc: try the next location */
+} ProbeResult;
+
+static ProbeResult
+probe_open_file (const char *path)
+{
+    int fd = open (path, O_RDONLY | O_NONBLOCK | O_CLOEXEC);
+
+    if (fd >= 0)
+    {
+        close (fd);
+        return PROBE_GRANTED;
+    }
+
+    return (errno == EPERM || errno == EACCES) ? PROBE_DENIED : PROBE_INCONCLUSIVE;
+}
+
+static ProbeResult
+probe_list_dir (const char *path)
+{
+    DIR *dir = opendir (path);
+    struct dirent *entry;
+    int saved_errno;
+
+    if (dir == NULL)
+    {
+        return (errno == EPERM || errno == EACCES) ? PROBE_DENIED : PROBE_INCONCLUSIVE;
+    }
+
+    /* opendir alone can succeed on TCC-protected dirs; the denial may only
+     * surface on the first readdir, so force one. */
+    errno = 0;
+    entry = readdir (dir);
+    saved_errno = errno;
+    closedir (dir);
+
+    if (entry != NULL || saved_errno == 0)
+    {
+        return PROBE_GRANTED;
+    }
+
+    return (saved_errno == EPERM || saved_errno == EACCES) ? PROBE_DENIED : PROBE_INCONCLUSIVE;
+}
+
+gboolean
+nautilus_macos_fda_is_granted (void)
+{
+    /* Canonical technique: try to read locations that FDA (and only FDA)
+     * unlocks. The user TCC database always exists; the others are
+     * fallbacks in case a probe is inconclusive (e.g. missing path).
+     * See the dev-vs-bundle caveat in the header comment: under a
+     * terminal/IDE this reports the *responsible process*'s grant. */
+    g_autofree char *user_tcc_db = g_build_filename (g_get_home_dir (),
+                                                     "Library", "Application Support",
+                                                     "com.apple.TCC", "TCC.db", NULL);
+    g_autofree char *user_trash = g_build_filename (g_get_home_dir (), ".Trash", NULL);
+    g_autofree char *user_safari = g_build_filename (g_get_home_dir (),
+                                                     "Library", "Safari", NULL);
+    struct
+    {
+        const char *path;
+        ProbeResult (*probe) (const char *path);
+    } probes[] =
+    {
+        { user_tcc_db, probe_open_file },
+        { user_trash, probe_list_dir },
+        { user_safari, probe_list_dir },
+        { "/Library/Application Support/com.apple.TCC/TCC.db", probe_open_file },
+    };
+
+    for (gsize i = 0; i < G_N_ELEMENTS (probes); i++)
+    {
+        ProbeResult result = probes[i].probe (probes[i].path);
+
+        if (result != PROBE_INCONCLUSIVE)
+        {
+            g_debug ("FDA probe %s: %s", probes[i].path,
+                     result == PROBE_GRANTED ? "granted" : "denied");
+            return result == PROBE_GRANTED;
+        }
+    }
+
+    g_debug ("FDA probes all inconclusive; assuming not granted");
+    return FALSE;
+}
+
+/* --- Bundle path (for "Reveal in Finder" + registering the app) ----------- */
+
+/* Absolute path of the running .app bundle, or NULL when Nautilus is not
+ * running from a bundle (dev/terminal launch). The caller owns the result. */
+static char *
+fda_running_bundle_path (void)
+{
+    @autoreleasepool
+    {
+        NSBundle *main_bundle = [NSBundle mainBundle];
+        NSString *path = [main_bundle bundlePath];
+
+        /* mainBundle resolves to the enclosing .app for a bundled launch and
+         * to the plain executable directory otherwise; the ".app" suffix plus
+         * a non-nil bundle identifier is the reliable discriminator. */
+        if (path != nil && [path hasSuffix:@".app"] &&
+            [main_bundle bundleIdentifier] != nil)
+        {
+            return g_strdup ([path fileSystemRepresentation]);
+        }
+
+        return NULL;
+    }
+}
+
+/* --- Register a TCC access attempt --------------------------------------- */
+
+/* Touch a definitively Full-Disk-Access-gated path so TCC records an access
+ * attempt from this app. That is what makes Nautilus appear (as a togglable,
+ * initially-off row) in System Settings ▸ Privacy & Security ▸ Full Disk
+ * Access — the pane never lists apps that have not yet tried. Requires a
+ * stable code signature (Developer ID) for the record to be keyed on the
+ * bundle identifier and to survive rebuilds; see package/README.md. */
+static void
+fda_register_access_attempt (void)
+{
+    g_autofree char *user_tcc_db = g_build_filename (g_get_home_dir (),
+                                                     "Library", "Application Support",
+                                                     "com.apple.TCC", "TCC.db", NULL);
+    int fd = open (user_tcc_db, O_RDONLY | O_CLOEXEC);
+
+    if (fd >= 0)
+    {
+        close (fd);
+    }
+}
+
+void
+nautilus_macos_fda_register_with_tcc (void)
+{
+    /* Called unconditionally, once per launch, early in application startup
+     * (nautilus_application_startup) — no dialog, result discarded.
+     *
+     * (a) This deliberate denied-or-granted access attempt is what makes
+     *     Nautilus show up in System Settings ▸ Privacy & Security ▸ Full
+     *     Disk Access: the pane only lists apps TCC has seen try.
+     * (b) It only reliably lists the bundled Nautilus.app launched via
+     *     Finder/LaunchServices, where the responsible process is Nautilus
+     *     itself with a stable-ish bundle identity. Terminal/IDE dev runs
+     *     attribute the attempt to the terminal/IDE instead.
+     * (c) Signing is ad-hoc by choice, so the code-signing identity can
+     *     change across rebuilds and TCC may treat a rebuilt app as new
+     *     (the FDA toggle resets). Known + accepted for this port. */
+    static gsize once = 0;
+
+    if (g_once_init_enter (&once))
+    {
+        fda_register_access_attempt ();
+        g_once_init_leave (&once, 1);
+    }
+}
+
+/* --- System Settings deep link ------------------------------------------- */
+
+void
+nautilus_macos_fda_open_settings (void)
+{
+    /* Fire a real access attempt first so TCC has recorded this app before
+     * the pane opens — otherwise a not-yet-granted Nautilus is absent from
+     * the list and the user has nothing to toggle. */
+    fda_register_access_attempt ();
+
+    @autoreleasepool
+    {
+        /* Same deep link shenzhen-pdf uses; still the documented way to reach
+         * Privacy & Security → Full Disk Access on current macOS. */
+        NSURL *url = [NSURL URLWithString:
+                      @"x-apple.systempreferences:com.apple.preference.security?Privacy_AllFiles"];
+
+        if (url != nil)
+        {
+            [[NSWorkspace sharedWorkspace] openURL:url];
+        }
+    }
+}
+
+/* --- First-launch persistence (keyfile; no GSettings schema on purpose) --- */
+
+#define FDA_STATE_GROUP "fda"
+#define FDA_STATE_KEY_DISMISSED "prompt-dismissed"
+#define FDA_STATE_KEY_FIRST_LAUNCH_SHOWN "first-launch-prompt-shown"
+
+static char *
+fda_state_file_path (void)
+{
+    return g_build_filename (g_get_user_config_dir (), "nautilus", "macos-fda.ini", NULL);
+}
+
+static gboolean
+fda_prompt_dismissed (void)
+{
+    g_autofree char *path = fda_state_file_path ();
+    g_autoptr (GKeyFile) key_file = g_key_file_new ();
+
+    if (!g_key_file_load_from_file (key_file, path, G_KEY_FILE_NONE, NULL))
+    {
+        return FALSE;
+    }
+
+    return g_key_file_get_boolean (key_file, FDA_STATE_GROUP, FDA_STATE_KEY_DISMISSED, NULL);
+}
+
+void
+nautilus_macos_fda_set_prompt_dismissed (void)
+{
+    g_autofree char *path = fda_state_file_path ();
+    g_autofree char *dir = g_path_get_dirname (path);
+    g_autoptr (GKeyFile) key_file = g_key_file_new ();
+    g_autoptr (GError) error = NULL;
+
+    /* Preserve any other keys a future version may add. */
+    g_key_file_load_from_file (key_file, path, G_KEY_FILE_KEEP_COMMENTS, NULL);
+    g_key_file_set_boolean (key_file, FDA_STATE_GROUP, FDA_STATE_KEY_DISMISSED, TRUE);
+
+    g_mkdir_with_parents (dir, 0700);
+    if (!g_key_file_save_to_file (key_file, path, &error))
+    {
+        g_warning ("Failed to save FDA prompt state to %s: %s", path, error->message);
+    }
+}
+
+gboolean
+nautilus_macos_fda_should_prompt_on_launch (void)
+{
+    if (nautilus_macos_fda_is_granted ())
+    {
+        return FALSE;
+    }
+
+    return !fda_prompt_dismissed ();
+}
+
+/* --- One-time-ever first-launch prompt state ------------------------------ */
+
+static gboolean
+fda_first_launch_prompt_shown (void)
+{
+    g_autofree char *path = fda_state_file_path ();
+    g_autoptr (GKeyFile) key_file = g_key_file_new ();
+
+    if (!g_key_file_load_from_file (key_file, path, G_KEY_FILE_NONE, NULL))
+    {
+        return FALSE;
+    }
+
+    return g_key_file_get_boolean (key_file, FDA_STATE_GROUP,
+                                   FDA_STATE_KEY_FIRST_LAUNCH_SHOWN, NULL);
+}
+
+void
+nautilus_macos_fda_set_first_launch_prompt_shown (void)
+{
+    g_autofree char *path = fda_state_file_path ();
+    g_autofree char *dir = g_path_get_dirname (path);
+    g_autoptr (GKeyFile) key_file = g_key_file_new ();
+    g_autoptr (GError) error = NULL;
+
+    g_key_file_load_from_file (key_file, path, G_KEY_FILE_KEEP_COMMENTS, NULL);
+    g_key_file_set_boolean (key_file, FDA_STATE_GROUP,
+                            FDA_STATE_KEY_FIRST_LAUNCH_SHOWN, TRUE);
+
+    g_mkdir_with_parents (dir, 0700);
+    if (!g_key_file_save_to_file (key_file, path, &error))
+    {
+        g_warning ("Failed to save FDA first-launch state to %s: %s",
+                   path, error->message);
+    }
+}
+
+gboolean
+nautilus_macos_fda_should_show_first_launch_prompt (void)
+{
+    /* The one-time flag wins over everything: once set (which happens the
+     * instant the prompt is first scheduled), no launch ever prompts again,
+     * regardless of what the user chose in the dialog. The legacy
+     * "prompt-dismissed" opt-out is honored too. */
+    if (fda_first_launch_prompt_shown () || fda_prompt_dismissed ())
+    {
+        return FALSE;
+    }
+
+    /* Already granted (e.g. FDA inherited or previously enabled): nothing
+     * to onboard, and the flag stays unset — harmless, since a later launch
+     * that is granted again still returns FALSE here. */
+    return !nautilus_macos_fda_is_granted ();
+}
+
+/* --- The prompt ----------------------------------------------------------- */
+
+/* The dialog is shown ONLY from the explicit "Grant Full Disk Access…" menu
+ * item (app.fda-prompt). There is deliberately no launch-time prompt: the
+ * responsible-process / signing rules make an automatic prompt both annoying
+ * and frequently wrong on dev builds, so FDA is now strictly opt-in from the
+ * menu. */
+
+#define FDA_DIALOG_BUNDLE_PATH_KEY "nautilus-fda-bundle-path"
+
+static void
+fda_dialog_response_cb (AdwAlertDialog *dialog,
+                        const char     *response,
+                        gpointer        user_data)
+{
+    /* Bundle path is attached to the dialog (owned + freed by it); may be
+     * NULL when Nautilus is not running from a .app bundle. */
+    const char *bundle_path = g_object_get_data (G_OBJECT (dialog),
+                                                 FDA_DIALOG_BUNDLE_PATH_KEY);
+
+    if (g_strcmp0 (response, "open-settings") == 0)
+    {
+        nautilus_macos_fda_open_settings ();
+    }
+    else if (g_strcmp0 (response, "reveal") == 0 && bundle_path != NULL)
+    {
+        nautilus_macos_show_in_finder (bundle_path);
+    }
+}
+
+void
+nautilus_macos_fda_show_dialog (GtkWindow *parent)
+{
+    AdwAlertDialog *dialog;
+    g_autofree char *bundle_path = fda_running_bundle_path ();
+
+    if (nautilus_macos_fda_is_granted ())
+    {
+        /* Menu-invoked while already granted: confirm instead of nagging. */
+        dialog = ADW_ALERT_DIALOG (
+            adw_alert_dialog_new (_("Full Disk Access Is Active"),
+                                  _("Shenzhen Files already has Full Disk Access. "
+                                    "Browsing the Trash, opening Desktop, Documents "
+                                    "and Downloads, and searching the whole disk all "
+                                    "work without extra permission prompts.")));
+        adw_alert_dialog_add_response (dialog, "close", _("_Close"));
+        adw_alert_dialog_set_default_response (dialog, "close");
+        adw_alert_dialog_set_close_response (dialog, "close");
+    }
+    else
+    {
+        /* System Settings does not list apps that have never attempted a
+         * protected access, and even after an attempt the user usually has to
+         * add Nautilus with "+" (or a drag). The numbered steps below match
+         * exactly what the pane requires. "Open System Settings…" also fires a
+         * real access attempt (see nautilus_macos_fda_open_settings) so the
+         * app is at least a candidate the pane can resolve. */
+        dialog = ADW_ALERT_DIALOG (
+            adw_alert_dialog_new (_("Grant Full Disk Access"),
+                                  _("Full Disk Access lets Shenzhen Files browse the Trash "
+                                    "and open Desktop, Documents and Downloads without macOS "
+                                    "asking each time.\n\n"
+                                    "1. Click “Open System Settings” below.\n"
+                                    "2. Click the “+” button under the list (click the "
+                                    "lock to unlock first if needed).\n"
+                                    "3. Choose Shenzhen Files under Applications — or drag "
+                                    "Shenzhen Files.app into the list.\n"
+                                    "4. Turn the Shenzhen Files switch on, then quit and "
+                                    "reopen Shenzhen Files.\n\n"
+                                    "If Shenzhen Files is already in the list, just switch "
+                                    "it on and relaunch.")));
+
+        adw_alert_dialog_add_responses (dialog,
+                                        "open-settings", _("_Open System Settings…"),
+                                        NULL);
+
+        /* Reveal button only makes sense for a real .app launch: it points at
+         * the running bundle so the user can drag it into the "+" sheet. */
+        if (bundle_path != NULL)
+        {
+            adw_alert_dialog_add_response (dialog, "reveal",
+                                           _("_Reveal Shenzhen Files.app in Finder"));
+        }
+
+        adw_alert_dialog_add_response (dialog, "close", _("_Close"));
+        adw_alert_dialog_set_response_appearance (dialog, "open-settings",
+                                                  ADW_RESPONSE_SUGGESTED);
+        adw_alert_dialog_set_default_response (dialog, "open-settings");
+        adw_alert_dialog_set_close_response (dialog, "close");
+    }
+
+    g_object_set_data_full (G_OBJECT (dialog), FDA_DIALOG_BUNDLE_PATH_KEY,
+                            g_steal_pointer (&bundle_path), g_free);
+    g_signal_connect (dialog, "response", G_CALLBACK (fda_dialog_response_cb), NULL);
+
+    /* AdwDialog attaches to the parent window; with a NULL parent libadwaita
+     * falls back to presenting it as a standalone window, so early callers
+     * without a window yet still work. */
+    adw_dialog_present (ADW_DIALOG (dialog), parent != NULL ? GTK_WIDGET (parent) : NULL);
+}
diff --git a/src/nautilus-macos-fileicon.m b/src/nautilus-macos-fileicon.m
new file mode 100644
index 0000000..cd39c6a
--- /dev/null
+++ b/src/nautilus-macos-fileicon.m
@@ -0,0 +1,129 @@
+/*
+ * nautilus-macos-fileicon.m: LaunchServices file-type icons (W11).
+ *
+ * Copyright (C) 2026 The Nautilus authors
+ *
+ * This program is free software; you can redistribute it and/or
+ * modify it under the terms of the GNU General Public License as
+ * published by the Free Software Foundation; either version 2 of the
+ * License, or (at your option) any later version.
+ *
+ * This program is distributed in the hope that it will be useful,
+ * but WITHOUT ANY WARRANTY; without even the implied warranty of
+ * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU
+ * General Public License for more details.
+ *
+ * You should have received a copy of the GNU General Public
+ * License along with this program; if not, see <http://www.gnu.org/licenses/>.
+ *
+ * Finder-style document icons: when the icon theme has nothing better than
+ * the generic file icon for a type, nautilus-file.c substitutes the icon of
+ * the app that owns the type, as reported by LaunchServices (NSWorkspace
+ * iconForFile:). The NSImage → GdkTexture conversion is shared with the
+ * app-chooser bridge (nautilus_macos_app_icon_texture, W2).
+ */
+
+#define G_LOG_DOMAIN "nautilus-macos-bridge"
+
+#include <config.h>
+#include "nautilus-macos-bridge.h"
+
+#import <AppKit/AppKit.h>
+
+#include <string.h>
+
+/* Keyed by "<size>|ext:<lowercased extension>" (or "<size>|app:<path>" for
+ * .app bundles); value is an owned GdkTexture ref. Two files sharing an
+ * extension share an icon, so a 10k-file directory costs one AppKit call
+ * per distinct (extension, size) pair. Never evicted: real directory trees
+ * contain at most a few hundred distinct extensions, and entries are small
+ * next to the thumbnail cache. Main-thread only, so no locking. */
+static GHashTable *icon_cache = NULL;
+
+static guint appkit_call_count = 0;
+static guint cache_hit_count = 0;
+
+static char *
+cache_key_for_path (const char *path,
+                    int         size_px)
+{
+    const char *basename = strrchr (path, '/');
+
+    basename = (basename != NULL) ? basename + 1 : path;
+
+    /* App bundles all share the ".app" extension but each has its own
+     * icon: key those by full path. */
+    if (g_str_has_suffix (basename, ".app") || g_str_has_suffix (basename, ".APP"))
+    {
+        return g_strdup_printf ("%d|app:%s", size_px, path);
+    }
+
+    const char *dot = strrchr (basename, '.');
+    /* dot == basename means a dotfile like ".profile", not an extension. */
+    const char *extension = (dot != NULL && dot != basename) ? dot + 1 : "";
+    g_autofree char *lowered = g_ascii_strdown (extension, -1);
+
+    return g_strdup_printf ("%d|ext:%s", size_px, lowered);
+}
+
+GdkTexture *
+nautilus_macos_file_icon_texture (const char *path,
+                                  int         size_px)
+{
+    g_return_val_if_fail (path != NULL, NULL);
+    g_return_val_if_fail (size_px > 0, NULL);
+
+    if (![NSThread isMainThread])
+    {
+        g_warning ("nautilus_macos_file_icon_texture called off the main thread; "
+                   "returning NULL (NSWorkspace icon APIs are main-thread)");
+        return NULL;
+    }
+
+    if (G_UNLIKELY (icon_cache == NULL))
+    {
+        icon_cache = g_hash_table_new_full (g_str_hash, g_str_equal,
+                                            g_free, g_object_unref);
+    }
+
+    g_autofree char *key = cache_key_for_path (path, size_px);
+    GdkTexture *cached = g_hash_table_lookup (icon_cache, key);
+
+    if (cached != NULL)
+    {
+        cache_hit_count++;
+        return g_object_ref (cached);
+    }
+
+    /* Shared NSWorkspace iconForFile: → GdkTexture conversion (W2). */
+    appkit_call_count++;
+    GdkTexture *texture = nautilus_macos_app_icon_texture (path, size_px);
+
+    if (texture == NULL)
+    {
+        return NULL;
+    }
+
+    g_hash_table_insert (icon_cache, g_steal_pointer (&key), g_object_ref (texture));
+
+    return texture;
+}
+
+void
+nautilus_macos_file_icon_debug_stats (guint *out_appkit_calls,
+                                      guint *out_cache_hits,
+                                      guint *out_cache_entries)
+{
+    if (out_appkit_calls != NULL)
+    {
+        *out_appkit_calls = appkit_call_count;
+    }
+    if (out_cache_hits != NULL)
+    {
+        *out_cache_hits = cache_hit_count;
+    }
+    if (out_cache_entries != NULL)
+    {
+        *out_cache_entries = (icon_cache != NULL) ? g_hash_table_size (icon_cache) : 0;
+    }
+}
