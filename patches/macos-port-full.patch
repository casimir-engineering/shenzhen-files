              GAsyncResult             *result,
@@ -666,6 +763,7 @@ set_icon (NautilusPropertiesWidget *self,
     gtk_stack_set_visible_child_name (self->icon_stack, "loading");
     gly_loader_load_async (loader, self->icon_cancellable, (GAsyncReadyCallback) icon_loaded, self);
 }
+#endif /* __APPLE__ */
 
