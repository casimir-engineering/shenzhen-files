+#ifdef __APPLE__
+/* Replacement for gly_loader_get_mime_types(): the set of image types
+ * gdk-pixbuf can decode. */
+static GStrv
+get_loadable_image_mime_types (void)
+{
+    g_autoptr (GStrvBuilder) builder = g_strv_builder_new ();
+    GSList *format_list = gdk_pixbuf_get_formats ();
+
+    for (GSList *l = format_list; l != NULL; l = l->next)
+    {
+        g_auto (GStrv) types = gdk_pixbuf_format_get_mime_types (l->data);
+
+        for (gsize i = 0; types[i] != NULL; i++)
+        {
+            g_strv_builder_add (builder, types[i]);
+        }
+    }
+
+    g_slist_free (format_list);
+
+    return g_strv_builder_end (builder);
+}
+#endif
