     adw_overlay_split_view_set_show_sidebar (ADW_OVERLAY_SPLIT_VIEW (window->split_view), !revealed);
 }
 
+/* Clamps for the user-resizable sidebar; keep in sync with the range of the
+ * "sidebar-width" key in org.gnome.nautilus.gschema.xml. */
+#define SIDEBAR_RESIZE_MIN_WIDTH 180
+#define SIDEBAR_RESIZE_MAX_WIDTH 500
+/* Width of the sidebar overlay while the split view is collapsed, matching
+ * the max-sidebar-width Nautilus historically hardcoded. */
+#define SIDEBAR_COLLAPSED_WIDTH 240
+
+static void
+sidebar_resize_state_changed (NautilusWindow *window)
+{
+    AdwOverlaySplitView *split_view = ADW_OVERLAY_SPLIT_VIEW (window->split_view);
+    gboolean collapsed = adw_overlay_split_view_get_collapsed (split_view);
+    gboolean shown = adw_overlay_split_view_get_show_sidebar (split_view);
+
+    gtk_widget_set_visible (window->sidebar_resize_handle, shown && !collapsed);
+
+    /* While collapsed, the sidebar floats over the content; use the fixed
+     * historical overlay width there instead of the user-resized one. */
+    adw_overlay_split_view_set_max_sidebar_width (split_view,
+                                                  collapsed ?
+                                                  SIDEBAR_COLLAPSED_WIDTH :
+                                                  window->sidebar_width);
+}
+
+static void
+sidebar_resize_drag_update (GtkGestureDrag *gesture,
+                            double          offset_x,
+                            double          offset_y,
+                            gpointer        user_data)
+{
+    NautilusWindow *window = NAUTILUS_WINDOW (user_data);
+    int current_width = gtk_widget_get_width (GTK_WIDGET (window->places_sidebar));
+    int new_width;
+
+    if (gtk_widget_get_direction (window->split_view) == GTK_TEXT_DIR_RTL)
+    {
+        offset_x = -offset_x;
+    }
+
+    /* The drag offset is reported relative to the handle, which itself moves
+     * with the sidebar/content boundary as the sidebar is resized, so adding
+     * it to the current width yields the pointer-tracking width. */
+    new_width = CLAMP (current_width + (int) offset_x,
+                       SIDEBAR_RESIZE_MIN_WIDTH,
+                       SIDEBAR_RESIZE_MAX_WIDTH);
+
+    if (new_width != window->sidebar_width)
+    {
+        window->sidebar_width = new_width;
+        adw_overlay_split_view_set_max_sidebar_width (ADW_OVERLAY_SPLIT_VIEW (window->split_view),
+                                                      new_width);
+    }
+}
+
+static void
+sidebar_resize_drag_end (GtkGestureDrag *gesture,
+                         double          offset_x,
+                         double          offset_y,
+                         gpointer        user_data)
+{
+    NautilusWindow *window = NAUTILUS_WINDOW (user_data);
+
+    g_settings_set_int (nautilus_window_state,
+                        NAUTILUS_WINDOW_STATE_SIDEBAR_WIDTH,
+                        window->sidebar_width);
+}
+
+static void
+nautilus_window_set_up_sidebar_resize (NautilusWindow *window)
+{
+    GtkGesture *gesture;
+
+    window->sidebar_width = g_settings_get_int (nautilus_window_state,
+                                                NAUTILUS_WINDOW_STATE_SIDEBAR_WIDTH);
+
+    gtk_widget_set_cursor_from_name (window->sidebar_resize_handle, "col-resize");
+
+    gesture = gtk_gesture_drag_new ();
+    g_signal_connect (gesture, "drag-update",
+                      G_CALLBACK (sidebar_resize_drag_update), window);
+    g_signal_connect (gesture, "drag-end",
+                      G_CALLBACK (sidebar_resize_drag_end), window);
+    gtk_widget_add_controller (window->sidebar_resize_handle,
+                               GTK_EVENT_CONTROLLER (gesture));
+
+    g_signal_connect_swapped (window->split_view, "notify::collapsed",
+                              G_CALLBACK (sidebar_resize_state_changed), window);
+    g_signal_connect_swapped (window->split_view, "notify::show-sidebar",
+                              G_CALLBACK (sidebar_resize_state_changed), window);
+    sidebar_resize_state_changed (window);
+}
+
 static void
 nautilus_window_set_up_sidebar (NautilusWindow *window)
 {
