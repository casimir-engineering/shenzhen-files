+/* ==========================================================================
+ * Section W6 — Full Disk Access onboarding (nautilus-macos-fda.m)
+ *
+ * First-launch prompt asking the user to grant Full Disk Access (FDA),
+ * mirroring shenzhen-pdf's flow. FDA unlocks ~/.Trash browsing (TCC-blocked
+ * otherwise) and Desktop/Documents/Downloads without per-folder prompts.
+ * ========================================================================== */
+
+#include <gtk/gtk.h>    /* GtkWindow, for the dialog parent (C API, W6 only) */
+
+/* TRUE if this process can currently read TCC-protected locations that only
+ * Full Disk Access unlocks (probes TCC.db / ~/.Trash / ~/Library/Safari).
+ *
+ * CAVEAT (dev vs bundle): TCC checks the RESPONSIBLE PROCESS. Run from a
+ * terminal or IDE, this reports the terminal/IDE's own FDA grant, not
+ * "Nautilus"'s. It is truthful for the final .app bundle launched via
+ * Finder/LaunchServices. */
+gboolean nautilus_macos_fda_is_granted (void);
+
+/* Open System Settings on Privacy & Security → Full Disk Access
+ * (x-apple.systempreferences:com.apple.preference.security?Privacy_AllFiles). */
+void nautilus_macos_fda_open_settings (void);
+
+/* TRUE when the launch prompt should be shown: FDA not granted AND the user
+ * has not previously chosen "Don't Ask Again". State lives in a keyfile at
+ * $XDG_CONFIG_HOME/nautilus/macos-fda.ini (no GSettings schema). */
+gboolean nautilus_macos_fda_should_prompt_on_launch (void);
+
+/* Persist the "Don't Ask Again" choice (sets the dismissed flag in the
+ * keyfile). Called by the dialog; exposed for completeness/testing. */
+void nautilus_macos_fda_set_prompt_dismissed (void);
+
+/* Present the FDA prompt as an AdwAlertDialog attached to @parent (may be
+ * NULL for a standalone window). If FDA is not granted: explains why
+ * Nautilus wants it, with "Open System Settings…" / "Not Now" /
+ * "Don't Ask Again" responses (only the last one sets the dismissed flag).
+ * If FDA is already granted (e.g. re-launched from the menu): shows an
+ * "access is active" confirmation instead. Safe to call unconditionally
+ * from a menu action. Does not block. */
+void nautilus_macos_fda_show_dialog (GtkWindow *parent);
+
+/* Fire one deliberate access attempt on a TCC/FDA-protected path (result
+ * discarded, no UI). This is what makes Nautilus appear as an off-by-default
+ * row in System Settings ▸ Privacy & Security ▸ Full Disk Access — the pane
+ * only lists apps TCC has seen try. Call unconditionally once per launch,
+ * early in startup; further calls in the same process are no-ops. Only
+ * reliably lists the bundled .app (see the responsible-process caveat on
+ * nautilus_macos_fda_is_granted), and with ad-hoc signing the identity may
+ * change across rebuilds. */
+void nautilus_macos_fda_register_with_tcc (void);
+
+/* One-time-ever first-launch prompt gate. should_show returns TRUE only if
+ * FDA is not granted AND the "first-launch-prompt-shown" flag (keyfile
+ * $XDG_CONFIG_HOME/nautilus/macos-fda.ini, [fda] group) has never been set
+ * AND the legacy "prompt-dismissed" opt-out is not set. Callers must set
+ * the flag (set_first_launch_prompt_shown) the moment they schedule the
+ * prompt, so it can never fire on a second launch regardless of the user's
+ * response. */
+gboolean nautilus_macos_fda_should_show_first_launch_prompt (void);
+void nautilus_macos_fda_set_first_launch_prompt_shown (void);
+
+/* ==========================================================================
+ * End section W6
+ * ========================================================================== */
