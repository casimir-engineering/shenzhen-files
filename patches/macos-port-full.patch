+static void
+macos_setup_native_window_controls (GtkWindow *window)
+{
+    GtkWidget *split_view;
+
+    /* Controls exist as soon as the window's template is built (before the
+     * window is mapped), so turn them off now, again on map (belt and
+     * suspenders), and again whenever the sidebar toggles and libadwaita
+     * rebuilds the split header controls. */
+    macos_disable_native_window_controls (GTK_WIDGET (window));
+    g_signal_connect (window, "map", G_CALLBACK (macos_window_map_cb), NULL);
+
+    split_view = macos_find_descendant_by_type_name (GTK_WIDGET (window),
+                                                     "AdwOverlaySplitView");
+    if (split_view != NULL)
+    {
+        g_signal_connect (split_view, "notify::show-sidebar",
+                          G_CALLBACK (macos_split_view_controls_notify_cb), window);
+        g_signal_connect (split_view, "notify::collapsed",
+                          G_CALLBACK (macos_split_view_controls_notify_cb), window);
+    }
+}
