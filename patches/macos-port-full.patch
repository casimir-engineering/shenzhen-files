+/* ==========================================================================
+ * Native-feeling text rendering (see the call site in startup for the
+ * findings; measurements in docs/STATUS.md "Font rendering" entry).
+ * ========================================================================== */
+
+static void
+macos_setup_font_rendering (void)
+{
+    GtkSettings *settings = gtk_settings_get_default ();
+    g_autoptr (GtkCssProvider) provider = gtk_css_provider_new ();
+
+    if (settings == NULL)
+    {
+        return;
+    }
+
+    /* 13 pt is the macOS "regular control" size AppKit uses for sidebar /
+     * list text; GDK hardcodes the 12 pt "views" size. An application-set
+     * property outranks the backend xsetting (GTK_SETTINGS_SOURCE_
+     * APPLICATION > _XSETTING), which a bundled settings.ini would not. */
+    g_object_set (settings, "gtk-font-name", ".AppleSystemUIFont 13", NULL);
+
+    /* Weight compensation for the disabled CoreText stem darkening: the
+     * default text weight becomes Medium (500). Set on the window node so
+     * it INHERITS into labels; any theme rule that sets font-weight
+     * directly on a node (headings, .title-*, <b>…) still overrides
+     * inherited values regardless of provider priority. */
+    gtk_css_provider_load_from_string (provider, "window { font-weight: 500; }");
+    gtk_style_context_add_provider_for_display (gdk_display_get_default (),
+                                                GTK_STYLE_PROVIDER (provider),
+                                                GTK_STYLE_PROVIDER_PRIORITY_APPLICATION);
+}
+
+/* ==========================================================================
+ * macOS window chrome — Finder-style traffic lights (GTK-drawn)
+ *
+ * The window buttons move to the TOP-LEFT (mac convention) and sit in the
+ * sidebar's header bar, like Finder's full-height sidebar. Native AppKit
+ * controls stay force-disabled (GTK #7964 deadlock, see above), so the
+ * buttons are GTK-drawn and restyled below into 12 px traffic lights:
+ * plain colored circles, glyphs appear when hovering the cluster, and the
+ * circles go neutral gray on unfocused (backdrop) windows. libadwaita's
+ * split-header coordination hides the start controls in the content header
+ * while the sidebar header shows them, and automatically brings them back
+ * in the content header when the sidebar is collapsed (narrow window) or
+ * hidden — so the fallback needs no extra code.
+ * ========================================================================== */
+
+static void
+macos_setup_window_chrome (void)
+{
+    GtkSettings *settings = gtk_settings_get_default ();
+    g_autoptr (GtkCssProvider) provider = gtk_css_provider_new ();
+
+    if (settings == NULL)
+    {
+        return;
+    }
+
+    /* Buttons on the left, mac order. Applies to every toplevel (dialogs
+     * included), which is exactly the platform convention. */
+    g_object_set (settings, "gtk-decoration-layout", "close,minimize,maximize:", NULL);
+
+    /* Metrics measured off a native window on this macOS at 1x (AX +
+     * pixel-count, 2026-07-16): circle diameter 14 px, 23 px
+     * center-to-center (9 px gap), cluster inset ~13 px from the window
+     * edge. The circle is drawn on the button's inner IMAGE node, which
+     * keeps its natural size and stays centered — putting it on the
+     * button node instead lets the button stretch to the headerbar
+     * height and distorts the circle into a tall ellipse (regression
+     * seen 2026-07-16; do not move these rules onto the button).
+     * 12 px content + 1 px border ring = 14 px circle; whole-pixel sizes
+     * and a plain background + border-radius circle render crisply at
+     * 1x and 2x. */
+    gtk_css_provider_load_from_string (provider,
+                                       /* Traffic lights */
+                                       /* headerbar padding contributes ~6 px; 7 px margin puts the
+                                        * first circle 13 px from the edge like native windows */
+                                       "windowcontrols { border-spacing: 9px; margin-left: 7px; margin-right: 9px; }\n"
+                                       "windowcontrols > button {\n"
+                                       "  min-width: 14px; min-height: 14px; padding: 0;\n"
+                                       "  background: none; box-shadow: none;\n"
+                                       "}\n"
+                                       "windowcontrols > button > image {\n"
+                                       "  min-width: 12px; min-height: 12px; padding: 0;\n"
+                                       "  border-radius: 50%;\n"
+                                       "  background-image: none;\n"
+                                       "  border: 1px solid color-mix(in srgb, black 12%, transparent);\n"
+                                       "  box-shadow: none;\n"
+                                       "  -gtk-icon-shadow: none;\n"
+                                       "  color: transparent;\n"
+                                       "  -gtk-icon-size: 10px;\n"
+                                       "}\n"
+                                       "windowcontrols > button.close > image { background-color: #ff5f57; }\n"
+                                       "windowcontrols > button.minimize > image { background-color: #febc2e; }\n"
+                                       "windowcontrols > button.maximize > image { background-color: #28c840; }\n"
+                                       /* Hovering the cluster darkens the glyph color (Finder-ish) */
+                                       "windowcontrols:hover > button.close > image { color: rgba(90, 0, 0, 0.65); }\n"
+                                       "windowcontrols:hover > button.minimize > image { color: rgba(100, 60, 0, 0.65); }\n"
+                                       "windowcontrols:hover > button.maximize > image { color: rgba(0, 70, 0, 0.65); }\n"
+                                       /* Unfocused window: neutral gray (native backdrop look) */
+                                       "windowcontrols > button:backdrop > image {\n"
+                                       "  background-color: color-mix(in srgb, var(--window-fg-color) 22%, transparent);\n"
+                                       "  border-color: transparent;\n"
+                                       "  color: transparent;\n"
+                                       "}\n");
+    gtk_style_context_add_provider_for_display (gdk_display_get_default (),
+                                                GTK_STYLE_PROVIDER (provider),
+                                                GTK_STYLE_PROVIDER_PRIORITY_APPLICATION);
+}
