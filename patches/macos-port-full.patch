+static GtkWidget *
+macos_find_descendant_by_type_name (GtkWidget  *widget,
+                                    const char *type_name)
+{
+    if (g_str_equal (G_OBJECT_TYPE_NAME (widget), type_name))
+    {
+        return widget;
+    }
+
+    for (GtkWidget *child = gtk_widget_get_first_child (widget);
+         child != NULL;
+         child = gtk_widget_get_next_sibling (child))
+    {
+        GtkWidget *match = macos_find_descendant_by_type_name (child, type_name);
+
+        if (match != NULL)
+        {
+            return match;
+        }
+    }
+
+    return NULL;
+}
