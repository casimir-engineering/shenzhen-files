+/* --- Dev-run Dock icon --------------------------------------------------- */
+
+/* A terminal/IDE launch of build/src/nautilus is not a .app bundle, so
+ * LaunchServices gives it a generic Dock icon. Set the official Nautilus
+ * file-cabinet artwork explicitly in that case. When Nautilus IS running
+ * from a bundle, the Info.plist CFBundleIconFile already supplies the icon
+ * and we leave NSApplication alone.
+ *
+ * Source of the image, in priority order:
+ *   1. $NAUTILUS_DOCK_ICON — an explicit .icns/.png path (dev override).
+ *   2. NAUTILUS_DEV_DOCK_ICON_PATH — a compile-time default baked by
+ *      src/meson.build to the committed package/AppIcon.icns (the same
+ *      official upstream artwork the bundle ships). Dev-machine path; fine
+ *      because this branch only runs for non-bundle launches.
+ * Missing/unreadable files degrade silently — the Dock icon is cosmetic. */
+static gboolean
+macos_running_from_bundle (void)
+{
+    NSBundle *main_bundle = [NSBundle mainBundle];
+    NSString *path = [main_bundle bundlePath];
+
+    return path != nil && [path hasSuffix:@".app"] &&
+           [main_bundle bundleIdentifier] != nil;
+}
+
+static void
+macos_set_dev_dock_icon (void)
+{
+    if (macos_running_from_bundle ())
+    {
+        return;
+    }
+
+    const char *override_path = g_getenv ("NAUTILUS_DOCK_ICON");
+    g_autofree char *icon_path = NULL;
+
+    if (override_path != NULL && override_path[0] != '\0')
+    {
+        icon_path = g_strdup (override_path);
+    }
+#ifdef NAUTILUS_DEV_DOCK_ICON_PATH
+    else
+    {
+        icon_path = g_strdup (NAUTILUS_DEV_DOCK_ICON_PATH);
+    }
+#endif
+
+    if (icon_path == NULL || !g_file_test (icon_path, G_FILE_TEST_EXISTS))
+    {
+        g_debug ("dev Dock icon: no icon file found; leaving default");
+        return;
+    }
+
+    @autoreleasepool
+    {
+        NSImage *image = [[NSImage alloc] initWithContentsOfFile:@(icon_path)];
+
+        if (image != nil)
+        {
+            [NSApplication sharedApplication].applicationIconImage = image;
+            g_debug ("dev Dock icon: set from %s", icon_path);
+        }
+    }
+}
+
+/* --- "Check Permissions…" in the application (app-name) menu -------------- */
+
+/* GTK's quartz backend synthesizes the bold app-name menu (About / Settings /
+ * Services / Hide / Quit) from its own fixed template with no public GMenu
+ * extension point, so the item is inserted natively: take [NSApp mainMenu]
+ * item 0's submenu and add an NSMenuItem right after "About Nautilus". Its
+ * action activates the app.fda-prompt GAction — the same Full Disk Access
+ * check-and-prompt flow as the Help-menu item (shows the grant walkthrough
+ * when FDA is missing, an "already granted" confirmation otherwise). */
+
+@interface NautilusCheckPermissionsTarget : NSObject
+- (void) checkPermissions: (id) sender;
+@end
+
+@implementation NautilusCheckPermissionsTarget
+- (void) checkPermissions: (id) sender
+{
+    GApplication *app = g_application_get_default ();
+
+    if (app != NULL)
+    {
+        g_action_group_activate_action (G_ACTION_GROUP (app), "fda-prompt", NULL);
+    }
+    else
+    {
+        g_warning ("Check Permissions: no default GApplication to activate app.fda-prompt on");
+    }
+}
+@end
+
+/* NSMenuItem.target is weak; keep the target alive for the process lifetime. */
+static NautilusCheckPermissionsTarget *check_permissions_target = nil;
+
+/* TRUE once the item is in place. FALSE means the menubar (or the app menu
+ * inside it) does not exist yet — caller should retry later. */
+static gboolean
+macos_try_insert_check_permissions_item (void)
+{
+    @autoreleasepool
+    {
+        NSMenu *main_menu = [NSApp mainMenu];
+
+        if (main_menu == nil || [main_menu numberOfItems] == 0)
+        {
+            return FALSE;
+        }
+
+        /* Item 0 of the menubar is always the application menu on macOS. */
+        NSMenu *app_menu = [[main_menu itemAtIndex:0] submenu];
+
+        if (app_menu == nil || [app_menu numberOfItems] == 0)
+        {
+            return FALSE;
+        }
+
+        /* Idempotency: never insert twice (init may be re-entered, and the
+         * retry timer must be safe against races with GTK rebuilding menus). */
+        for (NSInteger i = 0; i < [app_menu numberOfItems]; i++)
+        {
+            if ([[app_menu itemAtIndex:i] action] == @selector (checkPermissions:))
+            {
+                return TRUE;
+            }
+        }
+
+        if (check_permissions_target == nil)
+        {
+            check_permissions_target = [[NautilusCheckPermissionsTarget alloc] init];
+        }
+
+        NSMenuItem *item =
+            [[NSMenuItem alloc] initWithTitle:@(_("Check Permissions…"))
+                                       action:@selector (checkPermissions:)
+                                keyEquivalent:@""];
+        [item setTarget:check_permissions_target];
+
+        /* Right below "About Nautilus" (item 0), above the separator that
+         * precedes Settings — i.e. About / Check Permissions… / ─── / … */
+        NSInteger insert_index = MIN (1, [app_menu numberOfItems]);
+        [app_menu insertItem:item atIndex:insert_index];
+
+        g_debug ("Check Permissions: inserted into the app menu at index %ld",
+                 (long) insert_index);
+        return TRUE;
+    }
+}
+
+/* GTK builds and installs the NSMenu bar during/after application startup
+ * (gtk_application_set_menubar → quartz backend), so inserting synchronously
+ * from startup can be too early or get clobbered. Poll from a main-loop
+ * timeout until the menubar exists, then insert once and stop. */
+#define CHECK_PERMISSIONS_RETRY_INTERVAL_MS 100
+#define CHECK_PERMISSIONS_MAX_RETRIES 50
+
+static guint check_permissions_retries = 0;
+
+static gboolean
+check_permissions_insert_cb (gpointer user_data)
+{
+    if (macos_try_insert_check_permissions_item ())
+    {
+        return G_SOURCE_REMOVE;
+    }
+
+    if (++check_permissions_retries >= CHECK_PERMISSIONS_MAX_RETRIES)
+    {
+        g_warning ("Check Permissions: menubar never appeared; giving up "
+                   "(the Help ▸ Grant Full Disk Access… item still works)");
+        return G_SOURCE_REMOVE;
+    }
+
+    return G_SOURCE_CONTINUE;
+}
+
+void
+nautilus_macos_menu_add_check_permissions_item (void)
+{
+    g_timeout_add (CHECK_PERMISSIONS_RETRY_INTERVAL_MS,
+                   check_permissions_insert_cb, NULL);
+}
+
+/* --- "Finder Integration…" in the application (app-name) menu -------------- */
+
+/* Same native-insertion technique as "Check Permissions…" (W12 addition):
+ * the item activates the app.finder-integration GAction, which opens the
+ * Finder Integration page of the preferences dialog. Opening the page is
+ * all it does — no integration is applied by the menu item itself. */
+
+@interface NautilusFinderIntegrationTarget : NSObject
+- (void) finderIntegration: (id) sender;
+@end
+
+@implementation NautilusFinderIntegrationTarget
+- (void) finderIntegration: (id) sender
+{
+    GApplication *app = g_application_get_default ();
+
+    if (app != NULL)
+    {
+        g_action_group_activate_action (G_ACTION_GROUP (app),
+                                        "finder-integration", NULL);
+    }
+    else
+    {
+        g_warning ("Finder Integration: no default GApplication to activate "
+                   "app.finder-integration on");
+    }
+}
+@end
+
+/* NSMenuItem.target is weak; keep the target alive for the process lifetime. */
+static NautilusFinderIntegrationTarget *finder_integration_target = nil;
+
+/* TRUE once the item is in place. FALSE means the menubar, the app menu or
+ * the "Check Permissions…" anchor item does not exist yet — retry later.
+ * Idempotent: scans for its own selector before inserting. */
+static gboolean
+macos_try_insert_finder_integration_item (void)
+{
+    @autoreleasepool
+    {
+        NSMenu *main_menu = [NSApp mainMenu];
+
+        if (main_menu == nil || [main_menu numberOfItems] == 0)
+        {
+            return FALSE;
+        }
+
+        NSMenu *app_menu = [[main_menu itemAtIndex:0] submenu];
+
+        if (app_menu == nil || [app_menu numberOfItems] == 0)
+        {
+            return FALSE;
+        }
+
+        NSInteger anchor_index = -1;
+
+        for (NSInteger i = 0; i < [app_menu numberOfItems]; i++)
+        {
+            SEL action = [[app_menu itemAtIndex:i] action];
+
+            /* Idempotency: never insert twice. */
+            if (action == @selector (finderIntegration:))
+            {
+                return TRUE;
+            }
+
+            /* Anchor: sit right below "Check Permissions…". */
+            if (action == @selector (checkPermissions:))
+            {
+                anchor_index = i;
+            }
+        }
+
+        if (anchor_index < 0)
+        {
+            /* Check Permissions… not inserted yet; wait for it so the order
+             * is always About / Check Permissions… / Finder Integration…. */
+            return FALSE;
+        }
+
+        if (finder_integration_target == nil)
+        {
+            finder_integration_target = [[NautilusFinderIntegrationTarget alloc] init];
+        }
+
+        NSMenuItem *item =
+            [[NSMenuItem alloc] initWithTitle:@(_("Finder Integration…"))
+                                       action:@selector (finderIntegration:)
+                                keyEquivalent:@""];
+        [item setTarget:finder_integration_target];
+        [app_menu insertItem:item atIndex:anchor_index + 1];
+
+        g_debug ("Finder Integration: inserted into the app menu at index %ld",
+                 (long) (anchor_index + 1));
+        return TRUE;
+    }
+}
+
+static guint finder_integration_retries = 0;
+
+static gboolean
+finder_integration_insert_cb (gpointer user_data)
+{
+    if (macos_try_insert_finder_integration_item ())
+    {
+        return G_SOURCE_REMOVE;
+    }
+
+    if (++finder_integration_retries >= CHECK_PERMISSIONS_MAX_RETRIES)
+    {
+        g_warning ("Finder Integration: menubar (or its Check Permissions… "
+                   "anchor) never appeared; giving up (Settings ▸ Finder "
+                   "Integration still works)");
+        return G_SOURCE_REMOVE;
+    }
+
+    return G_SOURCE_CONTINUE;
+}
+
+void
+nautilus_macos_menu_add_finder_integration_item (void)
+{
+    g_timeout_add (CHECK_PERMISSIONS_RETRY_INTERVAL_MS,
+                   finder_integration_insert_cb, NULL);
+}
+
+/* --- "Check for Updates…" in the application (app-name) menu --------------- */
+
+/* Same native-insertion technique (W14): the item calls straight into the
+ * updater bridge (nautilus_macos_updater_check_interactive — the manual,
+ * gate-bypassing check path). Anchored below "Finder Integration…" so the
+ * app menu reads About / Check Permissions… / Finder Integration… /
+ * Check for Updates…. */
+
+@interface NautilusCheckUpdatesTarget : NSObject
+- (void) checkForUpdates: (id) sender;
+@end
+
+@implementation NautilusCheckUpdatesTarget
+- (void) checkForUpdates: (id) sender
+{
+    nautilus_macos_updater_check_interactive ();
+}
+@end
+
+/* NSMenuItem.target is weak; keep the target alive for the process lifetime. */
+static NautilusCheckUpdatesTarget *check_updates_target = nil;
+
+static gboolean
+macos_try_insert_check_updates_item (void)
+{
+    @autoreleasepool
+    {
+        NSMenu *main_menu = [NSApp mainMenu];
+
+        if (main_menu == nil || [main_menu numberOfItems] == 0)
+        {
+            return FALSE;
+        }
+
+        NSMenu *app_menu = [[main_menu itemAtIndex:0] submenu];
+
+        if (app_menu == nil || [app_menu numberOfItems] == 0)
+        {
+            return FALSE;
+        }
+
+        NSInteger anchor_index = -1;
+
+        for (NSInteger i = 0; i < [app_menu numberOfItems]; i++)
+        {
+            SEL action = [[app_menu itemAtIndex:i] action];
+
+            /* Idempotency: never insert twice. */
+            if (action == @selector (checkForUpdates:))
+            {
+                return TRUE;
+            }
+
+            /* Anchor: sit right below "Finder Integration…". */
+            if (action == @selector (finderIntegration:))
+            {
+                anchor_index = i;
+            }
+        }
+
+        if (anchor_index < 0)
+        {
+            /* Finder Integration… not inserted yet; wait for it so the
+             * order is deterministic. */
+            return FALSE;
+        }
+
+        if (check_updates_target == nil)
+        {
+            check_updates_target = [[NautilusCheckUpdatesTarget alloc] init];
+        }
+
+        NSMenuItem *item =
+            [[NSMenuItem alloc] initWithTitle:@(_("Check for Updates…"))
+                                       action:@selector (checkForUpdates:)
+                                keyEquivalent:@""];
+        [item setTarget:check_updates_target];
+        [app_menu insertItem:item atIndex:anchor_index + 1];
+
+        g_debug ("Check for Updates: inserted into the app menu at index %ld",
+                 (long) (anchor_index + 1));
+        return TRUE;
+    }
+}
+
+static guint check_updates_retries = 0;
+
+static gboolean
+check_updates_insert_cb (gpointer user_data)
+{
+    if (macos_try_insert_check_updates_item ())
+    {
+        return G_SOURCE_REMOVE;
+    }
+
+    if (++check_updates_retries >= CHECK_PERMISSIONS_MAX_RETRIES)
+    {
+        g_warning ("Check for Updates: menubar (or its Finder Integration… "
+                   "anchor) never appeared; giving up (the silent daily "
+                   "check still runs)");
+        return G_SOURCE_REMOVE;
+    }
+
+    return G_SOURCE_CONTINUE;
+}
+
+void
+nautilus_macos_menu_add_check_updates_item (void)
+{
+    g_timeout_add (CHECK_PERMISSIONS_RETRY_INTERVAL_MS,
+                   check_updates_insert_cb, NULL);
+}
+
+/* --- Finder-like Dock lifecycle: reopen handler --------------------------- */
+
+/* Reopen-window placement: the window opened by a Dock-icon click must
+ * appear CENTERED on the screen the user clicked on. With a multi-display
+ * Dock the reliable proxy at reopen time is the screen under the mouse
+ * cursor — the pointer is by definition on the Dock icon that was just
+ * clicked. GTK4 has no window-move API, so positioning happens at the
+ * AppKit level: after the new GtkWindow is MAPPED (GDK creates and places
+ * the NSWindow during realize/present; hooking GtkWidget::map avoids any
+ * fixed sleeps), one main-loop idle later (so GDK's own cascade placement
+ * has finished), grab the NSWindow via the public
+ * gdk_macos_surface_get_native_window() and setFrameOrigin: it centered
+ * in the target screen's visibleFrame (menu-bar/Dock insets respected).
+ * ONLY the reopen-with-no-windows path does this; normal window placement
+ * is untouched. */
+
+typedef struct
+{
+    GtkWindow *window;      /* strong ref, released by apply-site/notify */
+    double x, y, w, h;      /* target screen visibleFrame, AppKit coords */
+} ReopenCenterData;
+
+/* visibleFrame of the screen containing the mouse pointer (AppKit
+ * bottom-left-origin global coordinates); main screen as fallback. */
+static NSRect
+macos_mouse_screen_visible_frame (void)
+{
+    NSPoint p = [NSEvent mouseLocation];
+
+    for (NSScreen *screen in [NSScreen screens])
+    {
+        if (NSMouseInRect (p, [screen frame], NO))
+        {
+            return [screen visibleFrame];
+        }
+    }
+
+    return [[NSScreen mainScreen] visibleFrame];
+}
+
+/* Center @window's NSWindow in the visibleFrame stored in @d. Safe to call
+ * any time after the surface exists; a no-op for maximized/fullscreen
+ * windows (position-only override, never size/state). */
+static void
+macos_center_data_apply (const ReopenCenterData *d)
+{
+    if (d->window == NULL ||
+        !gtk_widget_get_realized (GTK_WIDGET (d->window)) ||
+        gtk_window_is_maximized (d->window) ||
+        gtk_window_is_fullscreen (d->window))
+    {
+        return;
+    }
+
+    GdkSurface *surface = gtk_native_get_surface (GTK_NATIVE (d->window));
+
+    if (surface == NULL || !GDK_IS_MACOS_SURFACE (surface))
+    {
+        return;
+    }
+
+    NSWindow *nswindow = (NSWindow *) gdk_macos_surface_get_native_window (GDK_MACOS_SURFACE (surface));
+
+    if (nswindow == nil)
+    {
+        return;
+    }
+
+    NSRect frame = [nswindow frame];
+    NSPoint origin = NSMakePoint (d->x + (d->w - frame.size.width) / 2.0,
+                                  d->y + (d->h - frame.size.height) / 2.0);
+
+    [nswindow setFrameOrigin:origin];
+    /* visible == NO here proves the first frame the user ever sees is
+     * already the centered one (no wrong-screen flash). */
+    g_debug ("Window placement: centered at %.0f,%.0f on screen visibleFrame "
+             "%.0f,%.0f %.0fx%.0f (was visible before move: %s)",
+             origin.x, origin.y, d->x, d->y, d->w, d->h,
+             [nswindow isVisible] ? "YES" : "no");
+}
+
+static void
+reopen_center_on_map (GtkWidget *widget,
+                      gpointer   user_data)
+{
+    ReopenCenterData *d = user_data;
+
+    /* Synchronous on purpose — this is what makes placement flash-free.
+     * The "map" signal's RUN_FIRST class closure (GtkWindow.map →
+     * gdk_toplevel_present) has already run: the NSWindow exists at its
+     * final size and GDK has applied its own (possibly wrong-screen)
+     * placement. But GDK only orders the NSWindow front at the FIRST
+     * BUFFER SWAP (_gdk_macos_surface_show just sets show_on_next_swap;
+     * see gdkmacossurface.c), which happens after this emission when the
+     * frame clock paints. Moving the window here therefore precedes any
+     * visibility; a deferred idle would lose that race and briefly show
+     * the window at GDK's position. */
+    macos_center_data_apply (d);
+
+    /* Disconnecting frees d via the closure's destroy-notify (which also
+     * guards the window-never-mapped case: widget destruction drops the
+     * ref, no leak). */
+    g_signal_handlers_disconnect_by_func (widget, (gpointer) reopen_center_on_map, d);
+}
+
+static void
+reopen_center_data_destroy (gpointer  data,
+                            GClosure *closure)
+{
+    ReopenCenterData *d = data;
+
+    (void) closure;
+    g_clear_object (&d->window);
+    g_free (d);
+}
+
+static void
+macos_schedule_center_window_on_rect (GtkWindow *window,
+                                      NSRect     target)
+{
+    ReopenCenterData *d = g_new0 (ReopenCenterData, 1);
+
+    d->window = g_object_ref (window);
+    d->x = target.origin.x;
+    d->y = target.origin.y;
+    d->w = target.size.width;
+    d->h = target.size.height;
+
+    if (gtk_widget_get_mapped (GTK_WIDGET (window)))
+    {
+        /* Already mapped (reopen path: activation presented the window
+         * synchronously). GDK's delayed show hasn't ordered the NSWindow
+         * front yet — that happens at the first buffer swap, i.e. the next
+         * paint cycle — so moving it synchronously HERE is still before
+         * first visibility. (An idle would run at a lower priority than
+         * the redraw and flash the window at GDK's position first.) */
+        macos_center_data_apply (d);
+        g_clear_object (&d->window);
+        g_free (d);
+    }
+    else
+    {
+        g_signal_connect_data (window, "map",
+                               G_CALLBACK (reopen_center_on_map), d,
+                               reopen_center_data_destroy, 0);
+    }
+}
+
+/* Reopen path: g_application_activate() presents AND paints the new window
+ * before it returns (the first buffer swap — and with it GDK's delayed
+ * orderFront — happens inside the activation cycle), so scheduling the move
+ * after activate is too late: the window is already visible at GDK's
+ * wrong-screen position for a frame or two. Instead a one-shot
+ * "window-added" handler (fires during GtkWindow construction, well before
+ * realize/present) arms the map hook on the new window — same flash-free
+ * ordering as the cold-launch path. */
+static void
+reopen_center_on_window_added (GtkApplication *application,
+                               GtkWindow      *window,
+                               gpointer        user_data)
+{
+    ReopenCenterData *d = user_data;
+    NSRect target = NSMakeRect (d->x, d->y, d->w, d->h);
+
+    macos_schedule_center_window_on_rect (window, target);
+    g_signal_handlers_disconnect_by_func (application,
+                                          (gpointer) reopen_center_on_window_added,
+                                          d);
+}
+
+static void
+macos_center_next_window_on_rect (GtkApplication *app,
+                                  NSRect          target)
+{
+    ReopenCenterData *d = g_new0 (ReopenCenterData, 1);
+
+    d->window = NULL;
+    d->x = target.origin.x;
+    d->y = target.origin.y;
+    d->w = target.size.width;
+    d->h = target.size.height;
+
+    g_signal_connect_data (app, "window-added",
+                           G_CALLBACK (reopen_center_on_window_added), d,
+                           reopen_center_data_destroy, 0);
+}
+
+/* --- Cold-launch first-window placement ------------------------------------
+ *
+ * On a COLD launch GDK places the first window itself
+ * (_gdk_macos_display_position_toplevel), picking "the monitor under the
+ * mouse" — but it feeds raw AppKit bottom-left-origin [NSEvent mouseLocation]
+ * into _gdk_macos_display_get_monitor_at_display_coords(), which expects GDK
+ * top-left display coords. On multi-display setups that lands on the wrong
+ * screen. Same rule as the reopen path applies: center the FIRST window of a
+ * fresh process on the screen under the mouse at launch time (a Dock-click
+ * launch has the pointer on the Dock's screen).
+ *
+ * capture() runs early in GtkApplication::startup (before GTK settles, so a
+ * moving pointer can't skew the target); apply() is called from the window-
+ * creation path and arms the same synchronous-on-map machinery — one-shot,
+ * so session windows and later user-opened windows keep normal placement.
+ * Position only is overridden (maximized/fullscreen windows are skipped). */
+
+static NSRect launch_target_rect;
+static gboolean launch_target_valid = FALSE;
+static gboolean launch_placement_done = FALSE;
+
+void
+nautilus_macos_launch_placement_capture (void)
+{
+    @autoreleasepool
+    {
+        launch_target_rect = macos_mouse_screen_visible_frame ();
+        launch_target_valid = TRUE;
+    }
+}
+
+void
+nautilus_macos_launch_placement_apply (gpointer window)
+{
+    if (launch_placement_done || !launch_target_valid || window == NULL)
+    {
+        return;
+    }
+
+    launch_placement_done = TRUE;
+    g_debug ("Cold launch: centering first window on screen "
+             "visibleFrame %.0f,%.0f %.0fx%.0f",
+             launch_target_rect.origin.x, launch_target_rect.origin.y,
+             launch_target_rect.size.width, launch_target_rect.size.height);
+    macos_schedule_center_window_on_rect (GTK_WINDOW (window), launch_target_rect);
+}
+
+/* Clicking the Dock icon (or `open -a Nautilus`, or AppleScript `reopen`)
+ * sends the application a reopen Apple event, which AppKit routes to the
+ * NSApplicationDelegate's applicationShouldHandleReopen:hasVisibleWindows:.
+ * GTK4's GtkApplicationQuartzDelegate (gtk/gtkapplication-quartz.c) does NOT
+ * implement that method, so with no windows open a Dock click does nothing.
+ *
+ * Because the selector is entirely unimplemented on the delegate class, no
+ * swizzling is needed: class_addMethod() the missing method onto whatever
+ * class the installed [NSApp delegate] instance is. Returning YES lets
+ * AppKit do its normal thing (deminiaturize / raise windows) when windows
+ * exist; when none exist we g_application_activate() — Nautilus's activate
+ * vfunc opens a new browser window at $HOME — and return NO so AppKit
+ * doesn't also try to unhide anything. The AppKit runloop is integrated
+ * with the GLib main context on macOS, so calling into GLib here is safe. */
+static BOOL
+nautilus_reopen_imp (id        self_,
+                     SEL       _cmd,
+                     NSApplication *sender,
+                     BOOL      has_visible_windows)
+{
+    (void) self_;
+    (void) _cmd;
+    (void) sender;
+
+    GApplication *app = g_application_get_default ();
+    GList *windows = NULL;
+
+    if (app != NULL && GTK_IS_APPLICATION (app))
+    {
+        windows = gtk_application_get_windows (GTK_APPLICATION (app));
+    }
+
+    if (windows == NULL)
+    {
+        if (app != NULL)
+        {
+            /* Capture the target screen BEFORE activating: the pointer sits
+             * on the Dock icon the user just clicked. Arm the placement
+             * BEFORE activating too — activation paints (and shows) the
+             * new window before returning, so a post-activate move would
+             * flash it at GDK's position first. */
+            NSRect target = macos_mouse_screen_visible_frame ();
+
+            g_debug ("Dock reopen with no windows: activating application");
+            macos_center_next_window_on_rect (GTK_APPLICATION (app), target);
+            g_application_activate (app);
+        }
+        return NO;
+    }
+
+    /* Windows exist (possibly miniaturized/hidden): let AppKit handle it. */
+    g_debug ("Dock reopen with %u window(s), visible=%d: default AppKit handling",
+             g_list_length (windows), has_visible_windows);
+    return YES;
+}
+
+void
+nautilus_macos_lifecycle_install_reopen_handler (void)
+{
+    @autoreleasepool
+    {
+        id delegate = [NSApp delegate];
+
+        if (delegate == nil)
+        {
+            g_warning ("Dock reopen handler: NSApp has no delegate yet; "
+                       "Dock-click-with-no-windows will not open a window");
+            return;
+        }
+
+        SEL sel = @selector (applicationShouldHandleReopen:hasVisibleWindows:);
+
+        if ([delegate respondsToSelector:sel])
+        {
+            /* Already present (idempotent re-entry, or a future GTK that
+             * implements it — in which case we must not fight it). */
+            g_debug ("Dock reopen handler: delegate already responds; leaving as-is");
+            return;
+        }
+
+        /* Signature: BOOL (id, SEL, NSApplication *, BOOL) */
+        if (!class_addMethod (object_getClass (delegate), sel,
+                              (IMP) nautilus_reopen_imp, "c@:@c"))
+        {
+            g_warning ("Dock reopen handler: class_addMethod failed");
+            return;
+        }
+
+        g_debug ("Dock reopen handler: installed on %s",
+                 class_getName (object_getClass (delegate)));
+    }
+}
+
+void
+nautilus_macos_menu_init (void)
+{
+    /* The menu bar itself is GMenu on the GTK side; AppKit-level tweaks:
+     * the dev-run Dock icon, and the app-menu "Check Permissions…" and
+     * "Finder Integration…" items (deferred until GTK has installed the
+     * menubar; the latter also waits for the former so the order is
+     * stable). */
+    macos_set_dev_dock_icon ();
+    nautilus_macos_menu_add_check_permissions_item ();
+    nautilus_macos_menu_add_finder_integration_item ();
+    nautilus_macos_menu_add_check_updates_item ();
+}
diff --git a/src/nautilus-macos-openwith.m b/src/nautilus-macos-openwith.m
new file mode 100644
index 0000000..0941690
--- /dev/null
+++ b/src/nautilus-macos-openwith.m
@@ -0,0 +1,246 @@
+/*
+ * nautilus-macos-openwith.m: Open With / default apps via NSWorkspace (W2).
+ *
+ * Copyright (C) 2026 The Nautilus authors
+ *
+ * This program is free software; you can redistribute it and/or
+ * modify it under the terms of the GNU General Public License as
+ * published by the Free Software Foundation; either version 2 of the
+ * License, or (at your option) any later version.
+ *
+ * This program is distributed in the hope that it will be useful,
+ * but WITHOUT ANY WARRANTY; without even the implied warranty of
+ * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU
+ * General Public License for more details.
+ *
+ * You should have received a copy of the GNU General Public
+ * License along with this program; if not, see <http://www.gnu.org/licenses/>.
+ *
+ * Replaces the GAppInfo application-chooser contents on macOS with
+ * LaunchServices data: NSWorkspace URLsForApplicationsToOpenContentType: /
+ * openURLs:withApplicationAtURL:, and "Show in Finder" via
+ * activateFileViewerSelectingURLs:.
+ */
+
+#define G_LOG_DOMAIN "nautilus-macos-bridge"
+
+#include <config.h>
+#include "nautilus-macos-bridge.h"
+
+#import <AppKit/AppKit.h>
+#import <UniformTypeIdentifiers/UniformTypeIdentifiers.h>
+
+void
+nautilus_macos_app_candidate_free (NautilusMacosAppCandidate *candidate)
+{
+    if (candidate == NULL)
+    {
+        return;
+    }
+
+    g_free (candidate->display_name);
+    g_free (candidate->bundle_url);
+    g_free (candidate);
+}
+
+static NautilusMacosAppCandidate *
+candidate_new_for_app_url (NSURL    *app_url,
+                           gboolean  is_default)
+{
+    NautilusMacosAppCandidate *candidate = g_new0 (NautilusMacosAppCandidate, 1);
+    NSString *display_name = nil;
+
+    [app_url getResourceValue:&display_name
+                       forKey:NSURLLocalizedNameKey
+                        error:nil];
+    if (display_name == nil)
+    {
+        display_name = [[NSFileManager defaultManager] displayNameAtPath:[app_url path]];
+    }
+
+    /* Strip the ".app" Finder may leave on the localized name. */
+    if ([display_name hasSuffix:@".app"])
+    {
+        display_name = [display_name stringByDeletingPathExtension];
+    }
+
+    candidate->display_name = g_strdup ([display_name UTF8String]);
+    candidate->bundle_url = g_strdup ([[app_url absoluteString] UTF8String]);
+    candidate->is_default = is_default;
+
+    return candidate;
+}
+
+GList *
+nautilus_macos_get_apps_for_file (const char *path)
+{
+    g_return_val_if_fail (path != NULL, NULL);
+
+    @autoreleasepool
+    {
+        NSURL *file_url = [NSURL fileURLWithPath:@(path)];
+        NSWorkspace *workspace = [NSWorkspace sharedWorkspace];
+        GList *candidates = NULL;
+
+        /* Modern API (macOS 12+): per-file candidate list. Unlike the
+         * content-type variant this also honors per-extension overrides. */
+        NSArray<NSURL *> *app_urls = [workspace URLsForApplicationsToOpenURL:file_url];
+        NSURL *default_url = [workspace URLForApplicationToOpenURL:file_url];
+
+        /* Default app first. */
+        if (default_url != nil)
+        {
+            candidates = g_list_prepend (candidates,
+                                         candidate_new_for_app_url (default_url, TRUE));
+        }
+
+        for (NSURL *app_url in app_urls)
+        {
+            if (default_url != nil && [app_url isEqual:default_url])
+            {
+                continue;
+            }
+
+            candidates = g_list_prepend (candidates,
+                                         candidate_new_for_app_url (app_url, FALSE));
+        }
+
+        candidates = g_list_reverse (candidates);
+
+        g_debug ("nautilus_macos_get_apps_for_file: %u candidates for %s",
+                 g_list_length (candidates), path);
+
+        return candidates;
+    }
+}
+
+gboolean
+nautilus_macos_open_file_with (const char *path,
+                               const char *app_url)
+{
+    g_return_val_if_fail (path != NULL, FALSE);
+    g_return_val_if_fail (app_url != NULL, FALSE);
+
+    @autoreleasepool
+    {
+        NSURL *file_url = [NSURL fileURLWithPath:@(path)];
+        NSURL *application_url = [NSURL URLWithString:@(app_url)];
+
+        if (application_url == nil)
+        {
+            g_warning ("nautilus_macos_open_file_with: invalid app URL %s", app_url);
+            return FALSE;
+        }
+
+        NSWorkspaceOpenConfiguration *configuration =
+            [NSWorkspaceOpenConfiguration configuration];
+        configuration.activates = YES;
+
+        /* The completion handler outlives this call; capture NSString
+         * copies, not the caller-owned C strings. */
+        NSString *path_str = @(path);
+        NSString *app_url_str = @(app_url);
+
+        [[NSWorkspace sharedWorkspace]
+                    openURLs:@[file_url]
+         withApplicationAtURL:application_url
+               configuration:configuration
+           completionHandler:^(NSRunningApplication *app, NSError *error)
+        {
+            if (error != nil)
+            {
+                g_warning ("Launching %s with %s failed: %s",
+                           [path_str UTF8String], [app_url_str UTF8String],
+                           [[error localizedDescription] UTF8String]);
+            }
+        }];
+
+        return TRUE;
+    }
+}
+
+gboolean
+nautilus_macos_show_in_finder (const char *path)
+{
+    g_return_val_if_fail (path != NULL, FALSE);
+
+    const char *paths[] = { path, NULL };
+    return nautilus_macos_show_in_finder_files (paths);
+}
+
+GdkTexture *
+nautilus_macos_app_icon_texture (const char *app_path,
+                                 int         size_px)
+{
+    g_return_val_if_fail (app_path != NULL, NULL);
+    g_return_val_if_fail (size_px > 0, NULL);
+
+    @autoreleasepool
+    {
+        NSImage *icon = [[NSWorkspace sharedWorkspace] iconForFile:@(app_path)];
+
+        if (icon == nil)
+        {
+            return NULL;
+        }
+
+        const size_t stride = (size_t) size_px * 4;
+        CGColorSpaceRef color_space = CGColorSpaceCreateDeviceRGB ();
+        CGContextRef context =
+            CGBitmapContextCreate (NULL, size_px, size_px, 8, stride, color_space,
+                                   kCGImageAlphaPremultipliedLast | kCGBitmapByteOrder32Big);
+        CGColorSpaceRelease (color_space);
+
+        if (context == NULL)
+        {
+            return NULL;
+        }
+
+        NSGraphicsContext *ns_context =
+            [NSGraphicsContext graphicsContextWithCGContext:context flipped:NO];
+
+        [NSGraphicsContext saveGraphicsState];
+        [NSGraphicsContext setCurrentContext:ns_context];
+        [icon drawInRect:NSMakeRect (0, 0, size_px, size_px)
+                fromRect:NSZeroRect
+               operation:NSCompositingOperationCopy
+                fraction:1.0];
+        [NSGraphicsContext restoreGraphicsState];
+
+        /* Bitmap layout matches GDK_MEMORY_R8G8B8A8_PREMULTIPLIED (R,G,B,A
+         * in memory, premultiplied alpha), so the pixels transfer verbatim. */
+        g_autoptr (GBytes) bytes =
+            g_bytes_new (CGBitmapContextGetData (context), stride * size_px);
+        GdkTexture *texture =
+            gdk_memory_texture_new (size_px, size_px,
+                                    GDK_MEMORY_R8G8B8A8_PREMULTIPLIED,
+                                    bytes, stride);
+
+        CGContextRelease (context);
+
+        return texture;
+    }
+}
+
+gboolean
+nautilus_macos_show_in_finder_files (const char *const *paths)
+{
+    g_return_val_if_fail (paths != NULL && paths[0] != NULL, FALSE);
+
+    @autoreleasepool
+    {
+        NSMutableArray<NSURL *> *urls = [NSMutableArray array];
+
+        for (const char *const *p = paths; *p != NULL; p++)
+        {
+            [urls addObject:[NSURL fileURLWithPath:@(*p)]];
+        }
+
+        [[NSWorkspace sharedWorkspace] activateFileViewerSelectingURLs:urls];
+
+        g_debug ("nautilus_macos_show_in_finder_files: revealed %lu paths",
+                 (unsigned long) [urls count]);
+
+        return TRUE;
+    }
+}
diff --git a/src/nautilus-macos-previewer.m b/src/nautilus-macos-previewer.m
new file mode 100644
index 0000000..e0fca11
--- /dev/null
+++ b/src/nautilus-macos-previewer.m
@@ -0,0 +1,283 @@
+/*
+ * nautilus-macos-previewer.m: QuickLook space-bar preview (W2).
+ *
+ * Copyright (C) 2026 The Nautilus authors
+ *
+ * This program is free software; you can redistribute it and/or
+ * modify it under the terms of the GNU General Public License as
+ * published by the Free Software Foundation; either version 2 of the
+ * License, or (at your option) any later version.
+ *
+ * This program is distributed in the hope that it will be useful,
+ * but WITHOUT ANY WARRANTY; without even the implied warranty of
+ * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU
+ * General Public License for more details.
+ *
+ * You should have received a copy of the GNU General Public
+ * License along with this program; if not, see <http://www.gnu.org/licenses/>.
+ *
+ * Replaces the Sushi D-Bus previewer (nautilus-previewer.c) with the
+ * system QLPreviewPanel (Quartz / QuickLookUI framework).
+ *
+ * QLPreviewPanel normally locates its data source by walking the responder
+ * chain of the main window for an object implementing the
+ * QLPreviewPanelController informal protocol. Nautilus windows are GTK
+ * (GdkMacosWindow) objects that know nothing about QuickLook, so we add a
+ * lightweight NSWindow category that accepts panel control and hands both
+ * dataSource and delegate duties to a process-wide controller singleton.
+ */
+
+#define G_LOG_DOMAIN "nautilus-macos-bridge"
+
+#include <config.h>
+#include "nautilus-macos-bridge.h"
+
+#import <AppKit/AppKit.h>
+#import <Quartz/Quartz.h>
+
+/* -------------------------------------------------------------------------
+ * Controller singleton: owns the item list, feeds the panel, forwards
+ * arrow-key navigation back to the C side.
+ * ------------------------------------------------------------------------- */
+
+@interface NautilusQLController : NSObject <QLPreviewPanelDataSource, QLPreviewPanelDelegate>
+
+@property (strong) NSArray<NSURL *> *items;
+
++ (NautilusQLController *) shared;
+
+@end
+
+static NautilusMacosPreviewSelectionFunc selection_callback = NULL;
+static gpointer selection_callback_data = NULL;
+
+/* Deliver the selection event from an idle so it does not re-enter the
+ * panel (reloadData & co) while it is still dispatching the key event —
+ * doing that synchronously tears the panel window down. */
+static gboolean
+deliver_selection_event (gpointer data)
+{
+    if (selection_callback != NULL)
+    {
+        selection_callback ((NautilusMacosPreviewDirection) GPOINTER_TO_INT (data),
+                            selection_callback_data);
+    }
+
+    return G_SOURCE_REMOVE;
+}
+
+@implementation NautilusQLController
+
++ (NautilusQLController *) shared
+{
+    static NautilusQLController *instance = nil;
+    static dispatch_once_t once;
+
+    dispatch_once (&once, ^{
+        instance = [[NautilusQLController alloc] init];
+        instance.items = @[];
+    });
+
+    return instance;
+}
+
+- (NSInteger) numberOfPreviewItemsInPreviewPanel: (QLPreviewPanel *) panel
+{
+    return (NSInteger) [self.items count];
+}
+
+- (id<QLPreviewItem>) previewPanel: (QLPreviewPanel *) panel
+                previewItemAtIndex: (NSInteger) index
+{
+    if (index < 0 || (NSUInteger) index >= [self.items count])
+    {
+        return nil;
+    }
+
+    return self.items[(NSUInteger) index];
+}
+
+- (BOOL) previewPanel: (QLPreviewPanel *) panel
+          handleEvent: (NSEvent *) event
+{
+    if ([event type] != NSEventTypeKeyDown || selection_callback == NULL)
+    {
+        return NO;
+    }
+
+    NautilusMacosPreviewDirection direction;
+
+    switch ([event keyCode])
+    {
+        case 123: /* kVK_LeftArrow */
+        {
+            direction = NAUTILUS_MACOS_PREVIEW_DIRECTION_LEFT;
+        }
+        break;
+
+        case 124: /* kVK_RightArrow */
+        {
+            direction = NAUTILUS_MACOS_PREVIEW_DIRECTION_RIGHT;
+        }
+        break;
+
+        case 125: /* kVK_DownArrow */
+        {
+            direction = NAUTILUS_MACOS_PREVIEW_DIRECTION_DOWN;
+        }
+        break;
+
+        case 126: /* kVK_UpArrow */
+        {
+            direction = NAUTILUS_MACOS_PREVIEW_DIRECTION_UP;
+        }
+        break;
+
+        default:
+        {
+            return NO;
+        }
+    }
+
+    /* The panel natively pages through its own item list with Left/Right
+     * when it holds more than one item; only forward the directions it
+     * does not consume, so single-item panels track the files-view
+     * selection (Finder behavior) and multi-item panels page normally. */
+    if ([self.items count] > 1 &&
+        (direction == NAUTILUS_MACOS_PREVIEW_DIRECTION_LEFT ||
+         direction == NAUTILUS_MACOS_PREVIEW_DIRECTION_RIGHT))
+    {
+        return NO;
+    }
+
+    g_idle_add (deliver_selection_event, GINT_TO_POINTER (direction));
+
+    return YES;
+}
+
+@end
+
+/* -------------------------------------------------------------------------
+ * QLPreviewPanelController adoption for all NSWindows (GTK windows included)
+ * ------------------------------------------------------------------------- */
+
+@interface NSWindow (NautilusQuickLookControl)
+@end
+
+@implementation NSWindow (NautilusQuickLookControl)
+
+- (BOOL) acceptsPreviewPanelControl: (QLPreviewPanel *) panel
+{
+    return YES;
+}
+
+- (void) beginPreviewPanelControl: (QLPreviewPanel *) panel
+{
+    panel.dataSource = [NautilusQLController shared];
+    panel.delegate = [NautilusQLController shared];
+}
+
+- (void) endPreviewPanelControl: (QLPreviewPanel *) panel
+{
+    panel.dataSource = nil;
+    panel.delegate = nil;
+}
+
+@end
+
+/* -------------------------------------------------------------------------
+ * C seams
+ * ------------------------------------------------------------------------- */
+
+void
+nautilus_macos_preview_set_selection_callback (NautilusMacosPreviewSelectionFunc callback,
+                                               gpointer                          user_data)
+{
+    selection_callback = callback;
+    selection_callback_data = user_data;
+}
+
+void
+nautilus_macos_preview_files (const char *const *uris,
+                              int                selected_index)
+{
+    g_return_if_fail (uris != NULL);
+
+    @autoreleasepool
+    {
+        NSMutableArray<NSURL *> *items = [NSMutableArray array];
+
+        for (const char *const *p = uris; *p != NULL; p++)
+        {
+            g_autofree char *path = g_filename_from_uri (*p, NULL, NULL);
+
+            if (path == NULL)
+            {
+                g_debug ("nautilus_macos_preview_files: skipping non-local uri %s", *p);
+                continue;
+            }
+
+            [items addObject:[NSURL fileURLWithPath:@(path)]];
+        }
+
+        if ([items count] == 0)
+        {
+            g_debug ("nautilus_macos_preview_files: nothing local to preview");
+            return;
+        }
+
+        if (selected_index < 0 || (NSUInteger) selected_index >= [items count])
+        {
+            selected_index = 0;
+        }
+
+        NautilusQLController *controller = [NautilusQLController shared];
+        controller.items = items;
+
+        QLPreviewPanel *panel = [QLPreviewPanel sharedPreviewPanel];
+
+        if ([panel isVisible])
+        {
+            [panel reloadData];
+        }
+        else
+        {
+            [panel updateController];
+            [panel makeKeyAndOrderFront:nil];
+        }
+
+        /* If the responder-chain search failed (no main window, panel not
+         * yet begun), wire the controller in directly as a fallback. */
+        if (panel.dataSource == nil)
+        {
+            g_debug ("nautilus_macos_preview_files: controller not adopted "
+                     "via responder chain, setting dataSource directly");
+            panel.dataSource = controller;
+            panel.delegate = controller;
+            [panel reloadData];
+        }
+
+        panel.currentPreviewItemIndex = selected_index;
+    }
+}
+
+void
+nautilus_macos_preview_hide (void)
+{
+    if ([QLPreviewPanel sharedPreviewPanelExists] &&
+        [[QLPreviewPanel sharedPreviewPanel] isVisible])
+    {
+        [[QLPreviewPanel sharedPreviewPanel] orderOut:nil];
+
+        /* The panel was the key window; GTK does not reclaim key status by
+         * itself, which would leave the app deaf to keyboard input. */
+        [[NSApp mainWindow] makeKeyWindow];
+    }
+}
+
+gboolean
+nautilus_macos_preview_is_showing (void)
+{
+    return [QLPreviewPanel sharedPreviewPanelExists] &&
+           [[QLPreviewPanel sharedPreviewPanel] isVisible];
+}
