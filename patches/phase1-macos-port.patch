+/* memrchr() is a GNU extension not available in macOS libc. */
+static const void *
+memrchr (const void *s,
+         int         c,
+         size_t      n)
+{
+    const unsigned char *p = s;
+
+    for (size_t i = n; i > 0; i--)
+    {
+        if (p[i - 1] == (unsigned char) c)
+        {
+            return p + (i - 1);
+        }
+    }
